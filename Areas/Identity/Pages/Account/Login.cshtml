@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="max-w-5xl mx-auto px-4 py-10">

    <h1 class="text-3xl font-bold tracking-tight mb-8">@ViewData["Title"]</h1>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Local account login -->
        <div>
            <section>
                <form id="account" method="post">
                    <h2 class="text-xl font-semibold mb-1">Use a local account to log in</h2>
                    <hr class="border-gray-200 mb-6" />

                    <div asp-validation-summary="ModelOnly" class="mb-4 p-3 rounded-lg border border-red-200 bg-red-50 text-sm text-red-600" role="alert"></div>

                    <!-- Email -->
                    <div class="mb-4">
                        <label asp-for="Input.Username" class="block text-sm font-semibold text-gray-800 mb-2">Email</label>
                        <input asp-for="Input.Username" autocomplete="username" aria-required="true" placeholder="name@example.com"
                               class="block w-full border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-300 outline-none focus:border-gray-900 transition-colors" />
                        <span asp-validation-for="Input.Username" class="mt-1 block text-xs text-red-600"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-4">
                        <label asp-for="Input.Password" class="block text-sm font-semibold text-gray-800 mb-2">Password</label>
                        <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder="Password"
                               class="block w-full border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-300 outline-none focus:border-gray-900 transition-colors" />
                        <span asp-validation-for="Input.Password" class="mt-1 block text-xs text-red-600"></span>
                    </div>

                    <!-- Remember me -->
                    <div class="mb-6">
                        <label asp-for="Input.RememberMe" class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer select-none">
                            <input asp-for="Input.RememberMe" class="w-4 h-4 rounded border-gray-300 text-gray-900 focus:ring-0 focus:ring-offset-0" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>

                    <button id="login-submit" type="submit"
                            class="w-full inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-semibold hover:bg-gray-700 transition-colors">
                        Log in
                    </button>

                    <div class="mt-6 flex flex-col gap-2 text-sm">
                        <a id="forgot-password" asp-page="./ForgotPassword" class="text-gray-900 underline hover:text-gray-700 transition-colors">Forgot your password?</a>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-gray-900 underline hover:text-gray-700 transition-colors">Register as a new user</a>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-gray-900 underline hover:text-gray-700 transition-colors">Resend email confirmation</a>
                    </div>
                </form>
            </section>
        </div>

        <!-- External services -->
        <div>
            <section>
                <h3 class="text-lg font-semibold mb-1">Use another service to log in</h3>
                <hr class="border-gray-200 mb-6" />

                @{
                    if ((Model.ExternalLogins?.Count ?? 0) == 0)
                    {
                        <div class="text-sm text-gray-500 leading-relaxed">
                            <p>
                                There are no external authentication services configured. See this
                                <a href="https://go.microsoft.com/fwlink/?LinkID=532715" class="text-gray-900 underline hover:text-gray-700 transition-colors">
                                    article
                                    about setting up this ASP.NET application to support logging in via external services
                                </a>.
                            </p>
                        </div>
                    }
                    else
                    {
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <div class="flex flex-wrap gap-2">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" name="provider" value="@provider.Name"
                                            title="Log in using your @provider.DisplayName account"
                                            class="inline-flex items-center px-4 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 bg-white hover:border-gray-900 hover:text-gray-900 transition-colors">
                                        @provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    }
                }
            </section>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}