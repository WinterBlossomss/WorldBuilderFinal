@page
@model LoginModel

@{
    ViewData["Title"] = "Sign in";

    // Registry-aesthetic tokens (mirrors Home/Index.cshtml)
    const string hatch    = "bg-[repeating-linear-gradient(135deg,transparent_0_10px,rgba(26,26,26,0.08)_10px_11px)]";
    const string panel    = "border border-stone-300 bg-stone-100 p-8";
    const string fieldLbl = "block font-sans text-xs uppercase tracking-widest text-stone-600 mb-2";
    const string field    = "w-full bg-white border border-stone-400 px-4 py-3 font-sans text-sm text-stone-900 placeholder:text-stone-400 outline-none focus:border-teal-900 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#a3712a] focus-visible:outline-offset-2";
    const string fieldErr = "block mt-2 font-sans text-xs text-red-700";
    const string btnFill  = "w-full inline-flex items-center justify-center gap-2 font-sans text-sm tracking-[.06em] uppercase px-8 py-3 bg-stone-900 text-stone-50 cursor-pointer hover:bg-teal-900 transition-colors";
    const string btnLine  = "inline-flex items-center gap-2 font-sans text-xs tracking-[.06em] uppercase px-4 py-2.5 border border-stone-300 bg-stone-100 text-stone-700 cursor-pointer hover:border-teal-900 hover:text-teal-900 transition-colors";
    const string link     = "text-teal-900 underline underline-offset-4 hover:text-stone-900 transition-colors";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 text-stone-900">

    <!-- Header: eyebrow + title + subtitle -->
    <header class="flex items-start gap-4 pb-6 mb-8 border-b border-stone-300">
        <div class="hidden sm:block w-12 h-12 shrink-0 border border-stone-300 @hatch" aria-hidden="true"></div>
        <div class="min-w-0">
            <span class="font-sans text-xs tracking-[.22em] uppercase text-teal-900">Registry access</span>
            <h1 class="font-serif font-semibold text-4xl tracking-tight leading-none mt-1.5">@ViewData["Title"]</h1>
            <p class="font-sans text-sm text-stone-600 mt-2 max-w-xl">
                Pick up where you left off. Your worlds, scripts and drafts are exactly as you left them.
            </p>
        </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-[1.7fr_1fr] gap-8 items-start">

        <!-- Local account -->
        <section>
            <form id="account" method="post" class="@panel">

                <div class="pb-4 mb-6 border-b border-dashed border-stone-300">
                    <span class="font-sans text-[11px] tracking-[.22em] uppercase text-teal-900">Local account</span>
                    <h2 class="font-serif font-semibold text-2xl tracking-tight mt-1">Sign in with your email</h2>
                </div>

                <div asp-validation-summary="ModelOnly" role="alert"
                     class="empty:hidden mb-6 border border-red-700 bg-red-50 px-5 py-4 font-sans text-sm text-red-800"></div>

                <!-- Email -->
                <div class="mb-6">
                    <label asp-for="Input.Username" class="@fieldLbl">Email</label>
                    <input asp-for="Input.Username" autocomplete="username" aria-required="true"
                           placeholder="name@example.com" class="@field" />
                    <span asp-validation-for="Input.Username" class="@fieldErr"></span>
                </div>

                <!-- Password -->
                <div class="mb-6">
                    <div class="flex items-baseline justify-between gap-3 mb-2">
                        <label asp-for="Input.Password" class="@fieldLbl mb-0">Password</label>
                        <a id="forgot-password" asp-page="./ForgotPassword"
                           class="font-sans text-xs text-stone-500 hover:text-teal-900 no-underline transition-colors">
                            Forgot it?
                        </a>
                    </div>
                    <input asp-for="Input.Password" autocomplete="current-password" aria-required="true"
                           placeholder="••••••••" class="@field" />
                    <span asp-validation-for="Input.Password" class="@fieldErr"></span>
                </div>

                <!-- Remember me -->
                <div class="mb-8">
                    <label asp-for="Input.RememberMe"
                           class="inline-flex items-center gap-2.5 font-sans text-sm text-stone-700 cursor-pointer select-none">
                        <input asp-for="Input.RememberMe"
                               class="w-4 h-4 shrink-0 border border-stone-400 cursor-pointer focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#a3712a] focus-visible:outline-offset-2" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                <button id="login-submit" type="submit" class="@btnFill">Sign in</button>

                <div class="mt-6 pt-5 border-t border-dashed border-stone-300 font-sans text-sm text-stone-600">
                    <p class="mb-2">
                        No account yet?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="@link">Create one</a>
                    </p>
                    <p>
                        Confirmation email never arrived?
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="@link">Send it again</a>
                    </p>
                </div>
            </form>
        </section>

        <!-- External services -->
        <aside>
            <section class="border border-stone-300 bg-stone-100 p-6">
                <div class="pb-4 mb-5 border-b border-dashed border-stone-300">
                    <span class="font-sans text-[11px] tracking-[.22em] uppercase text-teal-900">Elsewhere</span>
                    <h2 class="font-serif font-semibold text-xl tracking-tight mt-1">Use another service</h2>
                </div>

                @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <p class="font-sans text-sm text-stone-600 leading-relaxed">
                        No external sign-in services are configured yet. Set them up in the
                        <a href="https://go.microsoft.com/fwlink/?LinkID=532715" class="@link">ASP.NET external providers guide</a>.
                    </p>
                }
                else
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div class="flex flex-wrap gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" name="provider" value="@provider.Name"
                                        title="Sign in with your @provider.DisplayName account" class="@btnLine">
                                    @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                }
            </section>

            <p class="mt-4 font-sans text-xs tracking-[.06em] text-stone-500 leading-relaxed">
                Signing in keeps your private worlds private — only you and the people you invite can read them.
            </p>
        </aside>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
