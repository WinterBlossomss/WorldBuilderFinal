@using Microsoft.AspNetCore.Identity
@model WorldBuilder.Models.World
@inject UserManager<IdentityUser> UserManager
@{
    var allPictures = ViewData["Pictures"] as List<Picture>;
    var cover = allPictures?.FirstOrDefault(p => p.PicWorldFK == Model.WorldIDPK);

    var authorId = Model.WorldUserFKNavigation?.UserInfoUserIDFK;
    var author = authorId is null ? null : await UserManager.FindByIdAsync(authorId);
}

<a asp-action="Details" asp-route-id="@Model.WorldIDPK"
   class="bg-stone-100 border border-stone-300 flex flex-col w-[240px] shrink-0 snap-start text-stone-900 no-underline group
    transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_14px_26px_rgba(33,28,20,0.10)] hover:border-[#1c4551]">
    <div class="aspect-[16/9] w-full shrink-0 border-b border-stone-300 bg-[repeating-linear-gradient(135deg,transparent_0_10px,rgba(26,26,26,0.08)_10px_11px)] flex items-center justify-center overflow-hidden">
        @if (cover != null && !string.IsNullOrEmpty(cover.PicPath))
        {
            <img src="~/@cover.PicPath" alt="@cover.PicCaption" class="w-full h-full object-cover" />
        }
        else
        {
            <span class="bg-[#f7f3ea] px-1.5 py-px text-[12px] text-[#a89f8e] relative z-10">@Model.WorldName</span>
        }
    </div>
    <div class="p-[15px] pb-[17px] flex flex-col flex-1 min-h-0">
        <div class="text-lg font-semibold truncate leading-tight group-hover:underline">@Model.WorldName</div>
        <div class="text-[11px] text-[#a89f8e] truncate">by @@@(author?.UserName ?? "creator")</div>
        @if (!string.IsNullOrEmpty(Model.WorldDesc))
        {
            <div class="text-[11.5px] text-[#444444] leading-snug mt-0.5 line-clamp-2">@Model.WorldDesc</div>
        }
        <div class="flex items-center gap-2 mt-auto pt-2 text-[11px]">
            <span class="inline-flex items-center gap-1">
                <svg width="11" height="10" viewBox="0 0 24 22" fill="none"><path d="M12 20 C 4 14, 2 9, 5 5 C 8 1, 12 5, 12 8 C 12 5, 16 1, 19 5 C 22 9, 20 14, 12 20 Z" stroke="#1a1a1a" stroke-width="1.8" fill="none" /></svg>
                @(Model.WorldLikes ?? 0)
            </span>
            <span class="text-[#a89f8e]">·</span>
            <span class="inline-flex items-center gap-1">
                <svg width="9" height="11" viewBox="0 0 9 11" fill="none"><path d="M1 1 H 6 L 8 3 V 10 H 1 Z" stroke="#1a1a1a" stroke-width="1.2" fill="none" /><line x1="2.5" y1="5" x2="6.5" y2="5" stroke="#1a1a1a" stroke-width="1" /><line x1="2.5" y1="7" x2="6.5" y2="7" stroke="#1a1a1a" stroke-width="1" /></svg>
                @(Model.Categories?.Count ?? 0) categories
            </span>
        </div>
    </div>
</a>