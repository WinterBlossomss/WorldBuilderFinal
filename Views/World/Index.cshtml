@model IEnumerable<WorldBuilder.Models.World>

@{
    ViewData["Title"] = "Browse Worlds";

    var worlds = (Model ?? Enumerable.Empty<WorldBuilder.Models.World>()).ToList();
    var total = worlds.Count;

    var chips = (ViewData["Genres"] as List<string>) ?? new List<string>();

    // Active filter state (echoed back from the controller)
    var activeQ = ViewData["Query"] as string ?? "";
    var activeGenre = ViewData["Genre"] as string ?? "";
    var activeSort = ViewData["Sort"] as string ?? "";
    var totalAll = ViewData["TotalAll"] is int t ? t : total;

    var filtering = !string.IsNullOrWhiteSpace(activeQ) || !string.IsNullOrWhiteSpace(activeGenre);
    var allActive = string.IsNullOrWhiteSpace(activeGenre);

    var sortLabel = activeSort switch
    {
        "newest" => "Newest",
        "loved" => "Most loved",
        "name" => "Z–A",
        _ => "Featured"
    };

    // Which discover rows this sort exposes
    var showNewest = activeSort is "" or "newest" or "name";
    var showLoved = activeSort is "" or "loved" or "name";
    var showByGenre = string.IsNullOrWhiteSpace(activeSort);

    // Discover-row data (used when no filter is active)
    var newest = worlds.OrderByDescending(w => w.WorldCreatedAt).Take(8).ToList();
    var loved = worlds.OrderByDescending(w => w.WorldLikes ?? 0).Take(8).ToList();

    // Z–A keeps both rows but reorders their contents
    if (activeSort == "name")
    {
        newest = newest.OrderByDescending(w => w.WorldName).ToList();
        loved = loved.OrderByDescending(w => w.WorldName).ToList();
    }

    var byGenre = worlds.Where(w => !string.IsNullOrEmpty(w.WorldGenFK))
                        .GroupBy(w => w.WorldGenFK)
                        .OrderByDescending(g => g.Count());

    // Only used when filtering returns nothing
    var related = chips.Where(c => c != activeGenre).Take(4).ToList();

    // Registry-aesthetic tokens (mirrors Home/Index.cshtml)
    const string chipOn = "font-sans text-xs tracking-[.06em] uppercase px-3 py-1.5 border border-stone-900 bg-stone-900 text-stone-50 no-underline cursor-pointer";
    const string chipOff = "font-sans text-xs tracking-[.06em] uppercase px-3 py-1.5 border border-stone-300 text-stone-600 no-underline cursor-pointer hover:border-teal-900 hover:text-teal-900 transition-colors";
    const string btnFill = "inline-flex items-center gap-2 font-sans text-sm px-6 py-3 bg-stone-900 text-stone-50 no-underline hover:bg-teal-900 transition-colors";
    const string btnLine = "inline-flex items-center gap-2 font-sans text-sm px-6 py-3 border border-stone-300 text-stone-900 no-underline hover:border-teal-900 hover:text-teal-900 transition-colors";
}

<!-- Width is like that to make sure cards fit perfectly-->
<div class="max-w-[calc(5*240px+4*1rem+3rem)] mx-auto px-6 py-10 text-stone-900">

    <!-- Header: eyebrow + title + subtitle -->
    <span class="font-sans text-xs tracking-[.22em] uppercase text-teal-900">Browse the registry</span>
    <h1 class="font-serif font-semibold text-3xl text-[clamp(28px,4vw,40px)] tracking-[-.01em] leading-[1.05] mt-2 mb-2">Find a world</h1>
    @if (filtering)
    {
        <p class="font-sans text-sm text-stone-600 mb-6">@total.ToString("N0") of @totalAll.ToString("N0") worlds match your filters</p>
    }
    else
    {
        <p class="font-sans text-sm text-stone-600 mb-6">@totalAll.ToString("N0") user-built worlds · pick a genre or just start scrolling</p>
    }

    <!-- Search bar (keeps genre + sort while searching) -->
    <form asp-action="Index" method="get" class="flex items-center gap-3 border border-stone-300 bg-stone-100 px-4 py-3 mb-5">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="6.5" cy="6.5" r="4.5" stroke="#57534e" stroke-width="1.4" />
            <line x1="10" y1="10" x2="14.5" y2="14.5" stroke="#57534e" stroke-width="1.4" stroke-linecap="round" />
        </svg>
        <input name="q" value="@activeQ" placeholder="Search by title, creator, tag, or lore keyword…"
               class="flex-1 outline-none font-sans text-sm bg-transparent placeholder-stone-400" />
        <input type="hidden" name="genre" value="@activeGenre" />
        <input type="hidden" name="sort" value="@activeSort" />
        @if (!string.IsNullOrWhiteSpace(activeQ))
        {
            <a asp-action="Index" asp-route-genre="@activeGenre" asp-route-sort="@activeSort"
               class="font-sans text-xs text-stone-500 no-underline whitespace-nowrap hover:text-teal-900 transition-colors">✕ clear</a>
        }
    </form>

    <!-- Filter toolbar -->
    <div class="flex items-center justify-between mb-3">
        <span class="font-sans text-xs tracking-[.16em] uppercase text-stone-600">Filter by genre</span>
        <div class="flex gap-2">
            <details class="relative">
                <summary class="list-none [&::-webkit-details-marker]:hidden flex items-center gap-1.5 border border-stone-300 bg-stone-100 px-3 py-1.5 font-sans text-xs text-stone-700 cursor-pointer hover:border-teal-900 transition-colors">
                    Sort: @sortLabel
                    <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1 L 5 5 L 9 1" stroke="#57534e" stroke-width="1.4" fill="none" /></svg>
                </summary>
                <div class="absolute right-0 mt-1 bg-stone-100 border border-stone-300 py-1 z-20 min-w-[150px] shadow-[0_10px_24px_rgba(33,28,20,0.10)]">
                    <a asp-action="Index" asp-route-q="@activeQ" asp-route-genre="@activeGenre"
                       class="block px-3 py-1.5 font-sans text-xs text-stone-700 no-underline hover:bg-stone-200">Featured</a>
                    <a asp-action="Index" asp-route-q="@activeQ" asp-route-genre="@activeGenre" asp-route-sort="loved"
                       class="block px-3 py-1.5 font-sans text-xs text-stone-700 no-underline hover:bg-stone-200">Most loved</a>
                    <a asp-action="Index" asp-route-q="@activeQ" asp-route-genre="@activeGenre" asp-route-sort="newest"
                       class="block px-3 py-1.5 font-sans text-xs text-stone-700 no-underline hover:bg-stone-200">Newest</a>
                    <a asp-action="Index" asp-route-q="@activeQ" asp-route-genre="@activeGenre" asp-route-sort="name"
                       class="block px-3 py-1.5 font-sans text-xs text-stone-700 no-underline hover:bg-stone-200">Z–A</a>
                </div>
            </details>
        </div>
    </div>

    <!-- Genre chips -->
    <div class="flex flex-wrap gap-2 mb-3">
        <a asp-action="Index" asp-route-q="@activeQ" asp-route-sort="@activeSort"
           class="@(allActive ? chipOn : chipOff)">All</a>
        @foreach (var c in chips)
        {
            var on = c == activeGenre;
            <a asp-action="Index"
               asp-route-genre="@(on ? null : c)"
               asp-route-q="@activeQ" asp-route-sort="@activeSort"
               class="@(on ? chipOn : chipOff)">@c@(on ? "  ✕" : "")</a>
        }
    </div>

    @if (filtering)
    {
        <!-- Active filter pills -->
        <div class="flex items-center gap-2 flex-wrap border border-stone-300 bg-stone-100 px-3 py-2.5 mb-6">
            <span class="font-sans text-xs tracking-[.16em] uppercase text-stone-600 mr-1">Active filters</span>
            @if (!string.IsNullOrWhiteSpace(activeGenre))
            {
                <a asp-action="Index" asp-route-q="@activeQ" asp-route-sort="@activeSort"
                   class="inline-flex items-center gap-1.5 border border-stone-300 px-2.5 py-1 font-sans text-xs text-stone-700 no-underline hover:border-teal-900 transition-colors">@activeGenre ✕</a>
            }
            @if (!string.IsNullOrWhiteSpace(activeQ))
            {
                <a asp-action="Index" asp-route-genre="@activeGenre" asp-route-sort="@activeSort"
                   class="inline-flex items-center gap-1.5 border border-stone-300 px-2.5 py-1 font-sans text-xs text-stone-700 no-underline hover:border-teal-900 transition-colors">“@activeQ” ✕</a>
            }
            <a asp-action="Index" class="ml-auto font-sans text-xs text-teal-900 no-underline hover:underline">Clear all</a>
        </div>

        @if (worlds.Any())
        {
            <!-- Results grid -->
            <div class="flex flex-wrap gap-4 mt-4">
                @foreach (var w in worlds)
                {
                    <partial name="_WorldCard" model="w" />
                }
            </div>
        }
        else
        {
            <!-- Empty state (adapts to search vs. genre filter) -->
            <div class="text-center py-16 border border-stone-300 bg-stone-100">
                <div class="flex justify-center mb-6">
                    <svg width="96" height="96" viewBox="0 0 96 96" fill="none" aria-hidden="true">
                        <circle cx="48" cy="48" r="34" stroke="#1c4551" stroke-width="1" />
                        <circle cx="48" cy="48" r="24" stroke="#1c4551" stroke-width=".6" stroke-dasharray="2 4" />
                        <path d="M48 16 L54 48 L48 80 L42 48 Z" fill="#1c4551" opacity=".85" />
                        <path d="M16 48 L48 42 L80 48 L48 54 Z" fill="#a3712a" opacity=".7" />
                        <circle cx="48" cy="48" r="2.5" fill="#211c14" />
                        <text x="48" y="12" font-family="IBM Plex Mono, monospace" font-size="8" fill="#5a5142" text-anchor="middle">N</text>
                    </svg>
                </div>

                @if (!string.IsNullOrWhiteSpace(activeGenre))
                {
                    <h2 class="font-serif font-semibold text-[clamp(22px,3vw,30px)] tracking-[-.01em] mb-2">No @activeGenre worlds match those filters</h2>
                    <p class="font-sans text-sm text-stone-500 mb-6">Loosen the filters to see more, or drop them entirely.</p>
                    <div class="flex gap-3 justify-center mb-10 flex-wrap">
                        <a asp-action="Index" asp-route-genre="@activeGenre" class="@btnFill">Show all @activeGenre worlds</a>
                        <a asp-action="Index" class="@btnLine">Clear filters</a>
                    </div>
                    @if (related.Any())
                    {
                        <div class="font-sans text-xs tracking-[.16em] uppercase text-stone-500 mb-3">Or try a related genre</div>
                        <div class="flex flex-wrap gap-2 justify-center">
                            @foreach (var r in related)
                            {
                                <a asp-action="Index" asp-route-genre="@r" class="@chipOff">@r</a>
                            }
                        </div>
                    }
                }
                else
                {
                    <h2 class="font-serif font-semibold text-[clamp(22px,3vw,30px)] tracking-[-.01em] mb-2">Nothing matches “@activeQ”</h2>
                    <p class="font-sans text-sm text-stone-500 mb-6">No worlds, creators, or genres share that name.<br />Try a broader spelling, or browse by genre.</p>
                    <div class="flex gap-3 justify-center mb-10 flex-wrap">
                        <a asp-action="Index" class="@btnFill">Browse all worlds</a>
                        <a asp-action="Create" class="@btnLine">+ Create a world called “@activeQ”</a>
                    </div>
                    @if (chips.Any())
                    {
                        <div class="font-sans text-xs tracking-[.16em] uppercase text-stone-500 mb-3">Browse by genre</div>
                        <div class="flex flex-wrap gap-2 justify-center">
                            @foreach (var r in chips.Take(4))
                            {
                                <a asp-action="Index" asp-route-genre="@r" class="@chipOff">@r</a>
                            }
                        </div>
                    }
                }
            </div>
        }
    }
    else
    {
        @if (total == 0)
        {
            <div class="border border-stone-300 bg-stone-100 px-6 py-16 text-center mt-6">
                <h2 class="font-serif font-semibold text-[28px] tracking-[-.01em] mb-1">No worlds yet</h2>
                <p class="font-sans text-sm text-stone-500 mb-5">Be the first to build one.</p>
                <a asp-action="Create" class="@btnFill">Create a world →</a>
            </div>
        }
        else
        {
            <!-- Discover rows -->
            @if (showNewest && newest.Any())
            {
                <partial name="_WorldRow" model='new ValueTuple<string, string, List<WorldBuilder.Models.World>>("New worlds", "Recently added", newest)' />
            }
            @if (showLoved && loved.Any())
            {
                <partial name="_WorldRow" model='new ValueTuple<string, string, List<WorldBuilder.Models.World>>("Most loved", "All-time", loved)' />
            }

            @if (showByGenre)
            {
                <!-- By-genre section header -->
                <div class="mt-10 mb-6 pt-8 border-t border-stone-300">
                    <span class="font-sans text-xs tracking-[.22em] uppercase text-teal-900">Browse the registry</span>
                    <h2 class="font-serif font-medium text-[clamp(24px,3.2vw,34px)] tracking-[-.01em] leading-[1.05]">By genre</h2>
                </div>

                @foreach (var g in byGenre)
                {
                    <partial name="_WorldRow" model='new ValueTuple<string, string, List<WorldBuilder.Models.World>>(g.Key, g.Count() + " worlds", g.ToList())' />
                }
            }
        }
    }
</div>
@section Scripts {
    <script src="~/js/world-row.js" asp-append-version="true"></script>
}