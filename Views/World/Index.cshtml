@model IEnumerable<WorldBuilder.Models.World>

@{
    ViewData["Title"] = "Browse Worlds";

    var worlds = (Model ?? Enumerable.Empty<WorldBuilder.Models.World>()).ToList();
    var total = worlds.Count;
    var newest = worlds.OrderByDescending(w => w.WorldCreatedAt).Take(8).ToList();
    var loved = worlds.OrderByDescending(w => w.WorldLikes ?? 0).Take(8).ToList();
    var byGenre = worlds.Where(w => !string.IsNullOrEmpty(w.WorldGenFK))
                        .GroupBy(w => w.WorldGenFK)
                        .OrderByDescending(g => g.Count());

    var chips = (ViewData["Genres"] as List<string>) ?? new List<string>();
}

<div class=" text-[#1a1a1a]  -mx-4 -my-3 px-[30px] pt-[30px] pb-[60px]">

    <!-- Header: title + subtitle -->
    <div class="text-4xl font-bold mb-1">Find a world</div>
    <div class="text-[14px] mb-4">@total.ToString("N0") user-built worlds · pick a genre or just start scrolling</div>

    <!-- Search bar -->
    <form asp-action="Index" method="get" class="flex items-center gap-2.5 border-[1.5px] rounded-full px-2 py-2.5 mb-4">
        <svg width="18" height="18" viewBox="0 0 14 14"><circle cx="6" cy="6" r="4" stroke="#1a1a1a" stroke-width="1.4" fill="none" /><line x1="9" y1="9" x2="13" y2="13" stroke="#1a1a1a" stroke-width="1.4" /></svg>
        <input name="q" placeholder="Search by title, creator, tag, or lore keyword…"
               class="flex-1 outline-none text-[16px] " />
    </form>

    <!-- Filter toolbar -->
    <div class="flex items-center justify-between mb-2.5">
        <div class="text-[13px]">Filter by genre</div>
        <div class="flex gap-2">
            <div class="flex items-center gap-1.5 border-[1.5px] rounded-full px-3 py-1.5 text-[13px] cursor-pointer">
                <svg width="12" height="12" viewBox="0 0 12 12"><path d="M1 2 H 11 L 7 7 V 11 L 5 10 V 7 L 1 2 Z" stroke="#1a1a1a" stroke-width="1.2" fill="none" /></svg>
                More filters
            </div>
            <div class="flex items-center gap-1.5 border-[1.5px] rounded-full px-3 py-1.5 text-[13px] cursor-pointer">
                Sort: Most loved
                <svg width="10" height="6" viewBox="0 0 10 6"><path d="M1 1 L 5 5 L 9 1" stroke="#1a1a1a" stroke-width="1.4" fill="none" /></svg>
            </div>
        </div>
    </div>

    <!-- Genre chips -->
    <div class="flex flex-wrap gap-2 mb-2.5">
        @foreach (var c in chips)
        {
            <a asp-action="Index" asp-route-genre="@c"
               class="px-3.5 py-1.5 rounded-full border-1 border-[#1a1a1a] text-sm  no-underline cursor-pointer hover:bg-[#1a1a1a] hover:text-[#f7f3ea] transition-colors">@c</a>
        }
    </div>

    @if (total == 0)
    {
        <div class="border-1 border-dashed border-[#a89f8e] rounded-md px-6 py-16 text-center mt-6">
            <div class=" text-[28px] font-bold mb-1">No worlds yet</div>
            <div class="text-[13px] text-[#a89f8e] mb-4">Be the first to build one.</div>
            <a asp-action="Create" class="inline-flex items-center bg-[#1a1a1a] text-[#f7f3ea] px-4 py-2 rounded-md text-[14px] font-bold no-underline">Create a world →</a>
        </div>
    }
    else
    {
        <!-- ✨ Discover rows -->
        @if (newest.Any())
        {
            <partial name="_WorldRow" model='new ValueTuple<string, string, List<WorldBuilder.Models.World>>("\u2728  New worlds", "last 7d", newest)' />
        }
        @if (loved.Any())
        {
            <partial name="_WorldRow" model='new ValueTuple<string, string, List<WorldBuilder.Models.World>>("\u2728  Most loved", "all-time", loved)' />
        }

        <!-- ✨divider✨ -->
        <div class="border-t-[1.5px] border-dashed border-[#a89f8e] my-2.5 pt-1 font-['Caveat'] text-[18px] text-[#a89f8e]">by genre ↓</div>

        <!-- ✨By-genre rows✨ -->
        @foreach (var g in byGenre)
        {
            <partial name="_WorldRow" model='new ValueTuple<string, string, List<WorldBuilder.Models.World>>(g.Key, g.Count() + " worlds", g.ToList())' />
        }
    }
</div>
