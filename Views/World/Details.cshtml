@model WorldBuilder.Models.World
@using WorldBuilder.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@{
    ViewData["Title"] = Model?.WorldName ?? "World";

    var isOwner = ViewData["IsOwner"] as bool? ?? false;
    var hasLiked = ViewData["HasLiked"] as bool? ?? false;
    var moreByAuthor = (ViewData["MoreByAuthor"] as List<World>) ?? new List<World>();
    var moreInGenre = (ViewData["MoreInGenre"] as List<World>) ?? new List<World>();
    var genreCount = ViewData["GenreCount"] is int gc ? gc : moreInGenre.Count;
    var allPictures = (ViewData["Pictures"] as List<Picture>)?.ToList();

    var cover = allPictures?.Where(p => p.PicWorldFK == Model.WorldIDPK).FirstOrDefault();
    var authorId = Model?.WorldUserFKNavigation?.UserInfoUserIDFK;
    var author = authorId == null ? null : (await UserManager.FindByIdAsync(authorId))?.UserName;
    var categories = Model?.Categories?.OrderBy(c => c.CatName).ToList() ?? new List<Category>();
    var subTotal = categories.Sum(c => c.SubCategories?.Count ?? 0);
    var lastTouch = Model?.WorldUpdatedAt ?? Model?.WorldCreatedAt ?? DateTime.Today;

    string Kfmt(int n) => n >= 1000 ? (n / 1000.0).ToString("0.#") + "k" : n.ToString();

    string Ago(DateTime d)
    {
        var days = (int)(DateTime.Today - d.Date).TotalDays;
        if (days <= 0) return "today";
        if (days == 1) return "yesterday";
        if (days < 7) return days + "d ago";
        if (days < 30) return (days / 7) + "w ago";
        if (days < 365) return (days / 30) + "mo ago";
        return (days / 365) + "y ago";
    }
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8 text-stone-900">
    @Html.AntiForgeryToken()

    <!-- Breadcrumb -->
    <div class="flex flex-wrap items-center gap-1.5 text-xs font-sans text-xs text-stone-500 mb-5">
        <a asp-action="Index" class="no-underline hover:text-teal-900 transition-colors">Public Worlds</a>
        <span>›</span>
        <a asp-action="Index" asp-route-genre="@Model?.WorldGenFK" class="no-underline hover:text-teal-900 transition-colors">@Model?.WorldGenFK</a>
        <span>›</span>
        <span class="text-stone-900">@Model?.WorldName</span>
    </div>

    <!-- ── Hero ── -->
    <div class="border border-stone-300 bg-stone-100 p-4 sm:p-5 mb-8 sm:mb-10 grid grid-cols-1 lg:grid-cols-[1.05fr_1fr] gap-5 sm:gap-6">

        <!-- Cover -->
        <div class="aspect-[16/9] w-full border border-stone-300 bg-[repeating-linear-gradient(135deg,transparent_0_10px,rgba(28,69,81,0.06)_10px_11px)] flex items-center justify-center overflow-hidden">
            @if (cover != null && !string.IsNullOrEmpty(cover.PicPath))
            {
                <img src="@Url.Content("~/" + cover.PicPath)" alt="@cover.PicCaption" class="w-full h-full object-cover" />
            }
            else
            {
                <span class="font-sans text-xs text-stone-500">No cover yet</span>
            }
        </div>

        <!-- Info -->
        <div class="flex flex-col">
            <div class="font-sans text-xs tracking-[.16em] uppercase text-teal-900 mb-2">
                @Model?.WorldGenFK · @(Model != null && Model.WorldIsPublic ? "public world" : "private world")
            </div>

            <h1 class="font-serif font-semibold text-[clamp(26px,7vw,44px)] tracking-[-.01em] leading-[1.02] mb-1.5">@Model?.WorldName</h1>

            <div class="font-sans text-sm text-stone-600 mb-3">
                by <span class="text-stone-900">@@@(author ?? "creator")</span>
                <span class="mx-1 text-stone-400">·</span> updated @Ago(lastTouch)
            </div>

            @if (!string.IsNullOrEmpty(Model?.WorldDesc))
            {
                <p class="text-sm sm:text-[15px] text-stone-600 leading-relaxed mb-4 max-w-prose">@Model.WorldDesc</p>
            }

            <!-- Stats -->
            <div class="flex flex-wrap items-center gap-2 text-sm font-sans text-stone-600 mb-1">
                <span class="inline-flex items-center gap-1.5">
                    <svg width="12" height="11" viewBox="0 0 24 22" fill="none"><path d="M12 20 C 4 14, 2 9, 5 5 C 8 1, 12 5, 12 8 C 12 5, 16 1, 19 5 C 22 9, 20 14, 12 20 Z" stroke="#1c4551" stroke-width="1.8" fill="none" /></svg>
                    <span id="worldLikeCountStat">@Kfmt(Model?.WorldLikes ?? 0)</span>
                </span>
                <span class="text-stone-400">·</span>
                <span>@categories.Count categories</span>
                <span class="text-stone-400">·</span>
                <span>@subTotal entries</span>
            </div>

            <!-- Tags -->
            @* @if (Model?.Tags != null && Model.Tags.Any())
            {
                <div class="flex flex-wrap gap-2 mt-2">
                    @foreach (var tag in Model.Tags)
                    {
                        <span class="inline-flex justify-center w-full sm:w-auto items-center gap-1.5 px-2.5 py-0.5 font-sans text-xs text-stone-700 border border-stone-300">
                            <span class="w-2 h-2 rounded-full" style="background-color:@tag.TagColor"></span>
                            @tag.TagName
                        </span>
                    }
                </div>
            } *@

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-3 mt-auto pt-6">
                @if (isOwner)
                {
                    <a asp-action="Edit" asp-route-id="@Model?.WorldIDPK"
                       class="inline-flex justify-center w-full sm:w-auto items-center font-sans text-sm font-medium px-6 py-3 bg-stone-900 text-stone-50 no-underline hover:bg-teal-900 transition-colors">Edit world</a>
                    <a asp-controller="BuilderView" asp-action="Index" asp-route-id="@Model?.WorldIDPK"
                       class="inline-flex justify-center w-full sm:w-auto items-center font-sans text-sm font-medium px-5 py-3 border border-stone-300 text-stone-900 no-underline hover:border-teal-900 hover:text-teal-900 transition-colors">Open workspace →</a>
                }
                else
                {
                    <a asp-action="Read" asp-route-id="@Model?.WorldIDPK"
                       class="inline-flex justify-center w-full sm:w-auto items-center font-sans text-sm font-medium px-6 py-3 bg-stone-900 text-stone-50 no-underline hover:bg-teal-900 transition-colors">Enter the world →</a>
                }

                <!-- Like button — works for anyone signed in, owner or not -->
                <button type="button" id="worldLikeBtn" data-id="@Model?.WorldIDPK"
                        class="inline-flex justify-center w-full sm:w-auto items-center gap-1.5 border px-4 py-3 font-sans text-sm font-medium cursor-pointer transition-colors @(hasLiked ? "bg-teal-900 text-stone-50 border-teal-900" : "border-stone-300 text-stone-900 hover:border-teal-900 hover:text-teal-900")">
                    <svg width="13" height="12" viewBox="0 0 24 22" fill="none"><path d="M12 20 C 4 14, 2 9, 5 5 C 8 1, 12 5, 12 8 C 12 5, 16 1, 19 5 C 22 9, 20 14, 12 20 Z" stroke="currentColor" stroke-width="1.8" fill="@(hasLiked ? "currentColor" : "none")" /></svg>
                    <span>Like</span><span class="opacity-60">·</span><span id="worldLikeCount">@(Model?.WorldLikes ?? 0)</span>
                </button>

                <button type="button" title="Share"
                        class="inline-flex justify-center w-full sm:w-auto items-center justify-center w-11 h-11 border border-stone-300 text-stone-900 cursor-pointer hover:border-teal-900 hover:text-teal-900 transition-colors">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="4" cy="8" r="2" stroke="currentColor" stroke-width="1.4" /><circle cx="12" cy="3.5" r="2" stroke="currentColor" stroke-width="1.4" /><circle cx="12" cy="12.5" r="2" stroke="currentColor" stroke-width="1.4" /><line x1="5.7" y1="7" x2="10.3" y2="4.4" stroke="currentColor" stroke-width="1.2" /><line x1="5.7" y1="9" x2="10.3" y2="11.6" stroke="currentColor" stroke-width="1.2" /></svg>
                </button>
            </div>
        </div>
    </div>

    
    <!-- ── Body + Sidebar ── -->
    <div class="grid grid-cols-1 lg:grid-cols-[1.6fr_1fr] gap-8 lg:gap-10">

        <!-- Left: readable body -->
        <div>
            @if (categories.Any())
            {
                foreach (var cat in categories)
                {
                    <section id="cat-@cat.CatIDPK" class="mb-9 scroll-mt-6">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="w-2.5 h-2.5 rounded-full" style="background-color:@cat.CatColor"></span>
                            <h2 class="font-serif font-semibold text-xl sm:text-2xl tracking-[-.01em] leading-none">@cat.CatName</h2>
                        </div>
                        @if (!string.IsNullOrEmpty(cat.CatDescription))
                        {
                            <p class="text-sm text-stone-600 leading-relaxed mb-3 max-w-prose">@cat.CatDescription</p>
                        }
                        @if (cat.SubCategories != null && cat.SubCategories.Any())
                        {
                            <ul class="space-y-1.5 max-w-prose">
                                @foreach (var sub in cat.SubCategories.OrderBy(s => s.SubName))
                                {
                                    <li class="flex items-start gap-2 text-sm">
                                        <span class="text-stone-400">└</span>
                                        <div>
                                            <span class="font-semibold">@sub.SubName</span>
                                            @if (!string.IsNullOrEmpty(sub.SubDescription))
                                            {
                                                <span class="text-stone-600"> — @sub.SubDescription</span>
                                            }
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </section>
                }
            }
            else
            {
                <div class="border border-stone-300 bg-stone-100 px-6 py-14 text-center">
                    <div class="font-serif font-semibold text-2xl tracking-[-.01em] mb-1">Nothing written here yet</div>
                    <div class="font-sans text-sm text-stone-500">This world doesn't have any categories or entries to read yet.</div>
                </div>
            }
        </div>

        <!-- Right: contents sidebar + other worlds -->
        <aside class="mt-10 lg:mt-0">
            <span class="font-sans text-xs tracking-[.22em] uppercase text-teal-900">Index</span>
            <h2 class="font-serif font-semibold text-2xl tracking-[-.01em] mt-1 mb-3">Contents</h2>

            <div class="flex items-center gap-2 border border-stone-300 bg-stone-100 px-3 py-2 mb-4">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="4" stroke="#57534e" stroke-width="1.4" /><line x1="9" y1="9" x2="13" y2="13" stroke="#57534e" stroke-width="1.4" stroke-linecap="round" /></svg>
                <input id="tocFilter" placeholder="Filter contents…" class="flex-1 outline-none bg-transparent font-sans text-sm placeholder-stone-400" />
            </div>

            @if (categories.Any())
            {
                <div id="toc" class="text-sm mb-8">
                    @foreach (var cat in categories)
                    {
                        <div class="toc-group" data-name="@cat.CatName.ToLower()">
                            <a href="#cat-@cat.CatIDPK" class="flex items-center gap-2 p-3 justify-between py-1 no-underline text-stone-900 hover:text-teal-900 transition-colors">
                                <span class="font-semibold">@cat.CatName</span>
                                <span class="font-sans text-xs text-stone-500">@(cat.SubCategories?.Count ?? 0)</span>
                            </a>
                            @if (cat.SubCategories != null && cat.SubCategories.Any())
                            {
                                <div class="pl-3">
                                    @foreach (var sub in cat.SubCategories.OrderBy(s => s.SubName))
                                    {
                                        <div class="toc-item flex gap-1.5 py-0.5 text-stone-600" data-name="@sub.SubName.ToLower()">
                                            <span class="text-stone-400">└</span><span>@sub.SubName</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="font-sans text-sm text-stone-500 mb-8">No contents yet.</p>
            }

            @if (moreByAuthor.Any())
            {
                <div class="font-sans text-xs tracking-[.16em] uppercase text-stone-600 mb-2">Other worlds by @@@(author ?? "creator")</div>
                <div class="space-y-1.5">
                    @foreach (var w in moreByAuthor)
                    {
                        <a asp-action="Details" asp-route-id="@w.WorldIDPK"
                           class="lex items-center justify-between gap-3 text-sm no-underline text-stone-900 hover:text-teal-900 transition-colors">
                            <span class="flex-1 truncate flex gap-1.5"><span class="text-stone-400">└</span>@w.WorldName</span>
                            <span class="inline-flex items-center gap-1 font-sans text-xs text-stone-500">
                                <svg width="11" height="10" viewBox="0 0 24 22" fill="none"><path d="M12 20 C 4 14, 2 9, 5 5 C 8 1, 12 5, 12 8 C 12 5, 16 1, 19 5 C 22 9, 20 14, 12 20 Z" stroke="#a8a29e" stroke-width="1.8" fill="none" /></svg>
                                @Kfmt(w.WorldLikes ?? 0)
                            </span>
                        </a>
                    }
                </div>
            }
        </aside>
    </div>
    <!-- ── Bottom carousel: more in genre ── -->
    @if (moreInGenre.Any())
    {
        <div class="mt-10 sm:mt-12 pt-6 sm:pt-8 border-t border-stone-300">
            <partial name="_WorldRow"
                     model='new ValueTuple<string, string, List<WorldBuilder.Models.World>>("More " + Model.WorldGenFK + " worlds", genreCount.ToString("N0") + " worlds", moreInGenre)' />
        </div>
    }

    
</div>


@section Scripts {
    <script>
        (function () {
            var box = document.getElementById('tocFilter');
            if (!box) return;
            box.addEventListener('input', function () {
                var q = this.value.trim().toLowerCase();
                document.querySelectorAll('#toc .toc-group').forEach(function (g) {
                    var groupHit = (g.dataset.name || '').includes(q);
                    var anyChild = false;
                    g.querySelectorAll('.toc-item').forEach(function (it) {
                        var hit = !q || (it.dataset.name || '').includes(q);
                        it.style.display = hit ? '' : 'none';
                        if (hit) anyChild = true;
                    });
                    g.style.display = (!q || groupHit || anyChild) ? '' : 'none';
                });
            });
        })();
    </script>
    <script>
        (function () {
            var btn = document.getElementById('worldLikeBtn');
            if (!btn) return;
            var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            btn.addEventListener('click', async function () {
                var id = btn.getAttribute('data-id');
                btn.disabled = true;
                try {
                    var res = await fetch('@Url.Action("ToggleLike", "World")/' + id, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': tokenEl ? tokenEl.value : '' }
                    });
                    if (res.status === 401) { window.location.href = '/Identity/Account/Login'; return; }
                    if (!res.ok) throw new Error('failed');
                    var data = await res.json();
                    var pretty = data.count >= 1000 ? (data.count / 1000).toFixed(1) + 'k' : data.count;
                    var cEl = document.getElementById('worldLikeCount');
                    if (cEl) cEl.textContent = data.count;          // button count (raw)
                    var sEl = document.getElementById('worldLikeCountStat');
                    if (sEl) sEl.textContent = pretty;              // stats line (compact)
                    var heart = btn.querySelector('path');
                    if (data.liked) {
                        btn.classList.remove('border-stone-300', 'text-stone-900', 'hover:border-teal-900', 'hover:text-teal-900');
                        btn.classList.add('bg-teal-900', 'text-stone-50', 'border-teal-900');
                        if (heart) heart.setAttribute('fill', 'currentColor');
                    } else {
                        btn.classList.remove('bg-teal-900', 'text-stone-50', 'border-teal-900');
                        btn.classList.add('border-stone-300', 'text-stone-900', 'hover:border-teal-900', 'hover:text-teal-900');
                        if (heart) heart.setAttribute('fill', 'none');
                    }
                } catch (e) { console.error(e); }
                finally { btn.disabled = false; }
            });
        })();
    </script>
}
