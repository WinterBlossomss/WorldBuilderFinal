@model WorldBuilder.Models.World

@{
    ViewData["Title"] = "Create";
}

<div class="flex items-center gap-1.5 text-[12.5px] text-wb-muted mb-3.5">
    <a href="#" class="text-wb-muted no-underline hover:text-wb-subtle transition-colors">Public Worlds</a>
    <span>›</span>
    <span class="text-wb-text">New World</span>

</div>
<div class="flex flex-col">
    <h1 class="text-4xl font-bold">Create a new World</h1>
    <p class="mt-2 mb-2">Just the basics- you can add scripts, characters and lore after</p>
</div>
<div>
    <div class="flex flex-col">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- NAME -->

            <div class="flex flex-col mb-5">
                <div class="flex flex-row mb-1">
                    <label class="font-semibold flex flex-row">
                        Name
                        <div class="text-red-500"> *</div>
                    </label>
                    <div class="grow"></div>
                    <label>0/100</label>
                </div>
                <input asp-for="WorldName" class="border-1 rounded p-2" placeholder="e.g. Ashenmoor" />
                <span asp-validation-for="WorldName" class="text-red-500"></span>
            </div>

            <!-- DESCRIPTION -->

            <div class="flex flex-col mb-5">
                <div class="flex flex-row mb-1">
                    <label class="font-semibold">Short Description</label>
                    <div class="grow"></div>
                    <label>0/500</label>
                </div>
                <input asp-for="WorldDesc" class="border-1 rounded p-2" placeholder="Pitch your world in 1-2 sentences" />
                <span asp-validation-for="WorldDesc" class="text-red-500"></span>
            </div>

            <!-- GENRE CHIPS -->

            <div class="form-group">
                <label asp-for="WorldIsPublic" class="control-label"></label>
                <input asp-for="WorldIsPublic" class="form-check-input" />
                <span asp-validation-for="WorldIsPublic" class="text-danger"></span>
            </div>

            <!-- TODO: Make these hidden fixed inputs -->

            <div class="form-group">
                <label asp-for="WorldUserFK" class="control-label"></label>
                <input asp-for="WorldUserFK" class="form-control" />
                <span asp-validation-for="WorldUserFK" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="WorldCreatedAt" class="control-label"></label>
                <input asp-for="WorldCreatedAt" class="form-control" />
                <span asp-validation-for="WorldCreatedAt" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="WorldUpdatedAt" class="control-label"></label>
                <input asp-for="WorldUpdatedAt" class="form-control" />
                <span asp-validation-for="WorldUpdatedAt" class="text-danger"></span>
            </div>

            <!-- TODO: Make these hidden fixed inputs END -->

            <!-- PICTURES -->

            <div class="form-group">
                <label asp-for="Pictures" class="control-label"></label>
                <input asp-for="Pictures" class="form-control" />
                <span asp-validation-for="Pictures" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
