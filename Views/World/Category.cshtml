@model WorldBuilder.Models.World
@using WorldBuilder.Models

@functions {
    // Plain-text excerpt from Quill HTML — keeps the controller free of view concerns.
    static string Excerpt(string html, int max = 140)
    {
        if (string.IsNullOrEmpty(html)) return null;
        var t = System.Text.RegularExpressions.Regex.Replace(html, "<.*?>", " ");
        t = System.Net.WebUtility.HtmlDecode(t);
        t = System.Text.RegularExpressions.Regex.Replace(t, "\\s+", " ").Trim();
        return t.Length > max ? t.Substring(0, max).TrimEnd() + "…" : t;
    }
}

@{
    var w       = Model;
    var current = ViewData["Current"] as Category;
    var author  = ViewData["AuthorHandle"] as string;

    ViewData["Title"] = (current?.CatName ?? "Category") + " · " + (w?.WorldName ?? "");

    var cards      = ViewData["CatScripts"] as List<Script>            ?? new List<Script>();
    var connections = ViewData["Connections"] as Dictionary<int, int>  ?? new Dictionary<int, int>();
    var subNames   = ViewData["SubNames"] as Dictionary<int, string>   ?? new Dictionary<int, string>();
    var catCounts  = ViewData["CatCounts"] as Dictionary<int, int>     ?? new Dictionary<int, int>();
    var totalWorldScripts = ViewData["TotalWorldScripts"] as int? ?? 0;

    var siblings = w?.Categories?.OrderBy(c => c.CatName).ToList() ?? new List<Category>();

    Func<string, string> Pic = p => string.IsNullOrEmpty(p) ? null : (p.StartsWith("/") || p.StartsWith("http")) ? p : Url.Content("~/" + p);

    // Registry-aesthetic tokens (mirrors Home/Index.cshtml)
    const string chipOn  = "font-sans text-xs tracking-[.06em] uppercase px-3 py-1.5 border border-stone-900 bg-stone-900 text-stone-50 no-underline";
    const string chipOff = "font-sans text-xs tracking-[.06em] uppercase px-3 py-1.5 border border-stone-300 text-stone-600 no-underline hover:border-teal-900 hover:text-teal-900 transition-colors";
    const string hatch   = "bg-[repeating-linear-gradient(135deg,transparent_0_10px,rgba(26,26,26,0.08)_10px_11px)]";
}

<div class="max-w-7xl mx-auto px-6 py-10 text-stone-900">

    <!-- Toolbar -->
    <div class="flex items-center gap-4 mb-8 pb-6 border-b border-stone-300">
        <a asp-action="Read" asp-route-id="@w.WorldIDPK" class="flex items-center gap-3 min-w-0 no-underline text-stone-900 group">
            <div class="w-10 h-10 shrink-0 border border-stone-300 @hatch group-hover:border-teal-900 transition-colors"></div>
            <div class="min-w-0">
                <div class="font-serif font-semibold text-xl leading-none tracking-[-.01em] truncate group-hover:text-teal-900 transition-colors">@w?.WorldName</div>
                <div class="font-sans text-xs text-stone-500 mt-1 truncate">
                    by <span class="text-stone-700">@@@(author ?? "creator")</span> · @w?.WorldGenFK
                </div>
            </div>
        </a>
        <div class="grow"></div>
        <div class="hidden md:block relative w-64">
            <div class="flex items-center gap-2 border border-stone-300 bg-stone-100 px-3 py-1.5 hover:border-teal-900 transition-colors">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                    <circle cx="5.5" cy="5.5" r="4" stroke="#57534e" stroke-width="1.4" />
                    <line x1="8.5" y1="8.5" x2="12" y2="12" stroke="#57534e" stroke-width="1.4" stroke-linecap="round" />
                </svg>
                <input id="worldSearch" data-id="@w?.WorldIDPK" autocomplete="off"
                       placeholder="Search in @w?.WorldName…"
                       class="flex-1 font-sans text-xs bg-transparent outline-none placeholder-stone-400" />
            </div>
            <div id="worldSearchResults"
                 class="hidden absolute right-0 z-20 mt-1 w-full max-h-80 overflow-auto bg-stone-100 border border-stone-300 shadow-[0_10px_24px_rgba(33,28,20,0.10)]"></div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[230px_1fr] gap-10">

        <!-- LEFT: Contents tree -->
        <aside>
            <div class="flex items-baseline justify-between mb-3">
                <span class="font-sans text-xs tracking-[.22em] uppercase text-teal-900">Contents</span>
                <span class="font-sans text-xs text-stone-500">@totalWorldScripts scripts</span>
            </div>

            <div class="flex items-center gap-2 border border-stone-300 bg-stone-100 px-3 py-1.5 mb-5 hover:border-teal-900 transition-colors">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                    <circle cx="5.5" cy="5.5" r="4" stroke="#57534e" stroke-width="1.4" />
                    <line x1="8.5" y1="8.5" x2="12" y2="12" stroke="#57534e" stroke-width="1.4" stroke-linecap="round" />
                </svg>
                <input id="tocFilter" placeholder="Find a script…"
                       class="flex-1 font-sans text-xs bg-transparent outline-none placeholder-stone-400" />
            </div>

            <nav id="toc">
                @foreach (var cat in siblings)
                {
                    var on = current != null && cat.CatIDPK == current.CatIDPK;
                    var count = catCounts.TryGetValue(cat.CatIDPK, out var cc) ? cc : 0;
                    var subs = cat.SubCategories?.OrderBy(su => su.SubName).ToList() ?? new List<SubCategory>();
                    <div class="toc-group mb-5" data-name="@cat.CatName.ToLower()">
                        <a asp-action="Category" asp-route-id="@w.WorldIDPK" asp-route-catId="@cat.CatIDPK"
                           class="flex items-center gap-2 pb-2 mb-2 border-b border-stone-300 no-underline font-sans text-xs tracking-[.16em] font-semibold @(on ? "text-stone-900" : "text-teal-900 hover:text-stone-900") transition-colors">
                            <span class="w-2 h-2 rounded-full inline-block shrink-0" style="background-color:@(cat.CatColor ?? "#a89f8e")"></span>
                            <span class="truncate @(on ? "underline underline-offset-4" : "")">@cat.CatName.ToUpper()</span>
                            <span class="ml-auto shrink-0 font-normal tracking-normal text-stone-500">@count</span>
                        </a>
                        @if (subs.Any())
                        {
                            <ul class="list-none p-0 m-0">
                                @foreach (var sub in subs)
                                {
                                    <li class="toc-item font-sans text-xs text-stone-600 py-1 truncate" data-name="@sub.SubName.ToLower()">
                                        @sub.SubName
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                }
            </nav>
        </aside>

        <!-- MAIN -->
        <div>
            <!-- Breadcrumb -->
            <div class="flex items-center gap-2 font-sans text-xs text-stone-500 mb-6">
                <a asp-action="Read" asp-route-id="@w.WorldIDPK" class="no-underline text-stone-500 hover:text-teal-900 transition-colors">@w?.WorldName</a>
                <span>›</span>
                <span class="text-stone-900">@current?.CatName</span>
            </div>

            <!-- Category header -->
            <span class="font-sans text-xs tracking-[.22em] uppercase text-teal-900">Registry entries</span>
            <h1 class="font-serif font-semibold text-[clamp(28px,4vw,40px)] tracking-[-.01em] leading-[1.05] mt-2 mb-2">@current?.CatName</h1>
            <p class="font-sans text-sm text-stone-600 mb-6">
                @cards.Count entr@(cards.Count == 1 ? "y" : "ies") in this category
            </p>

            <!-- Sibling categories -->
            @if (siblings.Count > 1)
            {
                <div class="flex flex-wrap items-center gap-2 mb-8">
                    <span class="font-sans text-xs tracking-[.16em] uppercase text-stone-500 mr-1">Also in this world</span>
                    @foreach (var sib in siblings)
                    {
                        var on = current != null && sib.CatIDPK == current.CatIDPK;
                        <a asp-action="Category" asp-route-id="@w.WorldIDPK" asp-route-catId="@sib.CatIDPK"
                           class="@(on ? chipOn : chipOff)">@sib.CatName</a>
                    }
                </div>
            }

            <!-- Cards -->
            @if (cards.Any())
            {
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
                    @foreach (var sc in cards)
                    {
                        var portrait = sc.PicScriptPicFKs?.FirstOrDefault()?.PicPath;
                        var subName = (sc.ScriptSubFK > 0 && subNames.TryGetValue(sc.ScriptSubFK, out var sn)) ? sn : null;
                        var excerpt = Excerpt(sc.ScriptContent);
                        var conn = connections.TryGetValue(sc.ScriptIDPK, out var cq) ? cq : 0;
                        <a asp-controller="Script" asp-action="Details" asp-route-scriptidpk="@sc.ScriptIDPK"
                           class="bg-stone-100 border border-stone-300 flex flex-col no-underline text-stone-900 group
                                  transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_14px_26px_rgba(33,28,20,0.10)] hover:border-[#1c4551]">
                            <div class="aspect-square w-full shrink-0 relative overflow-hidden border-b border-stone-300 @hatch flex items-center justify-center">
                                @if (!string.IsNullOrEmpty(portrait))
                                {
                                    <img src="@Pic(portrait)" class="w-full h-full object-cover" alt="@sc.ScriptTitle" />
                                }
                                else
                                {
                                    <span class="font-sans text-xs tracking-[.16em] uppercase text-stone-400">Portrait</span>
                                }
                                <span class="absolute top-[9px] left-[10px] font-sans text-xs tracking-[.08em] text-[#153640] bg-stone-100/80 px-[7px] py-[2px] border border-stone-200 z-10">SCR-@sc.ScriptIDPK.ToString("D4")</span>
                            </div>
                            <div class="p-[15px] pb-[17px] flex flex-col flex-1 min-h-0">
                                <h3 class="font-serif font-semibold text-lg leading-[1.1] tracking-[-.01em] truncate">@sc.ScriptTitle</h3>
                                <div class="font-sans text-xs text-stone-500 mt-1 truncate">
                                    @(string.IsNullOrEmpty(subName) ? w?.WorldName : subName)
                                </div>
                                @if (!string.IsNullOrEmpty(excerpt))
                                {
                                    <p class="text-xs text-stone-600 leading-[1.45] mt-2 line-clamp-3">@excerpt</p>
                                }
                                <div class="flex items-center gap-1.5 font-sans text-xs text-stone-500 mt-auto pt-3">
                                    <svg width="10" height="10" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                        <circle cx="4" cy="8" r="1.6" stroke="currentColor" stroke-width="1.2" />
                                        <circle cx="12" cy="4" r="1.6" stroke="currentColor" stroke-width="1.2" />
                                        <circle cx="12" cy="12" r="1.6" stroke="currentColor" stroke-width="1.2" />
                                        <line x1="5.4" y1="7.2" x2="10.6" y2="4.6" stroke="currentColor" stroke-width="1" />
                                        <line x1="5.4" y1="8.8" x2="10.6" y2="11.4" stroke="currentColor" stroke-width="1" />
                                    </svg>
                                    @conn connection@(conn == 1 ? "" : "s")
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="border border-dashed border-stone-400 px-6 py-16 text-center">
                    <div class="font-serif text-2xl mb-1">No entries here yet</div>
                    <div class="font-sans text-sm text-stone-600">This category doesn't have any scripts on record.</div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var f = document.getElementById('tocFilter');
            if (!f) return;
            f.addEventListener('input', function () {
                var q = this.value.trim().toLowerCase();
                document.querySelectorAll('#toc .toc-group').forEach(function (g) {
                    var name = g.getAttribute('data-name') || '';
                    var subHit = Array.from(g.querySelectorAll('.toc-item'))
                        .some(function (i) { return (i.getAttribute('data-name') || '').includes(q); });
                    g.style.display = (!q || name.includes(q) || subHit) ? '' : 'none';
                });
            });
        })();

        // Toolbar search — live "search in this world" dropdown (entries + categories)
        (function () {
            var input = document.getElementById('worldSearch');
            var panel = document.getElementById('worldSearchResults');
            if (!input || !panel) return;

            var worldId    = input.getAttribute('data-id');
            var searchBase = '@Url.Action("Search", "World")';    // /World/Search
            var catBase    = '@Url.Action("Category", "World")';  // /World/Category
            var scriptBase = '@Url.Action("Details", "Script")';  // /Script/Details

            var timer = null, seq = 0;

            function esc(s) {
                return (s || '').replace(/[&<>"]/g, function (c) {
                    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
                });
            }
            function hide() { panel.classList.add('hidden'); panel.innerHTML = ''; }
            function render(data) {
                var html = '';

                var headCls = 'font-sans text-xs tracking-[.16em] uppercase text-stone-500 pt-2 px-3 pb-1';
                var itemCls = 'flex items-center gap-2 py-2 px-3 border-b border-stone-200 last:border-b-0 '
                            + 'no-underline text-stone-900 font-sans text-sm hover:bg-stone-200 transition-colors';
                var metaCls = 'ml-auto shrink-0 font-sans text-xs tracking-[.06em] uppercase text-stone-500';

                if (data.categories && data.categories.length) {
                    html += '<div class="' + headCls + '">Categories</div>';
                    data.categories.forEach(function (c) {
                        html += '<a class="' + itemCls + '" href="' + catBase + '/' + worldId + '?catId=' + c.id + '">'
                              +   '<span class="truncate">' + esc(c.name) + '</span>'
                              +   '<span class="' + metaCls + '">category</span></a>';
                    });
                }
                if (data.scripts && data.scripts.length) {
                    html += '<div class="' + headCls + '">Entries</div>';
                    data.scripts.forEach(function (s) {
                        var meta = s.cat || (s.isChar ? 'character' : 'entry');
                        html += '<a class="' + itemCls + '" href="' + scriptBase + '?scriptidpk=' + s.id + '">'
                              +   '<span class="truncate">' + esc(s.title) + '</span>'
                              +   '<span class="' + metaCls + '">' + esc(meta) + '</span></a>';
                    });
                }
                if (!html) html = '<div class="px-3 py-3 font-sans text-sm text-stone-500">No matches in this world</div>';
                panel.innerHTML = html;
                panel.classList.remove('hidden');
            }

            input.addEventListener('input', function () {
                var q = this.value.trim();
                clearTimeout(timer);
                if (q.length < 1) { hide(); return; }
                timer = setTimeout(function () {
                    var mine = ++seq;
                    fetch(searchBase + '/' + worldId + '?q=' + encodeURIComponent(q))
                        .then(function (res) { return res.ok ? res.json() : null; })
                        .then(function (data) { if (data && mine === seq) render(data); })
                        .catch(function () { /* ignore */ });
                }, 180);
            });
            input.addEventListener('focus', function () { if (this.value.trim()) input.dispatchEvent(new Event('input')); });
            input.addEventListener('keydown', function (e) { if (e.key === 'Escape') { hide(); this.blur(); } });
            document.addEventListener('click', function (e) {
                if (e.target !== input && !panel.contains(e.target)) hide();
            });
        })();
    </script>
}
