@model WorldBuilder.Models.World
@using WorldBuilder.Models

@functions {
    // Plain-text excerpt from Quill HTML — keeps the controller free of view concerns.
    static string Excerpt(string html, int max = 140)
    {
        if (string.IsNullOrEmpty(html)) return null;
        var t = System.Text.RegularExpressions.Regex.Replace(html, "<.*?>", " ");
        t = System.Net.WebUtility.HtmlDecode(t);
        t = System.Text.RegularExpressions.Regex.Replace(t, "\\s+", " ").Trim();
        return t.Length > max ? t.Substring(0, max).TrimEnd() + "…" : t;
    }
}

@{
    var w       = Model;
    var current = ViewData["Current"] as Category;
    var author  = ViewData["AuthorHandle"] as string;

    ViewData["Title"] = (current?.CatName ?? "Category") + " · " + (w?.WorldName ?? "");

    var cards      = ViewData["CatScripts"] as List<Script>            ?? new List<Script>();
    var connections = ViewData["Connections"] as Dictionary<int, int>  ?? new Dictionary<int, int>();
    var subNames   = ViewData["SubNames"] as Dictionary<int, string>   ?? new Dictionary<int, string>();
    var catCounts  = ViewData["CatCounts"] as Dictionary<int, int>     ?? new Dictionary<int, int>();
    var totalWorldScripts = ViewData["TotalWorldScripts"] as int? ?? 0;

    var siblings = w?.Categories?.OrderBy(c => c.CatName).ToList() ?? new List<Category>();

    Func<string, string> Pic = p => string.IsNullOrEmpty(p) ? null : (p.StartsWith("/") || p.StartsWith("http")) ? p : Url.Content("~/" + p);
}

<div class="m-5">
    <div class=" -mx-4 -my-3 px-[30px] pt-5 pb-16">

        <!-- Toolbar -->
        <div class="flex items-center gap-4 mb-6">
            <a asp-action="Read" asp-route-id="@w.WorldIDPK" class="flex items-center align-content-between gap-3 min-w-0 no-underline text-[#1a1a1a]">
                <div class="w-10 h-10 border-1 rounded-md bg-[repeating-linear-gradient(135deg,transparent_0_6px,rgba(26,26,26,0.08)_6px_7px)] shrink-0"></div>
                <div class="min-w-0">
                    <div class=" text-2xl font-bold leading-none truncate">@w?.WorldName</div>
                    <div class="text-base text-[#a89f8e] truncate">by <span class="text-[#1a1a1a]">@@@(author ?? "creator")</span> · @w?.WorldGenFK</div>
                </div>
            </a>
            <div class="grow"></div>
            <div class="md:block relative w-64">
                <div class="flex items-center gap-2 border-[1.5px] border-[#1a1a1a] rounded-full px-3 py-1.5">
                    <svg width="15" height="15" viewBox="0 0 14 14"><circle cx="6" cy="6" r="4" stroke="#1a1a1a" stroke-width="1.4" fill="none" /><line x1="9" y1="9" x2="13" y2="13" stroke="#1a1a1a" stroke-width="1.4" /></svg>
                    <input id="worldSearch" data-id="@w?.WorldIDPK" autocomplete="off" placeholder="Search in @w?.WorldName…" class="flex-1 outline-none bg-transparent text-[13px]" />
                </div>
                <div id="worldSearchResults" class="hidden absolute z-20 mt-1 w-full max-h-80 overflow-auto bg-[#f7f3ea] border-[1.5px] border-[#1a1a1a] rounded-md" style="box-shadow:3px 3px 0 #1a1a1a"></div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[230px_1fr] gap-8">

            <!-- LEFT: Contents tree -->
            <aside>
                <div class="flex items-baseline justify-between mb-2">
                    <h2 class="font-['Caveat'] text-[24px] font-bold">Contents</h2>
                    <span class="text-[11.5px] text-[#a89f8e]">@totalWorldScripts scripts</span>
                </div>
                <div class="flex items-center gap-2 border-[1.5px] border-[#1a1a1a] rounded-full px-3 py-1.5 mb-3">
                    <svg width="13" height="13" viewBox="0 0 14 14"><circle cx="6" cy="6" r="4" stroke="#1a1a1a" stroke-width="1.4" fill="none" /><line x1="9" y1="9" x2="13" y2="13" stroke="#1a1a1a" stroke-width="1.4" /></svg>
                    <input id="tocFilter" placeholder="find a script in this world…" class="flex-1 outline-none bg-transparent text-[12.5px]" />
                </div>
                <nav id="toc" class="text-base">
                    @foreach (var cat in siblings)
                    {
                        var on = current != null && cat.CatIDPK == current.CatIDPK;
                        var count = catCounts.TryGetValue(cat.CatIDPK, out var cc) ? cc : 0;
                        var subs = cat.SubCategories?.OrderBy(su => su.SubName).ToList() ?? new List<SubCategory>();
                        <div class="toc-group mb-1.5" data-name="@cat.CatName.ToLower()">
                            <a asp-action="Category" asp-route-id="@w.WorldIDPK" asp-route-catId="@cat.CatIDPK"
                               class="flex items-center justify-between py-1 no-underline text-[#1a1a1a] hover:text-[#a89f8e]">
                                <span class="flex items-center gap-1.5 font-bold @(on ? "underline underline-offset-4" : "")">
                                    <span class="w-2 h-2 rounded-full" style="background-color:@(cat.CatColor ?? "#a89f8e")"></span>
                                    @cat.CatName
                                </span>
                                <span class="text-[#a89f8e] text-[12px]">@count</span>
                            </a>
                            @if (subs.Any())
                            {
                                <div class="pl-3.5">
                                    @foreach (var sub in subs)
                                    {
                                        <div class="toc-item flex gap-1.5 py-0.5 text-[#444444]" data-name="@sub.SubName.ToLower()">
                                            <span class="text-[#a89f8e]">└</span><span>@sub.SubName</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </nav>
            </aside>

            <!-- MAIN -->
            <div>
                <!-- Breadcrumb -->
                <div class="flex items-center gap-1.5 text-base text-[#a89f8e] mb-3">
                    <a asp-action="Read" asp-route-id="@w.WorldIDPK" class="no-underline hover:text-[#1a1a1a]">@w?.WorldName</a>
                    <span>›</span>
                    <span class="text-[#1a1a1a]">@current?.CatName</span>
                </div>

                <!-- Category header -->
                <h1 class="font-['Caveat'] text-5xl font-bold leading-none mb-2">@current?.CatName</h1>
                <p class="text-base text-[#333333] leading-snug mb-4 max-w-prose">
                    @cards.Count entr@(cards.Count == 1 ? "y" : "ies") in this category.
                </p>

                <!-- Sibling categories -->
                @if (siblings.Count > 1)
                {
                    <div class="flex flex-wrap items-center gap-2 mb-6">
                        <span class="text-base] text-[#a89f8e]">also in this world:</span>
                        @foreach (var sib in siblings)
                        {
                            var on = current != null && sib.CatIDPK == current.CatIDPK;
                            <a asp-action="Category" asp-route-id="@w.WorldIDPK" asp-route-catId="@sib.CatIDPK"
                               class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-base no-underline border border-[#1a1a1a] @(on ? "bg-[#1a1a1a] text-[#f7f3ea]" : "text-[#1a1a1a] hover:bg-[#1a1a1a] hover:text-[#f7f3ea]") transition-colors">
                                @sib.CatName
                            </a>
                        }
                    </div>
                }

                <!-- Cards -->
                @if (cards.Any())
                {
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
                        @foreach (var sc in cards)
                        {
                            var portrait = sc.PicScriptPicFKs?.FirstOrDefault()?.PicPath;
                            var subName = (sc.ScriptSubFK > 0 && subNames.TryGetValue(sc.ScriptSubFK, out var sn)) ? sn : null;
                            var excerpt = Excerpt(sc.ScriptContent);
                            var conn = connections.TryGetValue(sc.ScriptIDPK, out var cq) ? cq : 0;
                            <a asp-controller="Script" asp-action="Details" asp-route-scriptidpk="@sc.ScriptIDPK"
                               class="block no-underline text-[#1a1a1a] group">
                                <div class="aspect-square w-full border-[1.5px] border-dashed border-[#1a1a1a] bg-[repeating-linear-gradient(135deg,transparent_0_10px,rgba(26,26,26,0.08)_10px_11px)] overflow-hidden flex items-center justify-center relative">
                                    @if (!string.IsNullOrEmpty(portrait))
                                    {
                                        <img src="@Pic(portrait)" class="w-full h-full object-cover text-md" alt="@sc.ScriptTitle" />
                                    }
                                    else
                                    {
                                        <span class="text-2xl text-[#a89f8e]">portrait</span>
                                    }
                                </div>
                                <div class="mt-1.5">
                                    <div class="font-['Caveat'] text-2xl font-bold leading-none group-hover:text-[#a89f8e]">@sc.ScriptTitle</div>
                                    <div class="text-md text-[#a89f8e] mt-0.5 ">
                                        in @w?.WorldName@(string.IsNullOrEmpty(subName) ? "" : " · " + subName)
                                    </div>
                                    @if (!string.IsNullOrEmpty(excerpt))
                                    {
                                        <p class="text-base text-[#444444] leading-snug mt-1 line-clamp-2">@excerpt</p>
                                    }
                                    <div class="flex items-center gap-1 text-[10px] text-[#a89f8e] mt-1">
                                        <svg width="10" height="10" viewBox="0 0 16 16" fill="none"><circle cx="4" cy="8" r="1.6" stroke="currentColor" stroke-width="1.2" /><circle cx="12" cy="4" r="1.6" stroke="currentColor" stroke-width="1.2" /><circle cx="12" cy="12" r="1.6" stroke="currentColor" stroke-width="1.2" /><line x1="5.4" y1="7.2" x2="10.6" y2="4.6" stroke="currentColor" stroke-width="1" /><line x1="5.4" y1="8.8" x2="10.6" y2="11.4" stroke="currentColor" stroke-width="1" /></svg>
                                        @conn connection@(conn == 1 ? "" : "s")
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="border-[1.5px] border-dashed border-[#a89f8e] rounded-md px-6 py-12 text-center">
                        <div class="font-['Caveat'] text-[24px] font-bold mb-1">No entries here yet</div>
                        <div class="text-[13px] text-[#a89f8e]">This category doesn't have any scripts yet.</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        var f = document.getElementById('tocFilter');
        if (!f) return;
        f.addEventListener('input', function () {
            var q = this.value.trim().toLowerCase();
            document.querySelectorAll('#toc .toc-group').forEach(function (g) {
                var name = g.getAttribute('data-name') || '';
                var subHit = Array.from(g.querySelectorAll('.toc-item'))
                    .some(function (i) { return (i.getAttribute('data-name') || '').includes(q); });
                g.style.display = (!q || name.includes(q) || subHit) ? '' : 'none';
            });
        });
    })();

         // Toolbar search — live "search in this world" dropdown (entries + categories)
        (function () {
            var input = document.getElementById('worldSearch');
            var panel = document.getElementById('worldSearchResults');
            if (!input || !panel) return;

            var worldId    = input.getAttribute('data-id');
            var searchBase = '@Url.Action("Search", "World")';    // /World/Search
            var catBase    = '@Url.Action("Category", "World")';  // /World/Category
            var scriptBase = '@Url.Action("Details", "Script")';  // /Script/Details

            var timer = null, seq = 0;

            function esc(s) {
                return (s || '').replace(/[&<>"]/g, function (c) {
                    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
                });
            }
            function hide() { panel.classList.add('hidden'); panel.innerHTML = ''; }
            function render(data) {
                var html = '';

                var headCls = 'text-[10px] tracking-wider uppercase text-[#a89f8e] pt-1.5 px-3 pb-0.5';
                var itemCls = 'flex items-center gap-2 py-[7px] px-3 border-b border-dashed border-[#e5ddcb] '
                            + 'last:border-b-0 no-underline text-[#1a1a1a] text-[13px]';

                if (data.categories && data.categories.length) {
                    html += '<div class="' + headCls + '">Categories</div>';
                    data.categories.forEach(function (c) {
                        html += '<a class="' + itemCls + '" href="' + catBase + '/' + worldId + '?catId=' + c.id + '">'
                              +   '<span class="font-bold whitespace-nowrap overflow-hidden text-ellipsis">' + esc(c.name) + '</span>'
                              +   '<span class="ml-auto shrink-0 text-[11px] text-[#a89f8e]">category</span></a>';
                    });
                }
                if (data.scripts && data.scripts.length) {
                    html += '<div class="' + headCls + '">Entries</div>';
                    data.scripts.forEach(function (s) {
                        var meta = s.cat || (s.isChar ? 'character' : 'entry');
                        html += '<a class="' + itemCls + ' hover:bg-slate-600 hover:text-white" href="' + scriptBase + '?scriptidpk=' + s.id + '">'
                              +   '<span class="font-bold whitespace-nowrap overflow-hidden text-ellipsis">' + esc(s.title) + '</span>'
                              +   '<span class="ml-auto shrink-0 text-xs text-slate-300 hover:text-amber-100">' + esc(meta) + '</span></a>';
                    });
                }
                if (!html) html = '<div class="pt-1 px-2 text-sm text-slate-300">No matches in this world</div>';
                panel.innerHTML = html;
                panel.classList.remove('hidden');
            }

            input.addEventListener('input', function () {
                var q = this.value.trim();
                clearTimeout(timer);
                if (q.length < 1) { hide(); return; }
                timer = setTimeout(function () {
                    var mine = ++seq;
                    fetch(searchBase + '/' + worldId + '?q=' + encodeURIComponent(q))
                        .then(function (res) { return res.ok ? res.json() : null; })
                        .then(function (data) { if (data && mine === seq) render(data); })
                        .catch(function () { /* ignore */ });
                }, 180);
            });
            input.addEventListener('focus', function () { if (this.value.trim()) input.dispatchEvent(new Event('input')); });
            input.addEventListener('keydown', function (e) { if (e.key === 'Escape') { hide(); this.blur(); } });
            document.addEventListener('click', function (e) {
                if (e.target !== input && !panel.contains(e.target)) hide();
            });
        })();
</script>
}
