@model WorldBuilder.Models.World
@using WorldBuilder.Models

@{
    ViewData["Title"] = Model?.WorldName ?? "World";

    var w      = Model;
    var author = ViewData["AuthorHandle"] as string;
    var hasLiked = ViewData["HasLiked"] as bool? ?? false;
    var catCounts = ViewData["CatCounts"] as Dictionary<int, int> ?? new Dictionary<int, int>();
    var totalScripts = ViewData["TotalScripts"] as int? ?? 0;
    var totalCategories = ViewData["TotalCategories"] as int? ?? (w?.Categories?.Count ?? 0);
    var totalCharacters = ViewData["TotalCharacters"] as int? ?? 0;

    var cats = w?.Categories?.OrderBy(c => c.CatName).ToList() ?? new List<Category>();
    var cover = w?.Pictures?.FirstOrDefault(p => p.PicWorldFK == w.WorldIDPK);

    Func<string, string> Pic = p =>
        string.IsNullOrEmpty(p) ? null
        : (p.StartsWith("/") || p.StartsWith("http")) ? p : Url.Content("~/" + p);

    string Kfmt(int n) => n >= 1000 ? (n / 1000.0).ToString("0.#") + "k" : n.ToString();

    string Ago(DateTime? d)
    {
        var dt = (d ?? DateTime.Today).Date;
        var days = (int)(DateTime.Today - dt).TotalDays;
        if (days <= 0) return "today";
        if (days == 1) return "yesterday";
        if (days < 7) return days + "d ago";
        if (days < 30) return (days / 7) + "w ago";
        if (days < 365) return (days / 30) + "mo ago";
        return (days / 365) + "y ago";
    }
    var likeCount = w?.WorldLikes ?? 0;
}

@Html.AntiForgeryToken()

<style>
    #worldSearchResults .wsr-head { font-size:10px; letter-spacing:.05em; text-transform:uppercase; color:#a89f8e; padding:6px 12px 2px; }
    #worldSearchResults .wsr-item { display:flex; align-items:center; gap:8px; padding:7px 12px; border-bottom:1px dashed #e5ddcb; text-decoration:none; color:#1a1a1a; font-size:13px; }
    #worldSearchResults .wsr-item:last-child { border-bottom:0; }
    #worldSearchResults .wsr-item:hover { background:#1a1a1a; color:#f7f3ea; }
    #worldSearchResults .wsr-item:hover .wsr-meta { color:#c9bfa9; }
    #worldSearchResults .wsr-title { font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    #worldSearchResults .wsr-meta { margin-left:auto; flex:0 0 auto; font-size:11px; color:#a89f8e; }
    #worldSearchResults .wsr-empty { padding:10px 12px; font-size:12.5px; color:#a89f8e; }
</style>

<div class="m-5">
    <div class=" text-[#1a1a1a] -mx-4 -my-3 px-[30px] pt-5 pb-16">

        <!-- Page toolbar -->
        <div class="flex items-center gap-4 mb-6">
            <div class="flex items-center gap-3 min-w-0">
                <div class="w-9 h-9 border-1 border-[#1a1a1a] rounded-md bg-[repeating-linear-gradient(135deg,transparent_0_6px,rgba(26,26,26,0.08)_6px_7px)] shrink-0 overflow-hidden">
                    @if (cover != null && !string.IsNullOrEmpty(cover.PicPath))
                    {
                        <img src="@Pic(cover.PicPath)" class="w-full h-full object-cover" alt="" />
                    }
                </div>
                <div class="min-w-0">
                    <div class=" text-[24px] font-bold leading-none truncate">@w?.WorldName</div>
                    <div class="text-[11.5px] text-[#a89f8e] truncate">
                        by <span class="text-[#1a1a1a]">@@@(author ?? "creator")</span>
                        <span class="mx-1">·</span>@w?.WorldGenFK
                        <span class="mx-1">·</span>updated @Ago(w?.WorldUpdatedAt ?? w?.WorldCreatedAt)
                    </div>
                </div>
            </div>

            <div class="grow"></div>

            <div class="md:block relative w-64">
                <div class="flex items-center gap-2 border-[1.5px] border-[#1a1a1a] rounded-full px-3 py-1.5">
                    <svg width="15" height="15" viewBox="0 0 14 14"><circle cx="6" cy="6" r="4" stroke="#1a1a1a" stroke-width="1.4" fill="none" /><line x1="9" y1="9" x2="13" y2="13" stroke="#1a1a1a" stroke-width="1.4" /></svg>
                    <input id="worldSearch" data-id="@w?.WorldIDPK" autocomplete="off" placeholder="Search in @w?.WorldName…" class="flex-1 outline-none bg-transparent text-[13px]" />
                </div>
                <div id="worldSearchResults" class="hidden absolute z-20 mt-1 w-full max-h-80 overflow-auto bg-[#f7f3ea] border-[1.5px] border-[#1a1a1a] rounded-md" style="box-shadow:3px 3px 0 #1a1a1a"></div>
            </div>

            <button type="button" id="worldLikeBtn" data-id="@w?.WorldIDPK"
                    class="inline-flex items-center gap-1.5 border-[1.5px] border-[#1a1a1a] px-3.5 py-1.5 rounded-full text-[13px] font-bold cursor-pointer transition-colors @(hasLiked ? "bg-[#1a1a1a] text-[#f7f3ea]" : "hover:bg-[#1a1a1a] hover:text-[#f7f3ea]")">
                <svg width="13" height="12" viewBox="0 0 24 22" fill="none"><path d="M12 20 C 4 14, 2 9, 5 5 C 8 1, 12 5, 12 8 C 12 5, 16 1, 19 5 C 22 9, 20 14, 12 20 Z" stroke="currentColor" stroke-width="1.8" fill="@(hasLiked ? "currentColor" : "none")" /></svg>
                <span>Like</span><span class="opacity-70">·</span><span id="worldLikeCount">@Kfmt(likeCount)</span>
            </button>

            <button type="button" title="Save"
                    class="inline-flex items-center justify-center w-9 h-9 border-[1.5px] border-[#1a1a1a] rounded-full cursor-pointer hover:bg-[#1a1a1a] hover:text-[#f7f3ea] transition-colors">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M4 2 h8 v12 l-4 -3 -4 3 z" stroke="currentColor" stroke-width="1.4" fill="none" /></svg>
            </button>
            <button type="button" title="Share"
                    class="inline-flex items-center justify-center w-9 h-9 border-[1.5px] border-[#1a1a1a] rounded-full cursor-pointer hover:bg-[#1a1a1a] hover:text-[#f7f3ea] transition-colors">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="4" cy="8" r="2" stroke="currentColor" stroke-width="1.4" /><circle cx="12" cy="3.5" r="2" stroke="currentColor" stroke-width="1.4" /><circle cx="12" cy="12.5" r="2" stroke="currentColor" stroke-width="1.4" /><line x1="5.7" y1="7" x2="10.3" y2="4.4" stroke="currentColor" stroke-width="1.2" /><line x1="5.7" y1="9" x2="10.3" y2="11.6" stroke="currentColor" stroke-width="1.2" /></svg>
            </button>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[230px_1fr] gap-8">

            <!-- LEFT: Contents tree -->
            <aside>
                <div class="flex items-baseline justify-between mb-2">
                    <h2 class=" text-[24px] font-bold">Contents</h2>
                    <span class="text-[11.5px] text-[#a89f8e]">@totalScripts scripts</span>
                </div>
                <div class="flex items-center gap-2 border-[1.5px] border-[#1a1a1a] rounded-full px-3 py-1.5 mb-3">
                    <svg width="13" height="13" viewBox="0 0 14 14"><circle cx="6" cy="6" r="4" stroke="#1a1a1a" stroke-width="1.4" fill="none" /><line x1="9" y1="9" x2="13" y2="13" stroke="#1a1a1a" stroke-width="1.4" /></svg>
                    <input id="tocFilter" placeholder="search through categories..." class="flex-1 outline-none bg-transparent text-[12.5px]" />
                </div>

                <nav id="toc" class="text-[13.5px]">
                    @if (cats.Any())
                    {
                        foreach (var cat in cats)
                        {
                            var count = catCounts.TryGetValue(cat.CatIDPK, out var cc) ? cc : 0;
                            var subs = cat.SubCategories?.OrderBy(su => su.SubName).ToList() ?? new List<SubCategory>();
                            <div class="toc-group mb-1.5" data-name="@cat.CatName.ToLower()">
                                <a asp-action="Category" asp-route-id="@w.WorldIDPK" asp-route-catId="@cat.CatIDPK"
                                   class="flex items-center justify-between py-1 no-underline text-[#1a1a1a] hover:text-[#a89f8e]">
                                    <span class="flex items-center gap-1.5 font-bold">
                                        <span class="w-2 h-2 rounded-full" style="background-color:@(cat.CatColor ?? "#a89f8e")"></span>
                                        @cat.CatName
                                    </span>
                                    <span class="text-[#a89f8e] text-[12px]">@count</span>
                                </a>
                                @if (subs.Any())
                                {
                                    <div class="pl-3.5">
                                        @foreach (var sub in subs)
                                        {
                                            <div class="toc-item flex gap-1.5 py-0.5 text-[#444444]" data-name="@sub.SubName.ToLower()">
                                                <span class="text-[#a89f8e]">└</span><span>@sub.SubName</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-[12.5px] text-[#a89f8e]">No contents yet.</p>
                    }
                </nav>
            </aside>

            <!-- MAIN -->
            <div>
                <!-- Hero -->
                <div class="relative aspect-[16/6] w-full border-[1.5px] border-[#1a1a1a] bg-[repeating-linear-gradient(135deg,transparent_0_10px,rgba(26,26,26,0.08)_10px_11px)] overflow-hidden flex items-end mb-6">
                    @if (cover != null && !string.IsNullOrEmpty(cover.PicPath))
                    {
                        <img src="@Pic(cover.PicPath)" class="absolute inset-0 w-full h-full object-cover" alt="" />
                    }
                    <div class="relative px-6 pb-4">
                        <div class="text-5xl font-bold leading-none drop-shadow-[0_1px_0_#f7f3ea] w-full bg-white p-3 rounded-xl border">Welcome to @w?.WorldName</div>
                    </div>
                </div>

                <!-- About + At a glance -->
                <div class="grid grid-cols-1 md:grid-cols-[1.6fr_1fr] gap-6 mb-8">
                    <div>
                        <div class="text-[11px] tracking-wide text-[#a89f8e] uppercase mb-1">About this world</div>
                        @if (!string.IsNullOrEmpty(w?.WorldDesc))
                        {
                            <p class="text-[14px] text-[#333333] leading-relaxed max-w-prose">@w.WorldDesc</p>
                        }
                        else
                        {
                            <p class="text-[13px] text-[#a89f8e] italic">No description yet.</p>
                        }
                        <div class="flex items-center gap-1.5 text-[13px] text-[#1a1a1a] mt-3">
                            <span>▸</span><span class="hover:text-[#a89f8e] cursor-default">Start from the contents on the left, or browse by category below.</span>
                        </div>
                    </div>

                    <div class="border-[1.5px] border-[#1a1a1a] rounded-md p-4">
                        <div class=" text-[22px] font-bold mb-2">At a glance</div>
                        <div class="text-[13px] space-y-1.5">
                            <div class="flex justify-between"><span class="text-[#a89f8e]">Genre</span><span>@w?.WorldGenFK</span></div>
                            <div class="flex justify-between"><span class="text-[#a89f8e]">Scripts</span><span>@totalScripts across @totalCategories categories</span></div>
                            <div class="flex justify-between"><span class="text-[#a89f8e]">Characters</span><span>@totalCharacters</span></div>
                            <div class="flex justify-between"><span class="text-[#a89f8e]">Likes</span><span>@Kfmt(likeCount)</span></div>
                            <div class="flex justify-between"><span class="text-[#a89f8e]">Updated</span><span>@Ago(w?.WorldUpdatedAt ?? w?.WorldCreatedAt)</span></div>
                        </div>
                    </div>
                </div>

                <!-- Browse by category -->
                <div class="flex items-baseline justify-between mb-3">
                    <h2 class=" text-[30px] font-bold">Browse by category</h2>
                    <span class="text-[12px] text-[#a89f8e]">or jump straight from the contents on the left</span>
                </div>

                @if (cats.Any())
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                        @foreach (var cat in cats)
                        {
                            var count = catCounts.TryGetValue(cat.CatIDPK, out var cc) ? cc : 0;
                            var subs = cat.SubCategories?.OrderBy(su => su.SubName).ToList() ?? new List<SubCategory>();
                            <a asp-action="Category" asp-route-id="@w.WorldIDPK" asp-route-catId="@cat.CatIDPK"
                               class="block border-[1.5px] border-[#1a1a1a] rounded-md p-4 no-underline text-[#1a1a1a] hover:bg-[#1a1a1a] hover:text-[#f7f3ea] transition-colors group">
                                <div class="flex items-baseline justify-between">
                                    <span class=" text-[24px] font-bold">@cat.CatName</span>
                                    <span class="text-[12px] text-[#a89f8e] group-hover:text-[#f7f3ea]">@count scripts</span>
                                </div>
                                @if (subs.Any())
                                {
                                    <div class="text-[12.5px] text-[#a89f8e] group-hover:text-[#f7f3ea] mt-1 line-clamp-1">
                                        @string.Join(", ", subs.Take(4).Select(su => su.SubName))
                                    </div>
                                }
                                <div class="text-[13px] mt-2">Browse →</div>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="border-[1.5px] border-dashed border-[#a89f8e] rounded-md px-6 py-12 text-center">
                        <div class=" text-[24px] font-bold mb-1">Nothing to read here yet</div>
                        <div class="text-[13px] text-[#a89f8e]">This world has no categories or entries yet.</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Contents filter
    (function () {
        var f = document.getElementById('tocFilter');
        if (!f) return;
        f.addEventListener('input', function () {
            var q = this.value.trim().toLowerCase();
            document.querySelectorAll('#toc .toc-group').forEach(function (g) {
                var name = g.getAttribute('data-name') || '';
                var subHit = Array.from(g.querySelectorAll('.toc-item'))
                    .some(function (i) { return (i.getAttribute('data-name') || '').includes(q); });
                g.style.display = (!q || name.includes(q) || subHit) ? '' : 'none';
            });
        });
    })();

    // World like toggle
    (function () {
        var btn = document.getElementById('worldLikeBtn');
        if (!btn) return;
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        btn.addEventListener('click', async function () {
            var id = btn.getAttribute('data-id');
            btn.disabled = true;
            try {
                var res = await fetch('@Url.Action("ToggleLike", "World")/' + id, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': tokenEl ? tokenEl.value : '' }
                });
                if (res.status === 401) { window.location.href = '/Identity/Account/Login'; return; }
                if (!res.ok) throw new Error('failed');
                var data = await res.json();
                document.getElementById('worldLikeCount').textContent =
                    data.count >= 1000 ? (data.count / 1000).toFixed(1) + 'k' : data.count;
                var heart = btn.querySelector('path');
                if (data.liked) {
                    btn.classList.add('bg-[#1a1a1a]', 'text-[#f7f3ea]');
                    if (heart) heart.setAttribute('fill', 'currentColor');
                } else {
                    btn.classList.remove('bg-[#1a1a1a]', 'text-[#f7f3ea]');
                    if (heart) heart.setAttribute('fill', 'none');
                }
            } catch (e) {
                console.error(e);
            } finally {
                btn.disabled = false;
            }
        });
    })();

    // Toolbar search — live "search in this world" dropdown (entries + categories)
    (function () {
        var input = document.getElementById('worldSearch');
        var panel = document.getElementById('worldSearchResults');
        if (!input || !panel) return;

        var worldId    = input.getAttribute('data-id');
        var searchBase = '@Url.Action("Search", "World")';    // /World/Search
        var catBase    = '@Url.Action("Category", "World")';  // /World/Category
        var scriptBase = '@Url.Action("Details", "Script")';  // /Script/Details

        var timer = null, seq = 0;

        function esc(s) {
            return (s || '').replace(/[&<>"]/g, function (c) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
            });
        }
        function hide() { panel.classList.add('hidden'); panel.innerHTML = ''; }

        function render(data) {
            var html = '';
            if (data.categories && data.categories.length) {
                html += '<div class="wsr-head">Categories</div>';
                data.categories.forEach(function (c) {
                    html += '<a class="wsr-item" href="' + catBase + '/' + worldId + '?catId=' + c.id + '">'
                          +   '<span class="wsr-title">' + esc(c.name) + '</span>'
                          +   '<span class="wsr-meta">category</span></a>';
                });
            }
            if (data.scripts && data.scripts.length) {
                html += '<div class="wsr-head">Entries</div>';
                data.scripts.forEach(function (s) {
                    var meta = s.cat || (s.isChar ? 'character' : 'entry');
                    html += '<a class="wsr-item" href="' + scriptBase + '?scriptidpk=' + s.id + '">'
                          +   '<span class="wsr-title">' + esc(s.title) + '</span>'
                          +   '<span class="wsr-meta">' + esc(meta) + '</span></a>';
                });
            }
            if (!html) html = '<div class="wsr-empty">No matches in this world</div>';
            panel.innerHTML = html;
            panel.classList.remove('hidden');
        }

        input.addEventListener('input', function () {
            var q = this.value.trim();
            clearTimeout(timer);
            if (q.length < 1) { hide(); return; }
            timer = setTimeout(function () {
                var mine = ++seq;
                fetch(searchBase + '/' + worldId + '?q=' + encodeURIComponent(q))
                    .then(function (res) { return res.ok ? res.json() : null; })
                    .then(function (data) { if (data && mine === seq) render(data); })
                    .catch(function () { /* ignore */ });
            }, 180);
        });
        input.addEventListener('focus', function () { if (this.value.trim()) input.dispatchEvent(new Event('input')); });
        input.addEventListener('keydown', function (e) { if (e.key === 'Escape') { hide(); this.blur(); } });
        document.addEventListener('click', function (e) {
            if (e.target !== input && !panel.contains(e.target)) hide();
        });
    })();
</script>
}
