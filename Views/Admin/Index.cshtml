@model WorldBuilder.Controllers.AdminDashboard
@{
    ViewData["Title"] = "Admin";
    int maxUsed = Model.MostUsedGenres.Select(g => g.Count).DefaultIfEmpty(1).Max();
    int maxLiked = Model.MostLikedGenres.Select(g => g.Count).DefaultIfEmpty(1).Max();
    string Kfmt(int n) => n >= 1000 ? (n / 1000.0).ToString("0.#") + "k" : n.ToString();
}

<aside class="bg-stone-200 text-stone-900 antialiased min-h-screen">
    <!-- Header -->
    <div class="max-w-7xl mx-auto px-6 py-6 flex items-center justify-between">
        <div>
            <span class="font-sans text-xs uppercase tracking-[.22em] text-teal-900">
                Administration
            </span>
            <h1 class="font-serif font-semibold text-5xl leading-none mt-3">
                Control panel.
            </h1>
            <p class="text-sm text-stone-600 mt-3">
                Manage users, worlds, genres and the registry.
            </p>
        </div>
        <button type="button"
                onclick="document.getElementById('genreModal').classList.remove('hidden')"
                class="inline-flex items-center gap-2 bg-teal-950 text-[#f0ebdf] px-6 py-3 text-sm transition-all hover:bg-teal-900 hover:border-teal-900 hover:-translate-y-0.5">
            Create genre
            <span>→</span>
        </button>
    </div>
    <hr class="max-w-7xl mx-auto border-stone-300">
    <!-- stats -->
    <div class="border-y border-stone-300 bg-stone-100/50 mt-10">
        <div class="max-w-7xl mx-auto grid grid-cols-2 sm:grid-cols-4">
            <div class="text-center px-6 py-8 border-r border-stone-200">
                <div class="font-serif text-4xl font-medium">
                    @Model.TotalWorlds.ToString("N0")
                </div>

                <div class="font-sans text-xs uppercase tracking-[.16em] text-stone-600 mt-3">
                    Worlds
                </div>
            </div>
            <div class="text-center px-6 py-8 border-r border-stone-200">
                <div class="font-serif text-4xl font-medium">
                    @Model.ActiveBuilders.ToString("N0")
                </div>
                <div class="font-sans text-xs uppercase tracking-[.16em] text-stone-600 mt-3">
                    Builders
                </div>
            </div>
            <div class="text-center px-6 py-8 border-r border-stone-200">

                <div class="font-serif text-4xl font-medium">
                    @Model.CreatorNodes.ToString("N0")
                </div>

                <div class="font-sans text-xs uppercase tracking-[.16em] text-stone-600 mt-3">
                    Categories
                </div>
            </div>
            <div class="text-center px-6 py-8">
                <div class="font-serif text-4xl font-medium">
                    @Model.LockedUsers.ToString("N0")
                </div>
                <div class="font-sans text-xs uppercase tracking-[.16em] text-stone-600 mt-3">
                    Locked users
                </div>
            </div>
        </div>
    </div>
    @* <main class="max-w-7xl mx-auto px-6 py-16">
        <!-- tabs -->
        <div class="flex gap-8 border-b border-stone-300 mb-8">
            <span class="pb-3 border-b-2 border-teal-900 font-serif text-lg">
                Users
                <span class="text-stone-500 text-sm">
                    @Model.Users.Count
                </span>
            </span>
            <a asp-controller="World"
               asp-action="Index"
               class="pb-3 text-stone-600 hover:text-stone-900 no-underline">
                Worlds
            </a>
            <a asp-controller="Genre"
               asp-action="Index"
               class="pb-3 text-stone-600 hover:text-stone-900 no-underline">
                Genres
            </a>
            <a asp-controller="Tag"
               asp-action="Index"
               class="pb-3 text-stone-600 hover:text-stone-900 no-underline">
                Tags
            </a>
        </div>
    </main> *@
    <!-- content -->
    <aside class="grid grid-cols-1 lg:grid-cols-[1.7fr_1fr] gap-8 m-5">
        <!-- users -->
        <section>
            <form method="get"
                  class="flex items-center gap-3 border border-stone-300 bg-stone-100 px-4 py-3 mb-5">
                <span class="material-symbols-outlined text-stone-500">
                    search
                </span>
                <input name="q"
                       value="@Model.Query"
                       placeholder="Search users..."
                       class="flex-1 bg-transparent outline-none text-sm">
            </form>
            <div class="border border-stone-300 bg-stone-100">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-stone-300 text-xs uppercase tracking-widest text-stone-500">
                            <th class="text-left px-4 py-3">
                                User
                            </th>
                            <th class="text-left px-4 py-3">
                                Role
                            </th>
                            <th class="text-left px-4 py-3">
                                Worlds
                            </th>
                            <th class="text-left px-4 py-3">
                                Likes
                            </th>
                            <th class="text-left px-4 py-3">
                                Status
                            </th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.Users)
                        {
                            <tr class="border-b border-dashed border-stone-300">
                                <td class="px-4 py-4">
                                    <div class="font-serif text-lg">
                                        @@@u.Handle
                                    </div>

                                    <div class="text-xs text-stone-500">
                                        @u.Email
                                    </div>
                                </td>
                                <td class="px-4 py-4">
                                    <form asp-action="SetRole"
                                          method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden"
                                               name="userId"
                                               value="@u.IdentityId">
                                        <select name="role"
                                                onchange="this.form.submit()"
                                                class="border border-stone-300 bg-transparent px-3 py-1 text-xs">
                                            @foreach (var r in Model.AllRoles)
                                            {
                                                <option value="@r"
                                                        selected="@(r == u.Role)">
                                                    @r
                                                </option>
                                            }
                                        </select>
                                    </form>
                                </td>
                                <td class="px-4 py-4">
                                    @u.Worlds
                                </td>
                                <td class="px-4 py-4">
                                    ♥ @Kfmt(u.Likes)
                                </td>
                                <td class="px-4 py-4">
                                    @if (u.Locked)
                                    {
                                        <span class="text-xs text-red-800 uppercase tracking-wide">
                                            Locked
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-green-800 uppercase tracking-wide">
                                            Active
                                        </span>
                                    }
                                </td>
                                <td class="px-4 py-4">
                                    <form asp-action="ToggleLock"
                                          method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden"
                                               name="userId"
                                               value="@u.IdentityId">
                                        <button class="material-symbols-outlined hover:text-teal-900">
                                            @(u.Locked ? "lock_open" : "lock")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <!-- RIGHT SIDEBAR -->
        <aside class="space-y-8">
            <!-- Pending genre requests -->
            <section class="border border-stone-300 bg-stone-100 p-6">
                <div class="flex items-end justify-between mb-6">
                    <div>
                        <span class="font-sans text-xs uppercase tracking-[.22em] text-teal-900">
                            Review
                        </span>
                        <h2 class="font-serif text-3xl leading-none mt-2">
                            Genre requests
                        </h2>
                    </div>
                    <span class="flex h-7 w-7 items-center justify-center rounded-full bg-teal-900 text-stone-100 text-xs">
                        @Model.PendingRequests.Count
                    </span>
                </div>
                @if (Model.PendingRequests.Any())
                {
                    var requesterUsernames = ViewData["RequesterUsernames"] as Dictionary<int, string>;
                    <div class="space-y-5">
                        @foreach (var r in Model.PendingRequests)
                        {
                            <div class="border-b border-dashed border-stone-300 pb-5 last:border-none">
                                <div class="flex justify-between gap-4">
                                    <div>
                                        <h3 class="font-serif text-xl">
                                            @r.GenreReqName
                                        </h3>
                                        <p class="text-xs text-stone-500 mt-1">
                                            from
                                            @(requesterUsernames != null && requesterUsernames.TryGetValue(r.GenreReqIDPK, out var uname) && uname != null ? uname : "someone")
                                            ·
                                            @r.GenreReqCreatedAt.ToString("MMM d")
                                        </p>
                                        @if (!string.IsNullOrWhiteSpace(r.GenreReqReason))
                                        {
                                            <p class="text-sm text-stone-600 mt-3">
                                                @r.GenreReqReason
                                            </p>
                                        }
                                    </div>
                                    <div class="flex flex-col gap-2">
                                        <form asp-action="ApproveRequest"
                                              method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden"
                                                   name="id"
                                                   value="@r.GenreReqIDPK">
                                            <button class="bg-[#211c14] text-stone-100 px-4 py-2 text-xs hover:bg-teal-900 transition-colors">
                                                Approve
                                            </button>
                                        </form>
                                        <form asp-action="RejectRequest"
                                              method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden"
                                                   name="id"
                                                   value="@r.GenreReqIDPK">
                                            <button class="border border-stone-900 px-4 py-2 text-xs hover:bg-stone-200 transition-colors">
                                                Reject
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-stone-500">
                        No pending requests.
                    </p>
                }
            </section>

            <!-- Worlds overview -->
            <section class="border border-stone-300 bg-stone-100">
                <div class="px-6 pt-6">
                    <span class="font-sans text-xs uppercase tracking-[.22em] text-teal-900">
                        Overview
                    </span>
                    <h2 class="font-serif text-3xl mt-2">
                        Registry
                    </h2>
                </div>
                <div class="grid grid-cols-2 mt-6">
                    <div class="text-center py-6 border-t border-r border-stone-300">
                        <div class="font-serif text-4xl">
                            @Model.TotalWorlds.ToString("N0")
                        </div>
                        <div class="text-xs uppercase tracking-widest text-stone-500 mt-2">
                            Worlds
                        </div>
                    </div>
                    <div class="text-center py-6 border-t border-stone-300">
                        <div class="font-serif text-4xl">
                            @Model.ActiveBuilders.ToString("N0")
                        </div>
                        <div class="text-xs uppercase tracking-widest text-stone-500 mt-2">
                            Builders
                        </div>
                    </div>
                    <div class="text-center py-6 border-t border-r border-stone-300">
                        <div class="font-serif text-4xl">
                            @Model.CreatorNodes.ToString("N0")
                        </div>
                        <div class="text-xs uppercase tracking-widest text-stone-500 mt-2">
                            Categories
                        </div>
                    </div>
                    <div class="text-center py-6 border-t border-stone-300">
                        <div class="font-serif text-4xl">
                            @Model.LockedUsers.ToString("N0")
                        </div>
                        <div class="text-xs uppercase tracking-widest text-stone-500 mt-2">
                            Locked
                        </div>
                    </div>
                </div>
            </section>

            <!-- Most used genres -->
            <section class="border border-stone-300 bg-stone-100 p-6">
                <span class="font-sans text-xs uppercase tracking-[.22em] text-teal-900">
                    Analytics
                </span>
                <h2 class="font-serif text-3xl mt-2 mb-6">
                    Popular genres
                </h2>



                <div class="space-y-5">


                    @foreach (var g in Model.MostUsedGenres)
                    {
                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="font-serif">
                                    @g.Name
                                </span>
                                <span class="text-stone-500">
                                    @g.Count
                                </span>
                            </div>
                            <div class="h-2 bg-stone-300">
                                <div class="h-full bg-teal-900"
                                     style="width:@(maxUsed == 0 ? 0 : (int)(g.Count * 100.0 / maxUsed))%">
                                </div>
                            </div>
                        </div>
                    }
                    @if (!Model.MostUsedGenres.Any())
                    {
                        <p class="text-sm text-stone-500">
                            No data yet.
                        </p>
                    }
                </div>
            </section>

            <!-- Most liked genres -->
            <section class="border border-stone-300 bg-stone-100 p-6">
                <span class="font-sans text-xs uppercase tracking-[.22em] text-teal-900">
                    Engagement
                </span>
                <h2 class="font-serif text-3xl mt-2 mb-6">
                    Most liked
                </h2>
                <div class="space-y-5">
                    @foreach (var g in Model.MostLikedGenres)
                    {
                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="font-serif">
                                    @g.Name
                                </span>
                                <span class="text-stone-500">
                                    @Kfmt(g.Count)
                                </span>
                            </div>
                            <div class="h-2 bg-stone-300">
                                <div class="h-full bg-[#a3712a]"
                                     style="width:@(maxLiked == 0 ? 0 : (int)(g.Count * 100.0 / maxLiked))%">
                                </div>
                            </div>
                        </div>
                    }
                    @if (!Model.MostLikedGenres.Any())
                    {
                        <p class="text-sm text-stone-500">
                            No data yet.
                        </p>
                    }
                </div>
            </section>
        </aside>
    </aside>
</aside>

<!-- Create genre modal -->
<div id="genreModal"
     class="hidden fixed inset-0 z-50 flex  items-center justify-center bg-black/40 px-6"
     onclick="if(event.target===this) this.classList.add('hidden')">
    <div class="max-w-lg bg-stone-100 border border-stone-900 p-8 shadow-xl w-[40%]">
        <div class="flex items-start justify-between mb-6">
            <div>
                <span class="font-sans text-xs uppercase tracking-[.22em] text-teal-900">
                    Registry
                </span>
                <h2 class="font-serif text-4xl leading-none mt-2">
                    Create genre
                </h2>
            </div>
            <button type="button"
                    onclick="document.getElementById('genreModal').classList.add('hidden')"
                    class="material-symbols-outlined text-stone-600 hover:text-stone-900">
                close
            </button>
        </div>
        <p class="text-sm text-stone-600 mb-8">
            Add a new genre to the world registry. It will immediately become available when creating worlds.
        </p>
        <form asp-action="CreateGenre"
              method="post">
            @Html.AntiForgeryToken()
            <!-- Name -->
            <div class="mb-5">
                <label class="block font-sans text-xs uppercase tracking-widest text-stone-600 mb-2">
                    Genre name
                </label>
                <input name="GenreName"
                       maxlength="100"
                       required
                       placeholder="Solarpunk"
                       class="w-full border border-stone-300 bg-white px-4 py-3 outline-none focus:border-teal-900">
            </div>
            <!-- Description -->
            <div class="mb-5">
                <label class="block font-sans text-xs uppercase tracking-widest text-stone-600 mb-2">
                    Description
                </label>
                <textarea name="GenreDescription"
                          maxlength="500"
                          rows="4"
                          placeholder="Hopeful futures powered by renewable technology..."
                          class="w-full border border-stone-300 bg-white px-4 py-3 outline-none focus:border-teal-900"></textarea>
            </div>
            <!-- Color -->
            <div class="mb-8">
                <label class="block font-sans text-xs uppercase tracking-widest text-stone-600 mb-3">
                    Accent colour
                </label>
                <input type="hidden"
                       id="GenreColor"
                       name="GenreColor"
                       value="#1c4551">
                @{
                    var swatches = new[]
                    {
                        "#1c4551",
                        "#a3712a",
                        "#4f7a52",
                        "#7a2f3a",
                        "#3f6079",
                        "#6b4a7a",
                        "#211c14"
                    };
                }
                <div class="flex gap-3">
                    @foreach (var c in swatches)
                    {
                        <button type="button"
                                data-color="@c"
                                class="genre-swatch h-8 w-8 border-2 border-transparent transition-transform hover:scale-110"
                                style="background:@c">
                        </button>
                    }
                </div>
            </div>
            <!-- Buttons -->
            <div class="flex justify-end gap-3">
                <button type="button"
                        onclick="document.getElementById('genreModal').classList.add('hidden')"
                        class="border border-stone-900 px-6 py-3 text-sm hover:bg-stone-200">
                    Cancel
                </button>
                <button type="submit"
                        class="bg-[#211c14] text-stone-100 px-6 py-3 text-sm hover:bg-teal-900 transition-colors">
                    Create genre →
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const hidden = document.getElementById('GenreColor');
            document.querySelectorAll('.genre-swatch').forEach(function (b) {
                if (b.dataset.color === hidden.value) b.style.borderColor = '#1a1a1a';
                b.addEventListener('click', function () {
                    hidden.value = b.dataset.color;
                    document.querySelectorAll('.genre-swatch').forEach(x => x.style.borderColor = 'transparent');
                    b.style.borderColor = '#1a1a1a';
                });
            });
        })();
    </script>
}
