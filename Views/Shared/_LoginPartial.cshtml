@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using WorldBuilder.Models
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject WorldBuilderDBContext DbContext
@model int?

@{
    // Resolve the signed-in user's own profile id. Prefer the value the layout passes
    // (set by HomeController), but fall back to a direct lookup so the link works on
    // every view, not just Home.
    int? profileId = Model;
    if (SignInManager.IsSignedIn(User) && profileId == null)
    {
        var uid = UserManager.GetUserId(User);
        profileId = await DbContext.UserInfos
            .Where(u => u.UserInfoUserIDFK == uid)
            .Select(u => (int?)u.UserInfoIDPK)
            .FirstOrDefaultAsync();
    }
}

<ul class="flex items-center gap-1 list-none m-0 p-0 min-w-0">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="min-w-0">
            @{
                var profileHref = profileId != null;
                var cls = "block max-w-[7rem] sm:max-w-[10rem] lg:max-w-[14rem] truncate text-sm "
                        + "text-gray-500 hover:text-gray-900 hover:bg-gray-100 px-2 sm:px-3 py-1.5 "
                        + "rounded-md transition-colors duration-150";
            }
            @if (profileHref)
            {
                <a asp-controller="Author" asp-action="Index" asp-route-id="@profileId"
                   class="@cls" title="My profile"><span class="hidden sm:inline">Hello, </span>@User.Identity?.Name</a>
            }
            else
            {
                @* No public profile row yet — send them to their settings instead. *@
                <a asp-controller="Profile" asp-action="Edit"
                   class="@cls" title="My profile"><span class="hidden sm:inline">Hello, </span>@User.Identity?.Name</a>
            }
        </li>
        <li class="shrink-0">
            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit"
                        class="text-sm text-gray-500 hover:text-gray-900 hover:bg-gray-100 px-2 sm:px-3 py-1.5 rounded-md transition-colors duration-150 cursor-pointer bg-transparent border-none">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li>
            <a asp-area="Identity" asp-page="/Account/Register"
               class="text-sm text-gray-500 hover:text-gray-900 hover:bg-gray-100 px-3 py-1.5 rounded-md transition-colors duration-150">
                Register
            </a>
        </li>
        <li>
            <a asp-area="Identity" asp-page="/Account/Login"
               class="text-sm font-medium text-gray-900 border border-gray-300 hover:bg-gray-50 px-3.5 py-1.5 rounded-md transition-colors duration-150">
                Login
            </a>
        </li>
    }
</ul>
