<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorldBuilder</title>
    <script type="importmap"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;700&family=Kalam:wght@300;400;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorldBuilder.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" rel="stylesheet">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
</head>
@{
    var userInfoId = ViewData["UserInfoId"] as int?;
}
<body class="min-h-screen flex flex-col bg-stone-200 text-stone-900 antialiased">

    <!-- top bar -->
    <header class="sticky top-0 z-50 bg-stone-200 backdrop-blur border-b border-stone-300">
        <div class="flex items-center justify-between max-w-7xl mx-auto px-6 py-3.5 gap-4">

            <div class="flex items-center gap-3 min-w-0">
                <button type="button" onclick="showDrawer()"
                        class="material-symbols-outlined cursor-pointer text-stone-600 hover:text-stone-900 transition-colors sm:hidden">
                    menu
                </button>
                <a asp-controller="Home" asp-action="Index" class="flex items-baseline gap-3 no-underline shrink-0">
                    <span class="font-serif font-semibold text-[20px] tracking-[.14em] uppercase text-teal-900">WORLD BUILDER</span>
                    <span class="hidden md:inline font-sans text-xs tracking-[.2em] uppercase text-teal-600">the world registry</span>
                </a>
            </div>

            <nav aria-label="Primary" class="hidden sm:flex items-center gap-6 font-sans text-xs tracking-[.04em]">
                <a asp-controller="Home" asp-action="Index" class="no-underline text-stone-600 hover:text-stone-900 transition-colors">Home</a>
                <a asp-controller="World" asp-action="Index" class="no-underline text-stone-600 hover:text-stone-900 transition-colors">Worlds</a>
                <a asp-controller="Author" asp-action="Browse" class="no-underline text-stone-600 hover:text-stone-900 transition-colors">Community</a>

            </nav>

            <div class="flex items-center gap-3">
                <div class="relative hidden md:block">
                    <form asp-controller="World" asp-action="Index" method="get"
                          class="flex items-center gap-2 border border-stone-300 bg-stone-100 px-3 py-1.5 hover:border-teal-900">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                            <circle cx="5.5" cy="5.5" r="4" stroke="#57534e" stroke-width="1.4" />
                            <line x1="8.5" y1="8.5" x2="12" y2="12" stroke="#57534e" stroke-width="1.4" stroke-linecap="round" />
                        </svg>
                        <input id="globalSearch" name="q" autocomplete="off"
                               class="font-sans text-xs bg-transparent outline-none w-40 placeholder-stone-400"
                               placeholder="Search worlds…" />
                    </form>
                    <div id="globalSearchResults"
                         class="hidden absolute right-0 z-[60] mt-1 w-80 max-h-96 overflow-auto bg-stone-100 border border-stone-300 shadow-xl">
                    </div>
                </div>
                <partial name="_LoginPartial" model="userInfoId" />
            </div>
        </div>
    </header>

    <!-- Drawer -->
    <div id="drawer"
         class="hidden fixed inset-0 z-[100] flex justify-start bg-black/30 opacity-0 transition-opacity duration-200"
         onclick="hideDrawer()">
        @await Component.InvokeAsync("Drawer")
    </div>

    <main class="flex-1 w-full">
        @RenderBody()
    </main>

    <!-- footer -->
    <footer class="border-t border-stone-300 bg-stone-100/60">
        <div class="max-w-7xl mx-auto px-6 py-7 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div class="flex items-baseline gap-3">
                <span class="font-serif font-semibold tracking-[.14em] text-teal-900">WORLD BUILDER</span>
                <span class="font-sans text-xs tracking-[.2em] uppercase text-teal-600">the world registry</span>
            </div>
            <div class="font-sans text-xs text-stone-500 flex items-center gap-4">
                <span>© 2026 WorldBuilder</span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy"
                   class="no-underline text-stone-500 hover:text-teal-900 transition-colors">Privacy</a>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/lightbox.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
