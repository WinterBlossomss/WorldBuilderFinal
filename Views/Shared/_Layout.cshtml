<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorldBuilder</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorldBuilder.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;700&family=Kalam:wght@300;400;700&display=swap" rel="stylesheet" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css"
          rel="stylesheet">
</head>
<body class="min-h-screen flex flex-col bg-gray-50 text-gray-900 font-crimson">

    <header class="bg-white border-b border-gray-200">
        <nav class="sticky top-0 z-50 h-15 bg-wb-bg/90 backdrop-blur-mdx border-b border-white/[0.07] px-7 ">
            <div class="flex flex row pt-2">
                <div class="flex flex-row flex-auto items-center">
                    <div class=" flex items-center flex-row gap-2 mr-8 shrink-0">
                        <button class="material-symbols-outlined cursor-pointer" onclick="showDrawer()">
                            menu
                        </button>
                    </div>
                    <div class=" flex items-center flex-row gap-2 mr-8 shrink-0">
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                            <circle cx="11" cy="11" r="9" stroke="#4f79f0" strokeWidth="1.8" />
                            <path d="M2 11Q11 4 20 11Q11 18 2 11Z" stroke="#4f79f0" strokeWidth="1.1" fill="none" />
                            <line x1="11" y1="2" x2="11" y2="20" stroke="#4f79f0" strokeWidth="1.1" />
                        </svg>
                        <a href="/" class="font-extrabold text-[20px] tracking-tight whitespace-nowrap">
                            World Builder
                        </a>
                    </div>
                    <ul class="flex flex-row gap-1 list-none m-0 p-0">
                        <li>
                            <a asp-controller="Home" asp-action="Index"
                               class="text-sm text-gray-500 hover:text-gray-900 hover:bg-gray-100 px-3 py-1.5 rounded-md transition-colors duration-150">
                                Home
                            </a>
                        </li>
                        <li>
                            <a asp-controller="World" asp-action="Index"
                               class="text-sm text-gray-500 hover:text-gray-900 hover:bg-gray-100 px-3 py-1.5 rounded-md transition-colors duration-150">
                                Worlds
                            </a>
                        </li>
                        <li>

                        </li>
                    </ul>
                </div>
                <div class="flex flex-row  justify-items-end">
                    <div class="flex items-center justify-items-end">
                        <div class="flex items-center gap-2 bg-wb-surf border border-white/[0.08] rounded-lg px-3 py-1.5 text-wb-muted">
                            <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                                <circle cx="5.5" cy="5.5" r="4" stroke="currentColor" strokeWidth="1.4" />
                                <line x1="8.5" y1="8.5" x2="12" y2="12" stroke="currentColor" strokeWidth="1.4" strokeLinecap="round" />
                            </svg>
                            <input class="text-[12.5px] p-1" placeholder="Search Worlds...">
                        </div>
                    </div>
                    <partial name="_LoginPartial" />
                </div>
            </div>
            
        </nav>
    </header>
    <!-- Drawer -->
    <div id="drawer"
         class="hidden fixed inset-0 z-[100] flex justify-start bg-black/30 opacity-0 transition-opacity duration-200"
         onclick="hideDrawer()">
        <aside id="drawerPanel"
               class="flex h-full w-[360px] max-w-[86vw] -translate-x-full flex-col overflow-y-auto bg-[#f4f1e8] text-[#2b2825] shadow-2xl transition-transform duration-300 ease-out"
               onclick="event.stopPropagation()">

            <!-- header -->
            <div class="flex items-center gap-3 px-5 pb-4 pt-5">
                <button type="button" onclick="hideDrawer()" aria-label="Close menu"
                        class="flex h-11 w-11 flex-none items-center justify-center rounded-full border-2 border-[#2b2825] transition-colors hover:bg-black/5">
                    <span class="material-symbols-outlined text-[22px]">close</span>
                </button>
                <span class="material-symbols-outlined text-[26px]">public</span>
                <span class="text-[26px] font-bold italic tracking-tight">World Builder</span>
            </div>

            <div class="mx-5 border-t border-[#d8d3c6]"></div>

            <!-- user -->
            <div class="flex items-center gap-4 px-5 py-4">
                <div class="flex h-12 w-12 flex-none items-center justify-center rounded-full bg-[#1c1a17] text-[22px] font-bold text-[#f4f1e8]">R</div>
                <div>
                    <div class="text-[19px] font-bold italic leading-tight">@@runeforge</div>
                    <div class="text-[14px] text-[#a39c8e]">3 worlds · 412 scripts</div>
                </div>
                <span class="material-symbols-outlined ml-auto text-[#8f887a]">expand_more</span>
            </div>

            <div class="mx-5 border-t border-dashed border-[#cbc4b3]"></div>

            <!-- browse -->
            <div class="px-6 pb-1.5 pt-5 text-[12px] italic uppercase tracking-[0.16em] text-[#b0a999]">Browse</div>
            <nav class="px-3">
                <a href="#" class="flex items-center gap-4 rounded-[11px] px-3 py-2.5 text-[19px] transition-colors hover:bg-black/5">
                    <span class="material-symbols-outlined text-[22px]">explore</span>
                    <span class="flex-1">Explore</span>
                </a>
                <a href="#" class="flex items-center gap-4 rounded-[11px] bg-[#e7e2d4] px-3 py-2.5 text-[19px]">
                    <span class="material-symbols-outlined text-[22px]">public</span>
                    <span class="flex-1 font-bold">All Worlds</span>
                    <span class="text-[15px] italic text-[#b0a999]">12,488</span>
                </a>
                <a href="#" class="flex items-center gap-4 rounded-[11px] px-3 py-2.5 text-[19px] transition-colors hover:bg-black/5">
                    <span class="material-symbols-outlined text-[22px]">groups</span>
                    <span class="flex-1">Community</span>
                </a>
            </nav>

            <!-- yours -->
            <div class="px-6 pb-1.5 pt-5 text-[12px] italic uppercase tracking-[0.16em] text-[#b0a999]">Yours</div>
            <nav class="px-3 pb-6">
                <a href="#" class="flex items-center gap-4 rounded-[11px] px-3 py-2.5 text-[19px] transition-colors hover:bg-black/5">
                    <span class="material-symbols-outlined text-[22px]">folder</span>
                    <span class="flex-1">My worlds</span>
                    <span class="text-[15px] italic text-[#b0a999]">3</span>
                </a>
                <a href="#" class="flex items-center gap-4 rounded-[11px] px-3 py-2.5 text-[19px] transition-colors hover:bg-black/5">
                    <span class="material-symbols-outlined text-[22px]">description</span>
                    <span class="flex-1">Drafts</span>
                    <span class="text-[15px] italic text-[#b0a999]">1</span>
                </a>
                <a href="#" class="flex items-center gap-4 rounded-[11px] px-3 py-2.5 text-[19px] transition-colors hover:bg-black/5">
                    <span class="material-symbols-outlined text-[22px]">favorite</span>
                    <span class="flex-1">Liked worlds</span>
                    <span class="text-[15px] italic text-[#b0a999]">42</span>
                </a>
                <a href="#" class="flex items-center gap-4 rounded-[11px] px-3 py-2.5 text-[19px] transition-colors hover:bg-black/5">
                    <span class="material-symbols-outlined text-[22px]">menu_book</span>
                    <span class="flex-1">Novels</span>
                    <span class="text-[15px] italic text-[#b0a999]">2</span>
                </a>
            </nav>

        </aside>
    </div>

    <main class="flex-1 w-full mx-auto">
        @RenderBody()
    </main>

    <footer class="border-t border-gray-200 bg-white">
        <div class="max-w-7xl mx-auto px-6 py-4 text-sm text-gray-400">
            &copy; 2026 - WorldBuilder -
            <a asp-area="" asp-controller="Home" asp-action="Privacy"
               class="hover:text-gray-600 transition-colors duration-150">Privacy</a>
        </div>
    </footer>
    <script src="../path/to/flowbite/dist/flowbite.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>