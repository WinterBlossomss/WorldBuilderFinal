<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorldBuilder</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorldBuilder.styles.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col bg-gray-50 text-gray-900">

    <header class="bg-white border-b border-gray-200">
        <nav class="sticky top-0 z-50 h-15 bg-wb-bg/90 backdrop-blur-md border-b border-white/[0.07] px-7 ">
            <div class="flex flex row pt-2">
                <div class="flex flex-row flex-auto items-center">
                    <div class=" flex items-center flex-row gap-2 mr-8 shrink-0">
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                            <circle cx="11" cy="11" r="9" stroke="#4f79f0" strokeWidth="1.8" />
                            <path d="M2 11Q11 4 20 11Q11 18 2 11Z" stroke="#4f79f0" strokeWidth="1.1" fill="none" />
                            <line x1="11" y1="2" x2="11" y2="20" stroke="#4f79f0" strokeWidth="1.1" />
                        </svg>
                        <a href="/" class="font-extrabold text-[20px] tracking-tight whitespace-nowrap">
                            World Builder
                        </a>
                    </div>
                    <ul class="flex flex-row gap-1 list-none m-0 p-0">
                        <li>
                            <a asp-controller="Home" asp-action="Index"
                               class="text-sm text-gray-500 hover:text-gray-900 hover:bg-gray-100 px-3 py-1.5 rounded-md transition-colors duration-150">
                                Home
                            </a>
                        </li>
                        <li>
                            <a asp-controller="World" asp-action="Index"
                               class="text-sm text-gray-500 hover:text-gray-900 hover:bg-gray-100 px-3 py-1.5 rounded-md transition-colors duration-150">
                                Worlds
                            </a>
                        </li>
                        <li>

                        </li>
                    </ul>
                </div>
                <div class="flex flex-row  justify-items-end">
                    <div class="flex items-center justify-items-end">
                        <div class="flex items-center gap-2 bg-wb-surf border border-white/[0.08] rounded-lg px-3 py-1.5 text-wb-muted">
                            <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                                <circle cx="5.5" cy="5.5" r="4" stroke="currentColor" strokeWidth="1.4" />
                                <line x1="8.5" y1="8.5" x2="12" y2="12" stroke="currentColor" strokeWidth="1.4" strokeLinecap="round" />
                            </svg>
                            <input class="text-[12.5px] p-1" placeholder="Search Worlds...">
                        </div>
                    </div>
                    <partial name="_LoginPartial" />
                </div>
            </div>
            
        </nav>
    </header>

    <main class="flex-1 max-w-7xl w-full mx-auto px-6 py-6">
        @RenderBody()
    </main>

    <footer class="border-t border-gray-200 bg-white">
        <div class="max-w-7xl mx-auto px-6 py-4 text-sm text-gray-400">
            &copy; 2026 - WorldBuilder -
            <a asp-area="" asp-controller="Home" asp-action="Privacy"
               class="hover:text-gray-600 transition-colors duration-150">Privacy</a>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>