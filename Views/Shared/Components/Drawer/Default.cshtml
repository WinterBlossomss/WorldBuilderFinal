@model WorldBuilder.ViewComponents.DrawerViewModel

@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject WorldBuilderDBContext Context
@inject UserManager<IdentityUser> UserManager

@{
    var userInfo = await Context.UserInfos
        .FirstOrDefaultAsync(x => x.UserInfoIDPK == Model.UserInfoId);

    var author = userInfo != null
        ? await UserManager.FindByIdAsync(userInfo.UserInfoUserIDFK)
        : null;
}

<aside id="drawerPanel"
       class="flex h-full w-96 max-w-[86vw] -translate-x-full flex-col overflow-y-auto bg-stone-200 text-stone-900 shadow-2xl transition-transform duration-300 ease-out"
       onclick="event.stopPropagation()">


    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-6">

        <a asp-controller="Home"
           asp-action="Index"
           class="font-serif font-semibold text-xl tracking-widest uppercase text-teal-900 no-underline">
            World Builder
        </a>

        <button type="button"
                onclick="hideDrawer()"
                aria-label="Close menu"
                class="flex h-8 w-8 items-center justify-center rounded-full transition-colors hover:bg-stone-300">

            <span class="material-symbols-outlined text-lg">
                close
            </span>

        </button>

    </div>


    <hr class="border-stone-300">


    <!-- User -->
    @if (Model.IsAuthenticated)
    {
        <a asp-controller="Author"
           asp-action="Index"
           asp-route-id="@Model.UserInfoId"
           class="flex items-center gap-4 px-6 py-5 text-stone-900 no-underline transition-colors hover:bg-stone-300/50">


            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-stone-900 text-lg font-bold text-stone-100">
                @Model.Initial
            </div>


            <div class="flex-1">

                <div class="font-serif text-lg italic font-semibold">
                    @@@author.UserName
                </div>

                <div class="mt-1 text-xs uppercase tracking-wider text-stone-600">
                    @Model.MyWorlds worlds · @Model.MyScripts scripts
                </div>

            </div>


            <span class="material-symbols-outlined text-stone-600">
                chevron_right
            </span>

        </a>
    }
    else
    {
        <div class="flex items-center gap-4 px-6 py-5">

            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-stone-900 text-lg font-bold text-stone-100">
                ?
            </div>

            <div>
                <div class="font-serif text-lg italic font-semibold">
                    Guest
                </div>

                <a asp-area="Identity"
                   asp-page="/Account/Login"
                   class="text-xs uppercase tracking-wider text-teal-900 underline">
                    Sign in to build
                </a>
            </div>

        </div>
    }


    <hr class="mx-6 border-dashed border-stone-300">


    <!-- Browse -->
    <div class="px-6 pt-6 pb-2 text-xs uppercase tracking-widest text-teal-900">
        Browse
    </div>


    <nav class="space-y-1 px-4">


        <a asp-controller="World"
           asp-action="Index"
           onclick="hideDrawer()"
           class="flex items-center gap-4 rounded-md px-3 py-3 text-stone-900 no-underline transition-colors hover:bg-stone-300/60">

            <span class="material-symbols-outlined">
                explore
            </span>

            <span class="flex-1 font-serif text-lg">
                Explore
            </span>

        </a>



        <a asp-controller="World"
           asp-action="Index"
           onclick="hideDrawer()"
           class="flex items-center gap-4 rounded-md bg-stone-300/60 px-3 py-3 text-stone-900 no-underline">

            <span class="material-symbols-outlined text-teal-900">
                public
            </span>


            <span class="flex-1 font-serif text-lg font-semibold">
                All Worlds
            </span>


            <span class="text-xs tracking-wide text-stone-600">
                @Model.TotalWorlds.ToString("N0")
            </span>

        </a>



        <a asp-controller="Author"
           asp-action="Browse"
           onclick="hideDrawer()"
           class="flex items-center gap-4 rounded-md px-3 py-3 text-stone-900 no-underline transition-colors hover:bg-stone-300/60">

            <span class="material-symbols-outlined">
                groups
            </span>

            <span class="flex-1 font-serif text-lg">
                Community
            </span>

        </a>



        @if (Model.IsAdmin)
        {
            <a asp-controller="Admin"
               asp-action="Index"
               onclick="hideDrawer()"
               class="flex items-center gap-4 rounded-md px-3 py-3 text-stone-900 no-underline transition-colors hover:bg-stone-300/60">


                <span class="material-symbols-outlined">
                    shield_person
                </span>


                <span class="flex-1 font-serif text-lg">
                    Admin
                </span>


            </a>
        }


    </nav>



    @if (Model.IsAuthenticated)
    {

        <div class="px-6 pt-6 pb-2 text-xs uppercase tracking-widest text-teal-900">
            Yours
        </div>


        <nav class="space-y-1 px-4">


            <a asp-controller="Author"
               asp-action="Index"
               asp-route-id="@Model.UserInfoId"
               onclick="hideDrawer()"
               class="flex items-center gap-4 rounded-md px-3 py-3 text-stone-900 no-underline transition-colors hover:bg-stone-300/60">


                <span class="material-symbols-outlined">
                    folder
                </span>


                <span class="flex-1 font-serif text-lg">
                    My Worlds
                </span>


                <span class="text-xs text-stone-600">
                    @Model.MyWorlds
                </span>


            </a>



            <a asp-controller="World"
               asp-action="Create"
               onclick="hideDrawer()"
               class="flex items-center gap-4 rounded-md px-3 py-3 text-stone-900 no-underline transition-colors hover:bg-stone-300/60">


                <span class="material-symbols-outlined">
                    add_circle
                </span>


                <span class="flex-1 font-serif text-lg">
                    New World
                </span>


            </a>



            <a asp-controller="World"
               asp-action="Liked"
               onclick="hideDrawer()"
               class="flex items-center gap-4 rounded-md px-3 py-3 text-stone-900 no-underline transition-colors hover:bg-stone-300/60">


                <span class="material-symbols-outlined">
                    favorite
                </span>


                <span class="flex-1 font-serif text-lg">
                    Liked Worlds
                </span>


                <span class="text-xs text-stone-600">
                    @Model.LikedWorlds
                </span>


            </a>


        </nav>



        <hr class="mx-6 my-4 border-dashed border-stone-300">



        <nav class="space-y-1 px-4 pb-5">


            <a asp-controller="Profile"
               asp-action="Edit"
               onclick="hideDrawer()"
               class="flex items-center gap-4 rounded-md px-3 py-3 text-stone-900 no-underline transition-colors hover:bg-stone-300/60">


                <span class="material-symbols-outlined">
                    settings
                </span>
                <span class="font-serif text-lg">
                    Settings
                </span>
            </a>
            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                  method="post">
                <button type="submit"
                        class="flex w-full items-center gap-4 rounded-md px-3 py-3 text-left text-red-900 transition-colors hover:bg-stone-300/60">
                    <span class="material-symbols-outlined">
                        logout
                    </span>
                    <span class="font-serif text-lg">
                        Sign out
                    </span>
                </button>
            </form>
        </nav>

    }
    else
    {

        <div class="mt-auto px-6 py-6">

            <a asp-area="Identity"
               asp-page="/Account/Login"
               class="block border border-stone-900 bg-stone-900 px-4 py-3 text-center text-sm text-stone-100 no-underline transition-colors hover:bg-teal-900 hover:border-teal-900">

                Sign in

            </a>

        </div>

    }


</aside>