@model List<WorldBuilder.Controllers.BuilderRow>
@{
    ViewData["Title"] = "Community";
}
<div class="bg-stone-200 text-stone-900 text-base leading-normal antialiased scroll-smooth">
    <!-- top bar -->
    <div class="flex items-center justify-between max-w-7xl mx-auto px-6 py-[22px]">
        <a asp-controller="Home" asp-action="Index"
           class="font-serif font-semibold text-[22px] tracking-[.14em] no-underline text-stone-900">
            @* WORLD BUILDER *@
        </a>
        <nav class="hidden sm:flex items-center gap-7 font-sans text-xs tracking-[.04em]">
            <a asp-controller="World" asp-action="Index"
               class="text-stone-600 hover:text-stone-900 transition-colors no-underline">
                Worlds
            </a>
            <div asp-controller="Community" asp-action="Index"
               class="text-teal-900 no-underline">
                Community
            </div>
        </nav>
    </div>
    <hr class="border-none border-t border-stone-300 max-w-7xl mx-auto">
    <!-- hero -->
    <header class="text-center px-6 pt-20 pb-16">
        <span class="font-sans text-xs tracking-[.22em] uppercase text-teal-900">
            The world registry community
        </span>
        <h1 class="font-serif font-semibold text-[clamp(48px,8vw,90px)] leading-[.95] tracking-[-.02em] mt-5 text-lg">
            The <span class="italic font-medium text-teal-900">builders.</span>
        </h1>
        <p class="text-[clamp(16px,2vw,19px)] text-stone-600 max-w-xl mx-auto mt-[22px] leading-[1.55]">
            Meet the creators behind the worlds on record.
            Explore authors, their creations, and the stories they bring to life.
        </p>
    </header>
    <!-- stats -->
    <div class="border-y border-stone-300 bg-stone-100/50">
        <div class="grid grid-cols-2 max-w-7xl mx-auto">
            <div class="text-center px-6 py-[34px] border-r border-stone-200">
                <div class="font-serif font-medium text-[44px] leading-none">
                    @Model.Count
                </div>
                <div class="font-sans text-xs tracking-[.16em] uppercase text-stone-600 mt-3">
                    Builders
                </div>
            </div>
            <div class="text-center px-6 py-[34px]">
                <div class="font-serif font-medium text-[44px] leading-none">
                    @Model.Sum(x => x.Worlds)
                </div>
                <div class="font-sans text-xs tracking-[.16em] uppercase text-stone-600 mt-3">
                    Worlds created
                </div>
            </div>
        </div>
    </div>
    <!-- builders -->
    <section class="py-16">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-5 mb-8">
                <div>
                    <span class="font-sans text-xs tracking-[.22em] uppercase text-teal-900">
                        Registry entries
                    </span>
                    <h2 class="font-serif font-medium text-[clamp(26px,3.4vw,38px)] tracking-[-.01em] leading-[1.05]">
                        Featured builders
                    </h2>
                </div>
                <span class="font-sans text-xs text-stone-600">
                    Sorted by published worlds
                </span>
            </div>
            @if (Model.Any())
            {
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-x-8">
                    @foreach (var b in Model)
                    {
                        var username = string.IsNullOrWhiteSpace(b.Username)
                            ? "builder"
                            : b.Username;
                        <a asp-controller="Author"
                           asp-action="Index"
                           asp-route-id="@b.UserInfoId"
                           class="group flex flex-col border-y border-stone-300 pt-5 pb-6 no-underline text-stone-900 transition-colors hover:border-teal-900 py-5">
                            <div class="flex items-center gap-4">
                                <!-- avatar -->
                                <div class="w-14 h-14 rounded-full border border-stone-400 flex items-center justify-center font-serif text-2xl">
                                    @username.Substring(0, 1).ToUpper()
                                </div>
                                <div class="min-w-0">
                                    <h3 class="font-serif font-semibold text-xl group-hover:text-teal-900 transition-colors">
                                        @@@username
                                    </h3>
                                    @if (!string.IsNullOrWhiteSpace(b.Bio))
                                    {
                                        <p class="text-sm text-stone-600 line-clamp-2 mt-1">
                                            @b.Bio
                                        </p>
                                    }
                                </div>
                            </div>
                            <div class="mt-5 pt-4 border-t border-stone-200 flex gap-8">
                                <div>
                                    <div class="font-serif text-2xl">
                                        @b.Worlds
                                    </div>
                                    <div class="font-sans text-xs uppercase tracking-[.14em] text-stone-600">
                                        Worlds
                                    </div>
                                </div>
                                <div>
                                    <div class="font-serif text-2xl">
                                        @b.Likes
                                    </div>
                                    <div class="font-sans text-xs uppercase tracking-[.14em] text-stone-600">
                                        Likes
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="border border-dashed border-stone-400 px-6 py-16 text-center">
                    <div class="font-serif text-2xl mb-1">
                        No builders registered yet
                    </div>
                    <div class="text-sm text-stone-600">
                        Create a world and become the first builder.
                    </div>
                </div>
            }
        </div>
    </section>
    <!-- footer CTA -->
    <div class="bg-teal-950 text-[#f0ebdf]">
        <div class="max-w-7xl mx-auto px-6 py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-9">
            <div>
                <h2 class="font-serif font-medium text-[clamp(28px,4vw,44px)] leading-[1.02]">
                    Ready to join the registry?
                </h2>
                <p class="text-[#c8c1af] mt-3.5 max-w-[460px] text-sm">
                    Start building a world and share your creations with the community.
                </p>


            </div>



            <div>

                <a asp-controller="World"
                   asp-action="Create"
                   class="inline-flex items-center gap-2 font-sans text-sm px-6 py-3 bg-stone-100 text-stone-900 no-underline hover:bg-stone-900 hover:text-white transition-colors">

                    Create a world →

                </a>

            </div>


        </div>


    </div>


</div>