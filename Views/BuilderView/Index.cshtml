@model WorldBuilder.Models.BuilderView
@Html.AntiForgeryToken()
@using WorldBuilder.Models
@{
    var status = Model.SelectedWorld.WorldIsPublic ? "public" : "private";
    var catSubCount = Model.SelectedWorld.Categories.Count > 0 ? Model.SelectedWorld.Categories.Sum(c => c.SubCategories.Count) : 0;
}
<div class="flex flex-col h-screen">
    <div class="grid grid-cols-3 items-center border-y gap-2">
        <div class="ms-3">
            <div class="flex flex-col">
                <h1 class="text-2xl pt-5 text-left truncate">
                    @Model.SelectedWorld.WorldName
                </h1>
            </div>
            <div class="pt-2 pb-5 indent-8">
                your world * @Model.WorldGenre.GenreName * @Model.TotalScripts scripts * @status
            </div>
        </div>
        <div class=" flex flex-row justify-center">
            <div class="inline-flex items-center gap-1 rounded-full border border-stone-800 bg-stone-50 p-1.5">
                <button data-view="board"
                        class="view-btn flex items-center gap-2 rounded-full px-4 py-1.5 text-sm transition-colors">
                    <span>⊹</span> Board
                </button>
                <button data-view="cards"
                        class="view-btn flex items-center gap-2 rounded-full px-4 py-1.5 text-sm transition-colors">
                    <span>▦</span> Cards
                </button>
                <button data-view="outline"
                        class="view-btn flex items-center gap-2 rounded-full px-4 py-1.5 text-sm transition-colors">
                    <span>☰</span> Outline
                </button>
            </div>
        </div>
        <div class="flex flex-row-reverse gap-2 me-3">
            <a class="bg-sky-500 text-white border rounded-xl p-3 cursor-pointer" onclick="showScriptModal()">
                + New Script
            </a>
            
            <button class="border border-sky-500 bg-white text-black border rounded-full p-3">
                Settings
            </button>
            <select class="border border-sky-500 bg-white text-black border rounded-full p-3">
                <option>Status</option>
                <option>Public</option>
                <option>Private</option>
            </select>
        </div>
    </div>
    <div class="flex flex-row flex-1 min-h-0 scrollbar-auto">
        <!-- sidebar -->
        <div class="border-r w-80 flex flex-col min-h-0 overflow-y-auto scroll-smooth gap-3">
            <div class="flex flex-row items-center justify-between mt-2 me-5">
                <h1 class="text-2xl indent-8 mt-3">
                    Scripts
                </h1>
                <button class="mt-1">
                    @Model.TotalScripts
                </button>
            </div>
            <div id="categoryList" class="p-5 mx-5 mt-2 border rounded-xl border-dashed overflow-y-auto max-h-64">
                @if (Model.TotalCategories == 0)
                {
                    <div class="text-center">
                        <p>no categories yet</p>
                        <p>Categories hold sub-categories and scripts - whatever scheme fits your world!</p>
                    </div>
                    <div class="flex justify-center mt-2">
                        <button onclick="showCategoryModal()" class="bg-black text-white rounded-full p-3 hover:bg-blue-500">
                            + New Category
                        </button>
                    </div>
                }
                else
                {
                    foreach (var cat in Model.SelectedWorld.Categories)
                    {
                        <div class="py-2">
                            <div class="flex flex-row items-center gap-2">
                                <button class="flex flex-row gap-2 items-center cursor-pointer" onclick="loadSubCategories(@cat.CatIDPK, 'subCatContainer-@cat.CatIDPK',this)">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:12px;height:12px;" class="chevron-down text-black flex-shrink-0 hidden">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                    </svg>
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:12px;height:12px;" class="chevron-right text-black flex-shrink-0">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                                    </svg>

                                    <div class="w-4 h-4 rounded-md border-2 border-dashed flex-shrink-0" style="background-color:@cat.CatColor"></div>
                                    <h2 class="text-md">@cat.CatName</h2>
                                </button>
                            </div>
                            <div id="subCatContainer-@cat.CatIDPK" class="hidden pl-5">
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="flex justify-center mt-2">
                <button onclick="showCategoryModal()" class="bg-black text-white rounded-full p-3 hover:bg-blue-500">
                    + New Category
                </button>
            </div>
            <div class="flex flex-row items-center justify-between mt-2 me-5">
                <h1 class="text-2xl indent-8">
                    Tags
                </h1>
                <button class="mt-1">
                    @Model.TotalTags
                </button>
            </div>
            <div class="p-5 mx-5 mt-2 border rounded-xl border-dashed items-center gap-3 flex flex-row flex-wrap">
                @if (Model.TotalTags == 0)
                {
                    <div class="text-center">
                        <p>no tags yet - tag scripts as you add them</p>
                    </div>
                    @* <div class="flex justify-center mt-2">
                        <button class="bg-black text-white rounded-full p-3 hover:bg-blue-500">
                            + New Tag
                        </button>
                    </div> *@
                }
                else
                {
                    @foreach(var tag in Model.Tags)
                    {
                        <div class="p-2 border rounded-xl" style="border-color:@tag.">
                            @tag.TagName
                        </div>
                    }
                }
            </div>
        </div>
        <div class="flex-1 min-h-0 overflow-y-auto">
            <div data-panel="board" class="view-panel">
                <partial name="_BoardView" model="Model" />
            </div>
            <div data-panel="cards" class="view-panel hidden">
                <partial name="_CardView" model="Model" />
            </div>
            <div data-panel="outline" class="view-panel hidden">
                <partial name="_OutlineView" model="Model" />
            </div>
        </div>
    </div>
</div>

<!-- Modals -->
<div id="catModal" class="hidden fixed left-0 top-0 bg-black/25 w-screen h-screen justify-center items-center">
    <!--Modal-->
    <div class="bg-white rounded-md shadow-md p-8 w-[40%] opacity-100 ">
        <div class="flex flex-row justify-between border-dashed border-b-1 items-center p-2">
            <h2 class="text-2xl">Create New Category</h2>
            <button onclick="hideCategoryModal()" class="text-gray-500 hover:text-gray-700 border rounded-full py-3 px-5">
                x
            </button>
        </div>
        <div class="text-xl text-semibold pb-1 pt-2">
            <div class="flex flex-row">
                <div class="text-xl text-semibold">
                    Name
                </div>
                <div class="text-red-500">
                    *
                </div>
            </div>
        </div>
        <input id="nameInput" class="border w-full py-1" />
        <div class="flex flex-row justify-between mt-3">
            <div class="flex flex-row">
                <div class="text-xl text-semibold">
                    Color
                </div>
                <div class="text-red-500">
                    *
                </div>
            </div>
            <div class="italic">
                categorises cards on the board
            </div>
        </div>
        <div class="p-5 border">
            <div id="colorContainer" class="items-center flex flex-wrap mb-3">

            </div>
            <div id="colorHex">
            </div>
        </div>
        
        <div class="my-3 p-3 border border-dashed flex flex-row justify-between items-center">
            <div class="flex flex-row items-center justify-center">
                <div>
                    preview:
                </div>
                <div id="colorPreview" class="items-center justify-center">

                </div>
                <div id="namePreview">
                    Name...
                </div>
            </div>
            <div>
                @Model.TotalScripts scripts
            </div>
        </div>
        <div>
            <div class="flex flex-row justify-between">
                <button class="border cursor-pointer text-black p-4 rounded-xl">
                    Cancel
                </button>
                <button onclick="saveCategory()" class="border cursor-pointer bg-black text-white p-4 rounded-xl">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>
<div id="subCatModal" class="hidden fixed left-0 top-0 bg-black/25 w-screen h-screen justify-center items-center">
    <!--Modal-->
    <div class="bg-white rounded-md shadow-md p-8 w-[40%] opacity-100 ">
        <div class="flex flex-row justify-between border-dashed border-b-1 items-center p-2">
            <h2 class="text-2xl">Create New Sub-Category</h2>
            <button onclick="hideSubCategoryModal()" class="text-gray-500 hover:text-gray-700 border rounded-full py-3 px-5">
                x
            </button>
        </div>
        <div class="text-xl text-semibold pb-1 pt-2">
            <div class="flex flex-row">
                <div class="text-xl text-semibold">
                    Name
                </div>
                <div class="text-red-500">
                    *
                </div>
            </div>
        </div>
        <input id="subNameInput" class="border w-full py-1 mb-2" />
        
        <div>
            <div class="flex flex-row justify-between">
                <button onclick="hideSubCategoryModal()" class="border cursor-pointer text-black p-4 rounded-xl">
                    Cancel
                </button>
                <button onclick="saveSubCategory()" class="border cursor-pointer bg-black text-white p-4 rounded-xl">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>
<div id="scriptModal" class="hidden fixed left-0 top-0 bg-black/25 w-screen h-screen justify-center items-center">
    <!--Modal-->
    <div class="bg-white rounded-md shadow-md p-4 w-[40%] opacity-100">
        <div class="flex flex-row justify-between border-dashed border-b-1 items-center p-1">
            <h2 class="text-2xl">Where does this Script live?</h2>
            <button onclick="hideScriptModal()" class="text-gray-500 hover:text-gray-700 border rounded-full py-3 px-5">
                x
            </button>
        </div>
        <div id="scriptModalContent" class="border m-2 grid grid-cols-2">
            <div class="border-r">
                <div class="text-xl font-semibold p-2 border-b border-dashed">
                    Category
                </div>
                <div id="scriptModalCatList" class="overflow-y-auto max-h-72">
                    @foreach (var cat in Model.SelectedWorld.Categories)
                    {
                        <div class="p-1.5">
                            <div class="flex flex-row items-center justify-between">
                                <button class="flex flex-row gap-1.5 items-center cursor-pointer" onclick="selectCategoryForScript(@cat.CatIDPK, '@cat.CatName')">
                                    <div class="w-3 h-3 rounded-sm border-2 border-dashed flex-shrink-0 p-3 rounded-xl" style="background-color:@cat.CatColor"></div>
                                    <h2 class="text-sm">@cat.CatName</h2>
                                </button>
                                <div class="text-xs text-gray-500" id="subCatCount-@cat.CatIDPK">
                                    @cat.SubCategoryCount
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="p-3 border-y-1 border-dashed">
                    <div class="flex flex-row items-center gap-2">
                        <button class="flex flex-row gap-2 items-center cursor-pointer" onclick="showCategoryModal()">
                            <h2 class="text-md italic">+ New category</h2>
                        </button>
                    </div>
                </div>
            </div>
            <div id="subCategoryDisplay" class="hidden">
                <div id="subCategoryName" class="text-xl font-semibold p-2 border-b border-dashed">
                    Sub-Category in
                </div>
                <div id="subCategoryContainer" class="overflow-y-auto max-h-72">
                </div>
            </div>
        </div>
        <div>
            <div class="flex flex-row justify-between p-1">
                <button class="border cursor-pointer text-black p-2 text-sm rounded-lg">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.builderConfig = {
            worldId: @Model.SelectedWorld.WorldIDPK,
            urls: {
                subCategories: "@Url.Action("Index", "SubCategorie")",
                scripts: "@Url.Action("Scripts", "SubCategorie")",
                createCategory: "@Url.Action("Create", "Categorie")",
                createSubCategory:"@Url.Action("Create","SubCategorie")",
                subFromCat: "@Url.Action("getSubFromCat", "BuilderView")",
                scriptCreateRedirect:"@Url.Action("Create","Script")",
                outlineData: "@Url.Action("OutlineData", "BuilderView")",
            }
        };
    </script>
    <script src="~/js/builder-tree.js" asp-append-version="true"></script>
    <script src="~/js/builder-modal.js" asp-append-version="true"></script>
    <script src="~/js/builder-views.js" asp-append-version="true"></script>
    <script src="~/js/outline.js" asp-append-version="true"></script>
}

