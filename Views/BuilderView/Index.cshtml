@model WorldBuilder.Models.BuilderView
@using WorldBuilder.Models
@{
    var status = Model.SelectedWorld.WorldIsPublic ? "public" : "private";
}
<div class="flex flex-col h-screen">
    <div class="grid grid-cols-3 items-center border-y gap-2">
        <div class="ms-3">
            <div class="flex flex-col">
                <h1 class="text-2xl pt-5 text-left truncate">
                    @Model.SelectedWorld.WorldName
                </h1>
            </div>
            <div class="pt-2 pb-5 indent-8">
                your world * @Model.WorldGenre.GenreName * @Model.TotalScripts scripts * @status
            </div>
        </div>
        <div class=" flex flex-row justify-center">
            <div class="inline-flex items-center gap-1 rounded-full border border-stone-800 bg-stone-50 p-1.5">
                <button data-view="board"
                        class="view-btn flex items-center gap-2 rounded-full px-4 py-1.5 text-sm transition-colors">
                    <span>⊹</span> Board
                </button>
                <button data-view="cards"
                        class="view-btn flex items-center gap-2 rounded-full px-4 py-1.5 text-sm transition-colors">
                    <span>▦</span> Cards
                </button>
                <button data-view="outline"
                        class="view-btn flex items-center gap-2 rounded-full px-4 py-1.5 text-sm transition-colors">
                    <span>☰</span> Outline
                </button>
            </div>
        </div>
        <div class="flex flex-row-reverse gap-2 me-3">
            <button class="bg-sky-500 text-white border rounded-xl p-3">
                + New Script
            </button>
            
            <button class="border border-sky-500 bg-white text-black border rounded-full p-3">
                Settings
            </button>
            <select class="border border-sky-500 bg-white text-black border rounded-full p-3">
                <option>Status</option>
                <option>Public</option>
                <option>Private</option>
            </select>
        </div>
    </div>
    <div class="flex flex-row flex-1 min-h-0">
        <div class="border-r w-80 flex flex-col scrollable scroll-smooth">
            <div class="flex flex-row items-center justify-between mt-2 me-5">
                <h1 class="text-2xl indent-8">
                    Scripts
                </h1>
                <button class="mt-1">
                    @Model.TotalScripts
                </button>
            </div>
            <div class="p-5 mx-5 mt-2 border rounded-xl border-dashed">
                @if(Model.TotalCategories == 0)
                {
                    <div class="text-center">
                        <p>no categories yet</p>
                        <p>Categories hold sub-categories and scripts - whatever scheme fits your world!</p>
                    </div>
                    <div class="flex justify-center mt-2">
                        <button onclick="showCategoryModal()" class="bg-black text-white rounded-full p-3 hover:bg-blue-500">
                            + New Category
                        </button>
                    </div>
                }
                else
                {
                    @* foreach (var cat in Model.SelectedWorld.Categories)
                    {
                        <div class="border rounded-md p-3 mb-2">
                            <div class="flex flex-row items-center gap-2">
                                <div class="w-4 h-4 rounded-full" style="background-color:@cat.CatColor"></div>
                                <h2 class="text-lg font-semibold">
                                    @cat.CatName
                                </h2>
                            </div>
                            <div class="ms-6 mt-1 text-sm text-gray-600">
                                @cat.ScriptCount scripts
                            </div>
                        </div>
                    } *@
                }
            </div>
            <div class="flex flex-row items-center justify-between mt-2 me-5">
                <h1 class="text-2xl indent-8">
                    Tags
                </h1>
                <button class="mt-1">
                    @Model.TotalTags
                </button>
            </div>
            <div class="p-5 mx-5 mt-2 border rounded-xl border-dashed">
                @if (Model.TotalTags == 0)
                {
                    <div class="text-center">
                        <p>no tags yet</p>
                        <p>Tags help organize your content - add some to get started!</p>
                    </div>
                    <div class="flex justify-center mt-2">
                        <button class="bg-black text-white rounded-full p-3 hover:bg-blue-500">
                            + New Tag
                        </button>
                    </div>
                }
            </div>
        </div>
        <div class="flex-1">
            <div data-panel="board" class="view-panel">
                <partial name="_BoardView" model="Model" />
            </div>
            <div data-panel="cards" class="view-panel hidden">
                <partial name="_CardView" model="Model" />
            </div>
            <div data-panel="outline" class="view-panel hidden">
                <partial name="_OutlineView" model="Model" />
            </div>
        </div>
    </div>
</div>
<!--Overlay-->
<div id="catModal" class="hidden fixed left-0 top-0 bg-black/25 w-screen h-screen justify-center items-center">
    <!--Modal-->
    <div class="bg-white rounded-md shadow-md p-8 w-[40%] opacity-100 ">
        <div class="flex flex-row justify-between border-dashed border-b-1 items-center p-2">
            <h2 class="text-2xl">Create New Category</h2>
            <button onclick="hideCategoryModal()" class="text-gray-500 hover:text-gray-700 border rounded-full py-3 px-5">
                x
            </button>
        </div>
        <div class="text-xl text-semibold pb-1 pt-2">
            <div class="flex flex-row">
                <div class="text-xl text-semibold">
                    Color
                </div>
                <div class="text-red-500">
                    *
                </div>
            </div>
        </div>
        <input id="nameInput" class="border w-full py-1" />
        <div class="flex flex-row justify-between mt-3">
            <div class="flex flex-row">
                <div class="text-xl text-semibold">
                    Color
                </div>
                <div class="text-red-500">
                    *
                </div>
            </div>
            <div class="italic">
                categorises cards on the board
            </div>
        </div>
        <div class="p-5 border">
            <div id="colorContainer" class="items-center flex flex-wrap mb-3">

            </div>
            <div id="colorHex">
            </div>
        </div>
        
        <div class="my-3 p-3 border border-dashed flex flex-row justify-between items-center">
            <div class="flex flex-row items-center justify-center">
                <div>
                    preview:
                </div>
                <div id="colorPreview" class="items-center justify-center">

                </div>
                <div id="namePreview">
                    Name...
                </div>
            </div>
            <div>
                @Model.TotalScripts scripts
            </div>
        </div>
        <div>
            <div class="flex flex-row justify-between">
                <button class="border cursor-pointer text-black p-4 rounded-xl">
                    Cancel
                </button>
                <button onclick="saveCategory()" class="border cursor-pointer bg-black text-white p-4 rounded-xl">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>





<script>

        function showCategoryModal() {
        let modal = document.getElementById('catModal');
        modal.style.display = 'flex';
    }

        function hideCategoryModal() {
        let modal = document.getElementById('catModal');
        modal.style.display = 'none';
    }

    let colors = ["#000000", "#FFFFFF", "#FF0000","#00FF00","#0000FF","#FFFF00","#008000","#800080","#800000","#000080","#C0C0C0"]
    let borders = colors.map(hex => {
        let r = parseInt(hex.slice(1,3), 16);
        let g = parseInt(hex.slice(3,5), 16);
        let b = parseInt(hex.slice(5,7), 16);

        r = Math.max(0, r - 40);
        g = Math.max(0, g - 40);
        b = Math.max(0, b - 40);

        return '#' + [r,g,b].map(v => v.toString(16).padStart(2,'0')).join('');
    });
    function darken(hex, amount) {
        let r = Math.max(0, parseInt(hex.slice(1,3), 16) - amount);
        let g = Math.max(0, parseInt(hex.slice(3,5), 16) - amount);
        let b = Math.max(0, parseInt(hex.slice(5,7), 16) - amount);
        return '#' + [r,g,b].map(v => v.toString(16).padStart(2,'0')).join('');
    }

    const container = document.getElementById("colorContainer");
    const colorHex = document.getElementById("colorHex");

    colors.forEach((color, i) => {
        const colorDiv = document.createElement("button");
        colorDiv.style.backgroundColor = color;
        colorDiv.style.borderColor = borders[i];
        colorDiv.className = "w-8 h-8 p-5 inline-block m-1 border-2 rounded-xl border-dashed cursor-pointer focus:";
        colorDiv.addEventListener('mouseenter', () => colorDiv.style.opacity = '0.75');
        colorDiv.addEventListener('mouseleave', () => colorDiv.style.opacity = '1');

        const darkBorder = darken(borders[i], 60);

        colorDiv.addEventListener('focus', () => {
        colorDiv.style.backgroundColor = borders[i];
        colorDiv.style.borderColor = darkBorder;
        colorPreview.style.backgroundColor = color;
        colorHex.textContent = color;
        colorHex.className = "inline-block p-1 border rounded-full";
    });
    colorDiv.addEventListener('blur', () => {
        colorDiv.style.backgroundColor = color;
        colorDiv.style.borderColor = borders[i];
    });
            container.appendChild(colorDiv);
    });

    const colorPickerLabel = document.createElement("label");
    colorPickerLabel.className = "inline-flex items-center justify-center m-1 border-2 border-dashed cursor-pointer text-center rounded-xl";
    colorPickerLabel.style.width = "3rem";
    colorPickerLabel.style.height = "3rem";
    colorPickerLabel.style.borderColor = "#000000";
    colorPickerLabel.textContent = "+";
    colorPickerLabel.style.backgroundImage = "url('/images/rainbow_gradient.jpg')";
    colorPickerLabel.style.backgroundSize = "cover";
    colorPickerLabel.style.backgroundPosition = "center";

    const colorPickerInput = document.createElement("input");
    colorPickerInput.type = "color";
    colorPickerInput.style.position = "absolute";
    colorPickerInput.style.width = "0";
    colorPickerInput.style.height = "0";
    colorPickerInput.style.opacity = "0";
    colorPickerInput.style.pointerEvents = "none";
    

    colorPickerLabel.appendChild(colorPickerInput);
    container.appendChild(colorPickerLabel);

    const buttons = document.querySelectorAll('.view-btn');
    const panels  = document.querySelectorAll('.view-panel');

    //preview

    const preview = document.getElementById('colorPreview');
    const colorPreview = document.createElement('div');
    colorPreview.className = 'w-8 h-8 mt-2 ms-2 me-2 inline-block border border-dashed rounded-md';
    preview.appendChild(colorPreview);

    colorPickerInput.addEventListener('input', () => {
        colorPreview.style.backgroundColor = colorPickerInput.value;
        colorHex.textContent = colorPickerInput.value;
        colorHex.className = "inline-block p-1 border rounded-full";
    });


    // classes for active vs inactive state
    const active   = ['bg-stone-900', 'text-stone-50', 'font-semibold', 'not-italic','bg-sky-500'];
    const inactive = ['text-stone-800', 'hover:bg-stone-200'];

    function select(view) {
      buttons.forEach(btn => {
        const isActive = btn.dataset.view === view;
        btn.classList.toggle('bg-stone-900', isActive);
        btn.classList.toggle('text-stone-50', isActive);
        btn.classList.toggle('font-semibold', isActive);
        btn.classList.toggle('not-italic', isActive);
        btn.classList.toggle('bg-sky-500', isActive);
        btn.classList.toggle('bg-stone-50', !isActive);
        btn.classList.toggle('text-white', isActive);
        btn.classList.toggle('text-stone-800', !isActive);
        btn.classList.toggle('hover:bg-stone-200', !isActive);
      });
      panels.forEach(p => p.classList.toggle('hidden', p.dataset.panel !== view));
    }

    const nameInput = document.getElementById('nameInput');
    const namePreview = document.getElementById('namePreview');

    nameInput.addEventListener('input', (e) => {
        const value = e.target.value.trim();
        namePreview.textContent = value ? value : "Name...";
    });

    //const saveBtn = document.getElementById('saveBtn');
    const worldId = @Model.SelectedWorld.WorldIDPK;  

    function saveCategory(){
        const name = nameInput.value.trim();
        const color = colorHex.textContent.trim();
        //console.log("here");
        // if (!name) {
        //     alert("Please enter a name for the category.");
        //     return;
        // }
        // if (!color) {
        //     alert("Please pick a color.");
        //     return;
        // }

        $.ajax({
            url: "@Url.Action("Create", "Category")",
            data: { worldId: worldId, name: name, color: color }
        }).done(function (res) {
            document.getElementById('categoryList').insertAdjacentHTML('beforeend', res);
            hideCategoryModal();
            nameInput.value = "";
            namePreview.textContent = "Name...";
            hideCategoryModal();
        }).fail(function (xhr) {
            alert("Could not save category: " + xhr.statusText);
        });
    }
    saveBtn.addEventListener('click', () => {
        
    });

    buttons.forEach(btn => btn.addEventListener('click', () => select(btn.dataset.view)));

    // start on Board
    select('board');
</script>