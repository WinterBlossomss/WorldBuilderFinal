@model WorldBuilder.Models.BuilderView

<div class="px-8 py-8 overflow-y-auto" id="outlinePanel" data-world="@Model.SelectedWorld.WorldIDPK">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end gap-4 mb-2">
        <div>
            <span class="font-sans text-[11px] tracking-[.22em] uppercase text-teal-900">The Registry</span>
            <h1 class="font-serif font-semibold text-4xl tracking-tight leading-none mt-1">Outline</h1>
        </div>
        <div class="flex flex-row flex-wrap gap-2 items-center">
            <input id="outlineFilter" placeholder="filter scripts, tags…"
                   class="border border-stone-300 bg-stone-100 px-4 py-2 text-sm w-64 font-sans placeholder:text-stone-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#a3712a] focus-visible:outline-offset-2">
            <button id="outlineExpandAll" class="border border-stone-300 px-4 py-2 text-sm font-sans text-stone-600 hover:bg-stone-100 transition-colors">Expand all</button>
            <button id="outlineCollapseAll" class="border border-stone-300 px-4 py-2 text-sm font-sans text-stone-600 hover:bg-stone-100 transition-colors">Collapse all</button>
            <button id="outlineSort" class="border border-stone-300 px-4 py-2 text-sm font-sans text-stone-600 hover:bg-stone-100 transition-colors" data-dir="asc">Sort: A → Z</button>
        </div>
    </div>
    <div id="outlineMeta" class="font-sans text-xs tracking-[.06em] text-stone-500 mb-5">loading…</div>
    <div id="outlineTree" class="border border-stone-300 bg-stone-100 overflow-hidden"></div>
    <div id="outlineNoResults" class="hidden text-center text-stone-400 font-serif italic py-10"></div>
</div>
