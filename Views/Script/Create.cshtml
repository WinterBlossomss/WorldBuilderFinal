@model WorldBuilder.Models.BuilderView

@{
    var subName = ViewData["SubName"] as string;
    var catName = ViewData["CatName"] as string;
    var scriptId = Model.NewScript?.ScriptIDPK ?? 0;
    var isEdit = scriptId > 0;
}

@* @if (!string.IsNullOrEmpty(subName))
{
    <p>Living under sub-category: @subName</p>
}
else
{
    <p>Living directly under category: @catName</p>
}
 *@
<div class="flex flex-row">
    <div class="grid grid-cols-3 items-center border-y gap-2">
        <div class="ms-3">
            <a class="flex flex-col" asp-action="Index" asp-controller="BuilderView" asp-route-id="@Model.SelectedWorld.WorldIDPK">
                <h1 class="text-2xl pt-5 text-left truncate">
                    @Model.SelectedWorld.WorldName
                </h1>
            </a>
        </div>
    </div>  
    
    
</div>
<div class="flex flex-col  m-5">
    <div class="flex flex-row justify-between">
        <nav class="flex my-3" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
                <li class="inline-flex items-center truncate">
                    <a asp-action="Index" asp-controller="BuilderView" asp-route-id="@Model.SelectedWorld.WorldIDPK" class="inline-flex items-center text-sm font-medium text-body hover:text-fg-brand">
                        <svg class="w-4 h-4 me-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m4 12 8-8 8 8M6 10.5V19a1 1 0 0 0 1 1h3v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3h3a1 1 0 0 0 1-1v-8.5" /></svg>
                        <span class="inline-flex items-center text-sm font-medium text-body-subtle">@Model.SelectedWorld.WorldName</span>
                    </a>
                </li>
                @if (catName != null)
                {
                    <li>
                        <div class="flex items-center space-x-1.5">
                            <svg class="w-3.5 h-3.5 rtl:rotate-180 text-body" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7" /></svg>
                            <a class="inline-flex items-center text-sm font-medium text-body hover:text-fg-brand">@catName</a>
                        </div>
                    </li>
                }
                @if (subName != null)
                {
                    <li>
                        <div class="flex items-center space-x-1.5">
                            <svg class="w-3.5 h-3.5 rtl:rotate-180 text-body" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7" /></svg>
                            <a class="inline-flex items-center text-sm font-medium text-body hover:text-fg-brand">@subName</a>
                        </div>
                    </li>
                }
                <li aria-current="page">
                    <div class="flex items-center space-x-1.5">
                        <svg class="w-3.5 h-3.5 rtl:rotate-180 text-body" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7" /></svg>
                        <span class="inline-flex items-center text-sm font-medium text-body-subtle">Script name...</span>
                    </div>
                </li>
            </ol>
        </nav>
        <div>
            <div>
            </div>
        </div>
    </div>
    
    <form id="scriptForm" method="post"
          asp-controller="Script"
          asp-action="@(isEdit ? "Edit" : "Create")"
          asp-route-scriptidpk="@scriptId">
        @Html.AntiForgeryToken()
        <input name="ScriptTitle" value="@Model.NewScript?.ScriptTitle"
               class="text-5xl border-b border-dashed w-full" placeholder="Name this script...">
        <input type="hidden" id="ScriptContentField" name="ScriptContent" />
        <input type="hidden" name="ScriptCatFK" value="@Model.NewScript?.ScriptCatFK" />
        <input type="hidden" name="ScriptSubFK" value="@Model.NewScript?.ScriptSubFK" />
    </form>
    <div class="flex flex-row my-2 items-center">
        <div class="me-5">
            tags:
        </div>
        <div id="tagContainer" class="flex flex-row gap-3 items-center">
            <div id="noTagsLabel" class="indent-2 text-base italic">none yet -</div>
            <button onclick="showTagModal()" class="py-1 px-2 border border-dashed rounded-full text-black cursor-pointer text-base">
                + tag
            </button>
        </div>
    </div>
    <div class="w-full">
        <div id="mainContainer" class="flex flex-col w-full">
            <div id="editorContainer" class="w-full">
                <div id="toolbar" class="editor-toolbar">
                    <span class="ql-formats">
                        <button class="ql-header" value="1">H1</button>
                        <button class="ql-header" value="2">H2</button>
                        <button class="ql-header" value="3">H3</button>
                    </span>

                    <span class="ql-formats">
                        <button class="ql-bold"></button>
                        <button class="ql-italic"></button>
                        <button class="ql-underline"></button>
                        <button class="ql-strike"></button>
                    </span>

                    <span class="ql-formats">
                        <button class="ql-list" value="bullet"></button>
                        <button class="ql-list" value="ordered"></button>

                        <button class="ql-blockquote"></button>
                    </span>

                    <span class="ql-formats">
                        <button class="ql-link"></button>
                        <button class="ql-image"></button>
                    </span>

                    <span class="ql-formats">
                        <button class="ql-script" value="sub"></button>
                        <button class="ql-script" value="super"></button>
                    </span>

                    <span class="ql-formats">
                        <button class="ql-link"></button>
                        <button class="ql-image"></button>

                        <button id="characterLinkButton" type="button">
                            🧙
                        </button>
                    </span>

                </div>

                <div id="editor" class="w-full"></div>
            </div>
        @* <div>
             Quick starts
        </div> *@
            
        </div>
    
    </div>
    <div class="p-5 m-5">

    </div>
    <div id="picturePanel" class="border border-dashed rounded-xl p-5 mt-5">
        <div class="flex flex-row justify-between items-start">
            <div>
                <div class="text-2xl font-semibold">Pictures</div>
                <div id="pictureSubtitle" class="text-sm text-gray-500"></div>
            </div>
            <label class="border font-bold rounded-full px-4 py-2 cursor-pointer whitespace-nowrap">
                + Add picture
                <input id="pictureBrowse" type="file" accept="image/*" multiple class="hidden">
            </label>
        </div>

        <div id="pictureGrid" class="grid grid-cols-6 gap-4 mt-4">
            <!-- cards + dropzone injected by JS -->
            <div id="pictureDrop"
                 class="border-2 border-dashed rounded-xl flex flex-col items-center justify-center text-gray-400 cursor-pointer text-center gap-1"
                 style="aspect-ratio:3/2;">
                <div class="text-2xl text-black">+</div>
                <div>drop a picture</div>
                <div>or <span class="underline">browse</span></div>
            </div>
        </div>
    </div>

    <div id="relatedScripts" class="border border-dashed rounded-xl p-5 mt-5">
        <div class="flex flex-row justify-between items-start">
            <div>
                <div class="text-2xl font-semibold">Related scripts</div>
                <div class="text-sm text-gray-500" id="relSubtitle"></div>
            </div>
            <div class="text-sm text-gray-400 italic">relations are bidirectional — adding here updates the other script too</div>
        </div>

        @if (!isEdit)
        {
            <div class="text-gray-400 italic text-center py-10">
                Save this script first to link it to other scripts.
            </div>
        }
        else
        {
            <div id="relList" class="flex flex-col gap-2 mt-4"></div>

            <div class="border border-dashed rounded-lg p-4 mt-4">
                <div class="font-bold uppercase text-xs text-gray-500 mb-3">+ Link a new script</div>
                <div class="flex flex-row items-center gap-3">
                    <span class="text-sm text-gray-500 whitespace-nowrap">Connected to →</span>
                    <div class="relative flex-grow">
                        <input id="relSearchInput" autocomplete="off" placeholder="search a script to connect..."
                               class="border rounded-lg px-3 py-2 w-full">
                        <div id="relSearchResults"
                             class="absolute left-0 right-0 bg-white border rounded-lg mt-1 hidden z-10 max-h-48 overflow-y-auto"></div>
                    </div>
                </div>
                <div class="flex flex-row items-center gap-2 flex-wrap mt-3">
                    <span class="text-sm text-gray-500">HOW:</span>
                    <div id="relTypePills" class="flex flex-row flex-wrap gap-2"></div>
                </div>
                <div class="flex justify-end mt-3">
                    <button type="button" id="relAddBtn" class="bg-black text-white px-5 py-2 rounded-lg cursor-pointer">+ Add link</button>
                </div>
            </div>
        }
    </div>
</div>
<div id="detailContainer">
</div>
<div class="flex justify-end mt-6">
    <button id="saveScriptBtn" type="button"
            class="bg-black text-white px-6 py-3 rounded-xl cursor-pointer">
        Save script
    </button>
</div>

<!-- Tag Modal -->
<div id="tagModal" class="hidden fixed left-0 top-0 bg-black/25 w-screen h-screen justify-center items-center">
    <!--Modal-->
    <div class="bg-white rounded-md shadow-md p-8 w-[40%] opacity-100 ">
        <div class="flex flex-row justify-between border-dashed border-b-1 items-center p-2">
            <h2 class="text-2xl">Add tags</h2>
            <button onclick="hideTagModal()" class="text-gray-500 hover:text-gray-700 border rounded-full py-3 px-5">
                x
            </button>
        </div>
        <div class="my-2 flex flex-row">
            <div>
                Tags cross-reference scripts across <a class="italics bold">@Model.SelectedWorld.WorldName.</a>Pick any number.
            </div>
        </div>
        <div class="flex flex-row border justify-between">
            <div class="flex flex-row p-2 items-center w-full" ">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:20px;height:20px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                </svg>
                <input id="tagSearchInput" class="py-2 ms-2 w-full">
            </div>
            <div id="tagMatchCount">

            </div>
        </div>
        <div class="flex flex-row border border-dashed p-3 mt-3 items-center gap-3">
            <div>
                selected:
            </div>
            <div id="tagSelectedContainer" class="flex flex-row gap-3 flex-wrap">

            </div>
        </div>
        <div class="font-bold mt-2">
            MATCHING TAGS
        </div>
        <div id="tagMatchContainer" class="flex flex-row gap-3 border-b border-dashed py-3">
        </div>
        <div class="uppercase mt-3 font-bold">
            Don't see one? Create a new tag
        </div>
        <div class="flex flex-row">
            <div class="border rounded-2 flex flex-row">
                <div>
                    <div id="tagColorPreview" class="w-8 h-8 mt-2 ms-2 me-2 inline-block border border-dashed rounded-full">
                    </div>
                </div>
                <input id="tagNameInput" placeholder="e.g. retainer" class="border p-2 w-full" />
            </div>
            <button class="p-3 bg-black text-white cursor-pointer" onclick="createTag()">
                + Create
            </button>
        </div>
        <div class="flex flex-row items-center my-5">
            <div class="pe-5">
                color
            </div>
            <div id="tagColorContainer">

            </div>
        </div>
        <div class="flex flex-row items-center p-3 border border-dashed rounded-md gap-3">
            <div class="flex flex-col">
                <div>
                    Available in all my worlds
                </div>
                <div>
                    off - this tag lives only in @Model.SelectedWorld.WorldName
                </div>
                <div>
                    on - reuse it across every world you own
                </div>
            </div>
            <div id="tagSwitch">
                <input type="checkbox" id="tagAllWorlds" />
            </div>
        </div>
        

        <div class="mt-5 border-t border-dashed">
            <div class="flex flex-row justify-between mt-4">
                <div>
                    click a tag to add - click again to remove
                </div>
                <div class="flex flex-row">
                    <button onclick="hideTagModal()" class="border cursor-pointer text-black p-4 rounded-xl">
                        Cancel
                    </button>
                    <button onclick="saveTag()" class="border cursor-pointer bg-black text-white p-4 rounded-xl">
                        Done 
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
    window.builderConfig = {
        worldId: @Model.SelectedWorld.WorldIDPK,
        scriptId: @scriptId,
        urls: {
            list:       "@Url.Action("List", "Tag")",
            create:     "@Url.Action("CreateAjax", "Tag")",
            picUpload:  "@Url.Action("UploadAjax", "Picture")",
            picCaption: "@Url.Action("UpdateCaptionAjax", "Picture")",
            picDelete:  "@Url.Action("DeleteAjax", "Picture")",
            relForScript:  "@Url.Action("ForScript", "Relation")",
            relSearch:     "@Url.Action("SearchScripts", "Relation")",
            relLink:       "@Url.Action("LinkAjax", "Relation")",
            relUnlink:     "@Url.Action("UnlinkAjax", "Relation")",
            relTypes:      "@Url.Action("TypesAjax", "Connection")",
            relCreateType: "@Url.Action("CreateTypeAjax", "Connection")"
        }
    };
</script>
<script src="~/js/script-create.js" asp-append-version="true"></script>
<script src="~/js/picture-create.js" asp-append-version="true"></script>
<script src="~/js/relation-create.js" asp-append-version="true"></script>
<script>
        document.getElementById('saveScriptBtn').addEventListener('click', async () => {
        const btn  = document.getElementById('saveScriptBtn');
        const form = document.getElementById('scriptForm');
        btn.disabled = true;

        const cf = document.getElementById('ScriptContentField');
        if (!window.quill) { alert("Editor not ready — Quill failed to load."); btn.disabled = false; return; }
        cf.value = window.quill.getSemanticHTML(0);
        console.log("saving content length:", cf.value.length);   // temporary sanity check

        // tags
        if (window.syncTagInputs) window.syncTagInputs();

        // pictures
        if (window.uploadPictures) {
        const ids = await window.uploadPictures();
        if (ids === null) { btn.disabled = false; return; }
        form.querySelectorAll('input[name="pictureIds"]').forEach(n => n.remove());
        ids.forEach(id => {
        const h = document.createElement('input');
        h.type = 'hidden'; h.name = 'pictureIds'; h.value = id; form.appendChild(h);
        });
        }

        form.submit();
        });

        document.getElementById('ScriptContentField').closest('form')?.id   // should print "scriptForm"
</script>
}

