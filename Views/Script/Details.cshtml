@model WorldBuilder.Models.Script
@using WorldBuilder.Models

@{
    ViewData["Title"] = Model?.ScriptTitle ?? "Script";

    var s      = Model;
    var world  = ViewData["World"] as World;
    var author = ViewData["AuthorHandle"] as string;
    var catId  = ViewData["CatId"] as int?;
    var catName = ViewData["CatName"] as string;
    var subName = ViewData["SubName"] as string;

    var tags     = s?.ScriptTagTagFKs?.ToList()  ?? new List<Tag>();
    var pictures = s?.PicScriptPicFKs?.ToList()   ?? new List<Picture>();

    var infoEnabled  = ViewData["InfoEnabled"] as bool? ?? false;
    var infoTitle    = ViewData["InfoTitle"] as string;
    var portraitPath = ViewData["PortraitPath"] as string;
    var infoRows     = ViewData["InfoRows"] as List<WorldBuilder.Models.Attribute> ?? new List<WorldBuilder.Models.Attribute>();

    var linkGroups   = ViewData["LinkGroups"] as Dictionary<string, List<Script>> ?? new Dictionary<string, List<Script>>();
    var linkCatNames = ViewData["LinkCatNames"] as Dictionary<int, string> ?? new Dictionary<int, string>();
    var linkTotal    = linkGroups.Values.Sum(v => v.Count);

    var lastTouch = s?.ScriptUpdateAt ?? s?.ScriptCreateAt ?? DateTime.Today;

    // Resolve both storage conventions: "/uploads/…" (new) and "Images/…" (legacy)
    Func<string, string> Pic = p =>
        string.IsNullOrEmpty(p) ? null
        : (p.StartsWith("/") || p.StartsWith("http")) ? p : Url.Content("~/" + p);

    string Ago(DateTime d)
    {
        var days = (int)(DateTime.Today - d.Date).TotalDays;
        if (days <= 0) return "today";
        if (days == 1) return "yesterday";
        if (days < 7) return days + "d ago";
        if (days < 30) return (days / 7) + "w ago";
        if (days < 365) return (days / 30) + "mo ago";
        return (days / 365) + "y ago";
    }
}

<style>
    /* Typography for the Quill-authored body (matches the hand-drawn house style) */
    .reader-body h1, .reader-body h2 {
        font-family: 'Caveat', cursive; font-weight: 700; line-height: 1.1; margin: 1.4rem 0 .6rem;
    }
    .reader-body h1 { font-size: 34px; }
    .reader-body h2 { font-size: 28px; }
    .reader-body h3 { font-size: 20px; font-weight: 700; margin: 1.1rem 0 .4rem; }
    .reader-body p  { margin: 0 0 .9rem; }
    .reader-body ul, .reader-body ol { margin: 0 0 .9rem 1.25rem; }
    .reader-body ul { list-style: disc; }
    .reader-body ol { list-style: decimal; }
    .reader-body li { margin: .2rem 0; }
    .reader-body a  { text-decoration: underline; text-underline-offset: 2px; }
    .reader-body blockquote {
        border-left: 3px solid #1a1a1a; padding: .2rem 0 .2rem 1rem; margin: 1.1rem 0;
        font-style: italic; color: #444;
    }
    .reader-body strong { font-weight: 700; }
    .reader-body em { font-style: italic; }
</style>

<div class="m-5">
    <div class="font-['Kalam'] text-[#1a1a1a] -mx-4 -my-3 px-[30px] pt-5 pb-16">

        <!-- Top bar: breadcrumb + updated + actions -->
        <div class="flex items-start justify-between gap-4 mb-5">
            <div class="text-[11px] tracking-wide text-[#a89f8e] uppercase">
                @if (world != null)
                {
                    <a asp-controller="World" asp-action="Read" asp-route-id="@world.WorldIDPK"
                       class="no-underline text-[#a89f8e] hover:text-[#1a1a1a]">@world.WorldName</a>
                    <span class="mx-1">·</span>
                }
                @if (catId != null)
                {
                    <a asp-controller="World" asp-action="Category" asp-route-id="@world?.WorldIDPK" asp-route-catId="@catId"
                       class="no-underline text-[#a89f8e] hover:text-[#1a1a1a]">@catName</a>
                }
                @if (!string.IsNullOrEmpty(subName))
                {
                    <span class="mx-1">·</span>@subName
                }
            </div>

            <div class="flex items-center gap-2 shrink-0">
                <span class="text-[12px] text-[#a89f8e] hidden sm:inline">
                    updated @Ago(lastTouch)@(author != null ? " by @" + author : "")
                </span>
                <button type="button"
                        class="inline-flex items-center gap-1.5 border-[1.5px] border-[#1a1a1a] px-3 py-1.5 rounded-md text-[13px] font-bold cursor-pointer hover:bg-[#1a1a1a] hover:text-[#f7f3ea] transition-colors">
                    <svg width="12" height="11" viewBox="0 0 24 22" fill="none"><path d="M12 20 C 4 14, 2 9, 5 5 C 8 1, 12 5, 12 8 C 12 5, 16 1, 19 5 C 22 9, 20 14, 12 20 Z" stroke="currentColor" stroke-width="1.8" fill="none" /></svg>
                    Save
                </button>
                <button type="button" title="Share"
                        class="inline-flex items-center justify-center w-9 h-9 border-[1.5px] border-[#1a1a1a] rounded-md cursor-pointer hover:bg-[#1a1a1a] hover:text-[#f7f3ea] transition-colors">
                    <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="4" cy="8" r="2" stroke="currentColor" stroke-width="1.4" /><circle cx="12" cy="3.5" r="2" stroke="currentColor" stroke-width="1.4" /><circle cx="12" cy="12.5" r="2" stroke="currentColor" stroke-width="1.4" /><line x1="5.7" y1="7" x2="10.3" y2="4.4" stroke="currentColor" stroke-width="1.2" /><line x1="5.7" y1="9" x2="10.3" y2="11.6" stroke="currentColor" stroke-width="1.2" /></svg>
                </button>
            </div>
        </div>

        <!-- Title -->
        <h1 class="font-['Caveat'] text-[52px] font-bold leading-none mb-2">@s?.ScriptTitle</h1>

        <!-- Tags -->
        @if (tags.Any())
        {
            <div class="flex flex-wrap items-center gap-2 mb-6">
                <span class="text-[12px] text-[#a89f8e]">tags:</span>
                @foreach (var tag in tags)
                {
                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[11.5px] border border-[#1a1a1a]">
                        <span class="w-2 h-2 rounded-full" style="background-color:@tag.TagColor"></span>
                        @tag.TagName
                    </span>
                }
            </div>
        }

        <!-- Body + sidebar -->
        <div class="grid grid-cols-1 lg:grid-cols-[1.6fr_1fr] gap-10">

            <!-- LEFT: readable body -->
            <div>
                <div class="reader-body text-[15px] leading-relaxed text-[#1a1a1a]">
                    @if (!string.IsNullOrWhiteSpace(s?.ScriptContent))
                    {
                        @Html.Raw(s.ScriptContent)
                    }
                    else
                    {
                        <p class="text-[#a89f8e] italic">Nothing has been written for this entry yet.</p>
                    }
                </div>

                <!-- Pictures -->
                @if (pictures.Any())
                {
                    <section class="border-[1.5px] border-[#1a1a1a] rounded-md p-5 mt-10">
                        <div class="flex items-baseline justify-between mb-1">
                            <h2 class="font-['Caveat'] text-[26px] font-bold">Pictures</h2>
                            <span class="text-[12px] text-[#a89f8e]">@pictures.Count picture@(pictures.Count == 1 ? "" : "s")</span>
                        </div>
                        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 mt-3">
                            @foreach (var p in pictures)
                            {
                                <figure class="m-0 @(string.IsNullOrEmpty(p.PicPath) ? "" : "js-lightbox cursor-zoom-in")"
                                        data-gallery="script-@s.ScriptIDPK"
                                        data-full="@Pic(p.PicPath)"
                                        data-caption="@p.PicCaption"
                                        data-title="@(string.IsNullOrEmpty(p.PicCaption) ? s?.ScriptTitle : p.PicCaption)"
                                        data-crumb="@world?.WorldName@(string.IsNullOrEmpty(catName) ? "" : " › " + catName)@(string.IsNullOrEmpty(subName) ? "" : " › " + subName)"
                                        data-meta="From @s?.ScriptTitle@(string.IsNullOrEmpty(author) ? "" : " · by @" + author)"
                                        data-back="@Url.Action("Details", "Script", new { scriptidpk = s?.ScriptIDPK })">
                                    <div class="aspect-square border-[1.5px] border-dashed border-[#1a1a1a] bg-[repeating-linear-gradient(135deg,transparent_0_10px,rgba(26,26,26,0.08)_10px_11px)] overflow-hidden flex items-center justify-center">
                                        @if (!string.IsNullOrEmpty(p.PicPath))
                                        {
                                            <img src="@Pic(p.PicPath)" alt="@p.PicCaption" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <span class="text-[11px] text-[#a89f8e]">picture</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(p.PicCaption))
                                    {
                                        <figcaption class="text-[11.5px] text-[#444444] mt-1 leading-snug">@p.PicCaption</figcaption>
                                    }
                                </figure>
                            }
                        </div>
                    </section>
                }

                <!-- Linked scripts -->
                @if (linkGroups.Any())
                {
                    <section class="border-[1.5px] border-[#1a1a1a] rounded-md p-5 mt-6">
                        <div class="flex items-baseline justify-between mb-1">
                            <h2 class="font-['Caveat'] text-[26px] font-bold">Linked scripts</h2>
                            <span class="text-[12px] text-[#a89f8e]">@linkTotal connections · grouped by relation</span>
                        </div>
                        <div class="mt-3 space-y-3">
                            @foreach (var g in linkGroups)
                            {
                                <div class="flex gap-3">
                                    <div class="w-32 shrink-0 text-[13px] text-[#a89f8e] pt-0.5">— @g.Key</div>
                                    <div class="flex-1 space-y-1">
                                        @foreach (var other in g.Value)
                                        {
                                            var cn = linkCatNames.TryGetValue(other.ScriptCatFK, out var n) ? n : null;
                                            <a asp-controller="Script" asp-action="Details" asp-route-scriptidpk="@other.ScriptIDPK"
                                               class="flex items-center gap-2 no-underline text-[#1a1a1a] hover:text-[#a89f8e]">
                                                <span class="font-bold text-[14px]">@other.ScriptTitle</span>
                                                @if (!string.IsNullOrEmpty(cn))
                                                {
                                                    <span class="px-2 py-0.5 rounded-full text-[11px] border border-[#a89f8e] text-[#a89f8e]">@cn</span>
                                                }
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }
            </div>

            <!-- RIGHT: infobox -->
            <aside>
                @if (infoEnabled)
                {
                    <div class="border-[1.5px] border-[#1a1a1a] rounded-md overflow-hidden sticky top-6">
                        <!-- title bar -->
                        <div class="bg-[#1a1a1a] text-[#f7f3ea] px-4 py-2 font-['Caveat'] text-[24px] font-bold text-center">
                            @(infoTitle ?? s?.ScriptTitle)
                        </div>

                        <!-- portrait -->
                        <div class="p-3">
                            <div class="aspect-[4/5] w-full border-[1.5px] border-dashed border-[#1a1a1a] bg-[repeating-linear-gradient(135deg,transparent_0_10px,rgba(26,26,26,0.08)_10px_11px)] flex items-center justify-center overflow-hidden @(string.IsNullOrEmpty(portraitPath) ? "" : "js-lightbox cursor-zoom-in")"
                                 data-gallery="script-@s.ScriptIDPK"
                                 data-full="@Pic(portraitPath)"
                                 data-caption="@(infoTitle ?? s?.ScriptTitle), the only known portrait"
                                 data-title="@(infoTitle ?? s?.ScriptTitle)"
                                 data-crumb="@world?.WorldName@(string.IsNullOrEmpty(catName) ? "" : " › " + catName)"
                                 data-meta="From @s?.ScriptTitle@(string.IsNullOrEmpty(author) ? "" : " · by @" + author)">
                                @if (!string.IsNullOrEmpty(portraitPath))
                                {
                                    <img src="@Pic(portraitPath)" alt="portrait" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <span class="text-[12px] text-[#a89f8e]">portrait</span>
                                }
                            </div>
                        </div>

                        <!-- rows -->
                        <div class="px-4 pb-4">
                            @foreach (var row in infoRows)
                            {
                                if (row.AttIsSection == true)
                                {
                                    <div class="text-center font-['Caveat'] text-[19px] font-bold border-b border-[#1a1a1a] mt-3 mb-2 pb-1">@row.AttName</div>
                                }
                                else
                                {
                                    <div class="flex gap-2 py-1 text-[13px] border-b border-dashed border-[#e5ddcb]">
                                        <div class="w-24 shrink-0 text-[#a89f8e]">@row.AttName</div>
                                        <div class="flex-1 whitespace-pre-line">@row.AttContent</div>
                                    </div>
                                }
                            }
                            @if (!infoRows.Any())
                            {
                                <p class="text-[12px] text-[#a89f8e] text-center py-2">No details recorded yet.</p>
                            }
                        </div>
                    </div>
                }
            </aside>
        </div>
    </div>
</div>
