@model WorldBuilder.Models.Script
@using WorldBuilder.Models

@{
    ViewData["Title"] = Model?.ScriptTitle ?? "Script";

    var s      = Model;
    var world  = ViewData["World"] as World;
    var author = ViewData["AuthorHandle"] as string;
    var catId  = ViewData["CatId"] as int?;
    var catName = ViewData["CatName"] as string;
    var subName = ViewData["SubName"] as string;

    var tags     = s?.ScriptTagTagFKs?.ToList()  ?? new List<Tag>();
    var pictures = s?.PicScriptPicFKs?.ToList()   ?? new List<Picture>();

    var infoEnabled  = ViewData["InfoEnabled"] as bool? ?? false;
    var infoTitle    = ViewData["InfoTitle"] as string;
    var portraitPath = ViewData["PortraitPath"] as string;
    var infoRows     = ViewData["InfoRows"] as List<WorldBuilder.Models.Attribute> ?? new List<WorldBuilder.Models.Attribute>();

    var linkGroups   = ViewData["LinkGroups"] as Dictionary<string, List<Script>> ?? new Dictionary<string, List<Script>>();
    var linkCatNames = ViewData["LinkCatNames"] as Dictionary<int, string> ?? new Dictionary<int, string>();
    var linkTotal    = linkGroups.Values.Sum(v => v.Count);

    var lastTouch = s?.ScriptUpdateAt ?? s?.ScriptCreateAt ?? DateTime.Today;

    // Resolve both storage conventions: "/uploads/…" (new) and "Images/…" (legacy)
    Func<string, string> Pic = p =>
        string.IsNullOrEmpty(p) ? null
        : (p.StartsWith("/") || p.StartsWith("http")) ? p : Url.Content("~/" + p);

    string Ago(DateTime d)
    {
        var days = (int)(DateTime.Today - d.Date).TotalDays;
        if (days <= 0) return "today";
        if (days == 1) return "yesterday";
        if (days < 7) return days + "d ago";
        if (days < 30) return (days / 7) + "w ago";
        if (days < 365) return (days / 30) + "mo ago";
        return (days / 365) + "y ago";
    }

    // Registry-aesthetic tokens (mirrors Home/Index.cshtml)
    const string hatch    = "bg-[repeating-linear-gradient(135deg,transparent_0_10px,rgba(26,26,26,0.08)_10px_11px)]";
    const string btnSmall = "inline-flex items-center gap-2 font-sans text-xs tracking-[.06em] uppercase px-3 py-1.5 border border-stone-300 bg-stone-100 text-stone-700 cursor-pointer hover:border-teal-900 hover:text-teal-900 transition-colors";
    const string iconBtn  = "inline-flex items-center justify-center w-8 h-8 border border-stone-300 bg-stone-100 text-stone-700 cursor-pointer hover:border-teal-900 hover:text-teal-900 transition-colors";
    const string panel    = "bg-stone-100 border border-stone-300 p-5";
}

<style>
    /* Typography for the Quill-authored body — registry house style */
    .reader-body {
        font-size: 16px;
        line-height: 1.7;
        color: var(--color-stone-800);
        overflow-wrap: break-word;
        word-break: break-word;
        max-width: 100%;
    }
    .reader-body h1, .reader-body h2, .reader-body h3 {
        font-family: var(--font-serif);
        font-weight: 600;
        letter-spacing: -.01em;
        line-height: 1.1;
        color: var(--color-stone-900);
    }
    .reader-body h1 { font-size: 30px; margin: 1.6rem 0 .6rem; }
    .reader-body h2 { font-size: 24px; margin: 1.4rem 0 .6rem; }
    .reader-body h3 { font-size: 19px; margin: 1.1rem 0 .4rem; }
    .reader-body p  { margin: 0 0 1rem; }
    .reader-body ul, .reader-body ol { margin: 0 0 1rem 1.25rem; }
    .reader-body ul { list-style: disc; }
    .reader-body ol { list-style: decimal; }
    .reader-body li { margin: .25rem 0; }
    .reader-body a  {
        color: var(--color-teal-900);
        text-decoration: underline;
        text-underline-offset: 2px;
    }
    .reader-body blockquote {
        border-left: 2px solid var(--color-stone-300);
        padding: .2rem 0 .2rem 1rem;
        margin: 1.2rem 0;
        font-style: italic;
        color: var(--color-stone-600);
    }
    .reader-body strong { font-weight: 600; }
    .reader-body em { font-style: italic; }
</style>

<div class="max-w-7xl mx-auto px-6 py-10 text-stone-900">

    <!-- Top bar: breadcrumb + updated + actions -->
    <div class="flex items-start justify-between gap-4 mb-6">
        <div class="flex items-center gap-2 font-sans text-xs text-stone-500 min-w-0">
            @if (world != null)
            {
                <a asp-controller="World" asp-action="Read" asp-route-id="@world.WorldIDPK"
                   class="no-underline text-stone-500 hover:text-teal-900 transition-colors truncate">@world.WorldName</a>
                <span>›</span>
            }
            @if (catId != null)
            {
                <a asp-controller="World" asp-action="Category" asp-route-id="@world?.WorldIDPK" asp-route-catId="@catId"
                   class="no-underline text-stone-500 hover:text-teal-900 transition-colors truncate">@catName</a>
            }
            @if (!string.IsNullOrEmpty(subName))
            {
                <span>›</span>
                <span class="text-stone-900 truncate">@subName</span>
            }
        </div>

        <div class="flex items-center gap-2 shrink-0">
            <span class="hidden sm:inline font-sans text-xs text-stone-500">
                updated @Ago(lastTouch)
            </span>
        </div>
    </div>

    <!-- Header: eyebrow + title -->
    <div class="flex items-baseline gap-3 flex-wrap">
        <span class="font-sans text-xs tracking-[.22em] uppercase text-teal-900">@(catName ?? "Registry entry")</span>
        <span class="font-sans text-xs tracking-[.08em] text-[#153640] bg-stone-100 px-[7px] py-[2px] border border-stone-200">SCR-@s?.ScriptIDPK.ToString("D4")</span>
    </div>
    <h1 class="font-serif font-semibold text-[clamp(32px,5vw,48px)] tracking-[-.02em] leading-[1.02] mt-2 mb-3">@s?.ScriptTitle</h1>

    <!-- Tags -->
    @if (tags.Any())
    {
        <div class="flex flex-wrap items-center gap-2 mb-8">
            <span class="font-sans text-xs tracking-[.16em] uppercase text-stone-500 mr-1">Tags</span>
            @foreach (var tag in tags)
            {
                <span class="inline-flex items-center gap-1.5 font-sans text-xs tracking-[.06em] uppercase px-2.5 py-1 border border-stone-300 text-stone-600">
                    <span class="w-2 h-2 rounded-full inline-block shrink-0" style="background-color:@tag.TagColor"></span>
                    @tag.TagName
                </span>
            }
        </div>
    }

    <!-- Body + sidebar -->
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-8 items-start">

        <!-- LEFT: readable body -->
        <div class="lg:col-span-7 min-w-0">
            <div class="reader-body text-wrap">
                @if (!string.IsNullOrWhiteSpace(s?.ScriptContent))
                {
                    @Html.Raw(s.ScriptContent)
                }
                else
                {
                    <p class="text-stone-500 italic">Nothing has been written for this entry yet.</p>
                }
            </div>

            <!-- Pictures -->
            @if (pictures.Any())
            {
                <section class="@panel mt-10">
                    <div class="flex items-baseline justify-between mb-3 pb-3 border-b border-stone-300">
                        <h2 class="font-serif font-medium text-2xl tracking-[-.01em] leading-[1.05]">Pictures</h2>
                        <span class="font-sans text-xs tracking-[.16em] uppercase text-stone-500">@pictures.Count picture@(pictures.Count == 1 ? "" : "s")</span>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
                        @foreach (var p in pictures)
                        {
                            <figure class="m-0 @(string.IsNullOrEmpty(p.PicPath) ? "" : "js-lightbox cursor-zoom-in")"
                                    data-gallery="script-@s.ScriptIDPK"
                                    data-full="@Pic(p.PicPath)"
                                    data-caption="@p.PicCaption"
                                    data-title="@(string.IsNullOrEmpty(p.PicCaption) ? s?.ScriptTitle : p.PicCaption)"
                                    data-crumb="@world?.WorldName@(string.IsNullOrEmpty(catName) ? "" : " › " + catName)@(string.IsNullOrEmpty(subName) ? "" : " › " + subName)"
                                    data-meta="From @s?.ScriptTitle@(string.IsNullOrEmpty(author) ? "" : " · by @" + author)"
                                    data-back="@Url.Action("Details", "Script", new { scriptidpk = s?.ScriptIDPK })">
                                <div class="aspect-square border border-stone-300 @hatch overflow-hidden flex items-center justify-center transition-colors hover:border-teal-900">
                                    @if (!string.IsNullOrEmpty(p.PicPath))
                                    {
                                        <img src="@Pic(p.PicPath)" alt="@p.PicCaption" class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        <span class="font-sans text-xs tracking-[.16em] uppercase text-stone-400">Picture</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(p.PicCaption))
                                {
                                    <figcaption class="font-sans text-xs text-stone-600 mt-1.5 leading-snug">@p.PicCaption</figcaption>
                                }
                            </figure>
                        }
                    </div>
                </section>
            }

            <!-- Linked scripts -->
            @if (linkGroups.Any())
            {
                <section class="@panel mt-6">
                    <div class="flex items-baseline justify-between mb-3 pb-3 border-b border-stone-300">
                        <h2 class="font-serif font-medium text-2xl tracking-[-.01em] leading-[1.05]">Linked scripts</h2>
                        <span class="font-sans text-xs tracking-[.16em] uppercase text-stone-500">@linkTotal connection@(linkTotal == 1 ? "" : "s")</span>
                    </div>
                    <div class="space-y-4">
                        @foreach (var g in linkGroups)
                        {
                            <div class="flex gap-4">
                                <div class="w-32 shrink-0 font-sans text-xs tracking-[.16em] uppercase text-teal-900 pt-1">@g.Key</div>
                                <div class="flex-1 space-y-1.5">
                                    @foreach (var other in g.Value)
                                    {
                                        var cn = linkCatNames.TryGetValue(other.ScriptCatFK, out var n) ? n : null;
                                        <a asp-controller="Script" asp-action="Details" asp-route-scriptidpk="@other.ScriptIDPK"
                                           class="flex items-center gap-2 no-underline text-stone-900 hover:text-teal-900 transition-colors">
                                            <span class="font-serif font-semibold text-base">@other.ScriptTitle</span>
                                            @if (!string.IsNullOrEmpty(cn))
                                            {
                                                <span class="font-sans text-xs tracking-[.06em] uppercase px-2 py-[3px] border border-stone-300 text-stone-600">@cn</span>
                                            }
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        </div>

        <!-- RIGHT: infobox -->
        <aside class="lg:col-span-5 min-w-0">
            @if (infoEnabled)
            {
                <div class="bg-stone-100 border border-stone-300 overflow-hidden sticky top-20">
                    <!-- title bar -->
                    <div class="bg-stone-900 text-stone-50 px-4 py-2.5 font-serif font-semibold text-lg tracking-[-.01em] text-center">
                        @(infoTitle ?? s?.ScriptTitle)
                    </div>

                    <!-- portrait -->
                    <div class="p-3">
                        <div class="aspect-[4/5] w-full border border-stone-300 @hatch flex items-center justify-center overflow-hidden @(string.IsNullOrEmpty(portraitPath) ? "" : "js-lightbox cursor-zoom-in")"
                             data-gallery="script-@s.ScriptIDPK"
                             data-full="@Pic(portraitPath)"
                             data-caption="@(infoTitle ?? s?.ScriptTitle), the only known portrait"
                             data-title="@(infoTitle ?? s?.ScriptTitle)"
                             data-crumb="@world?.WorldName@(string.IsNullOrEmpty(catName) ? "" : " › " + catName)"
                             data-meta="From @s?.ScriptTitle@(string.IsNullOrEmpty(author) ? "" : " · by @" + author)">
                            @if (!string.IsNullOrEmpty(portraitPath))
                            {
                                <img src="@Pic(portraitPath)" alt="portrait" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <span class="font-sans text-xs tracking-[.16em] uppercase text-stone-400">Portrait</span>
                            }
                        </div>
                    </div>

                    <!-- rows -->
                    <div class="px-4 pb-4">
                        @foreach (var row in infoRows)
                        {
                            if (row.AttIsSection == true)
                            {
                                <div class="font-sans text-xs tracking-[.16em] uppercase text-teal-900 font-semibold text-center border-b border-stone-300 mt-4 mb-2 pb-1.5">@row.AttName</div>
                            }
                            else
                            {
                                <div class="flex gap-3 py-1.5 font-sans text-xs border-b border-stone-200 last:border-b-0">
                                    <div class="w-24 shrink-0 text-stone-500">@row.AttName</div>
                                    <div class="flex-1 text-stone-800 whitespace-pre-line">@row.AttContent</div>
                                </div>
                            }
                        }
                        @if (!infoRows.Any())
                        {
                            <p class="font-sans text-xs text-stone-500 text-center py-3">No details recorded yet.</p>
                        }
                    </div>
                </div>
            }
        </aside>
    </div>
</div>
